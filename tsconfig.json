{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "target": "ES2020",
    "module": "CommonJS",
    "esModuleInterop": true
  },
  "include": [
    "app/**/*.js",
    "app.js",
    "deploy.js"
  ],
  "exclude": [
    "node_modules",
    "public/vendors",
    "public/vendors/**/*"
  ]
}
