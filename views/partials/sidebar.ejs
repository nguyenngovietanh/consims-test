      const navItem = `<li class="nav-item">
        <a class="nav-link consims-nav-link" href="${item.link}" data-link="${item.link}" data-reload="${reload}">
          <span class="consims-nav-icon">${senapp.sidebar.getIconHtml(item)}</span>
          <span class="nav-link-text">${menuName}</span>
        </a>
      </li>`;
      $(containerSelector).append(navItem);
    };
    senapp.sidebar.hydrateStaticIcons();
    (senapp.menu || []).forEach(function (item) {
      if (!item || !item.link) return;
      if (item.link === "/") return;
      senapp.sidebar.menu.push(item);
      const isPrimary = senapp.sidebar.primaryMenuLinks.some(function (link) {
        return item.link.indexOf(link) === 0;
      });
      if (isPrimary) {
        senapp.sidebar.renderMenuItem(item, "#navbarVerticalMenu");
      }
    });
    senapp.sidebar.menu.forEach(function (item) {
      const isPrimary = senapp.sidebar.primaryMenuLinks.some(function (link) {
        return item.link.indexOf(link) === 0;
      });
      if (!isPrimary) {
        senapp.sidebar.renderMenuItem(item, "#navbarVerticalMenu");
      }
    });
    senapp.sidebar.menuclickbydatalink = function (datalink) {
      const linkElement = $(".consims-sidebar a[data-link='" + datalink + "']");
      if (linkElement.length > 0) {
        const event = $.Event("click");
        linkElement.trigger(event);
      } else {
        console.warn("No link found with data-link:", datalink);
      }
    };
    senapp.sidebar.setActiveLink = function (href) {
      href = href || "/";
      $(".consims-sidebar a.nav-link").removeClass("active");
      const exactLink = $(".consims-sidebar a[data-link='" + href + "']");
      if (exactLink.length > 0) {
        exactLink.first().addClass("active");
        return;
      }
      $(".consims-sidebar a[data-link]").each(function () {
        const link = $(this).data("link");
        if (link && link !== "/" && href.indexOf(link) === 0) {
          $(this).addClass("active");
          return false;
        }
      });
      if (href === "/" && $(".consims-sidebar a.nav-link.active").length === 0) {
        $(".consims-sidebar a[data-link='/']").first().addClass("active");
      }
    };
    senapp.sidebar.pageLoadTimer = null;
    senapp.sidebar.setPageLoading = function (isLoading) {
      const content = document.getElementById("maincontent");
      if (!content) return;
      content.classList.toggle("is-page-loading", isLoading);
    };
    senapp.sidebar.menuclick = function (event) {
      if ($(this).data("reload") !== true) {
        event.preventDefault();
        const href = $(this).attr("href");
        if (!href) return;

        window.clearTimeout(senapp.sidebar.pageLoadTimer);
        senapp.sidebar.setActiveLink($(this).data("link") || href);
        senapp.sidebar.setPageLoading(true);

        senapp.sidebar.pageLoadTimer = window.setTimeout(function () {
          $("#maincontent").load(href, function (_response, status) {
            if (status === "error") {
              senapp.sidebar.setPageLoading(false);
              window.location.href = href;
              return;
            }

            window.requestAnimationFrame(function () {
              window.setTimeout(function () {
                senapp.sidebar.setPageLoading(false);
              }, 80);
            });

          const ham = document.querySelector('button.navbar-toggler-humburger-icon');
          if (ham && ham.getAttribute("aria-expanded") === "true") {
            ham.click();
          }
          });
        }, 120);
      }
    };
    $(".consims-sidebar").on("click", "a.nav-link[data-link]", senapp.sidebar.menuclick);
    $(".consims-sidebar").on("click", "a.nav-link[data-static-link]", function (event) {
      event.preventDefault();
      $(".consims-sidebar a.nav-link").removeClass("active");
      $(this).addClass("active");
    });
    senapp.sidebar.setActiveLink(window.location.pathname);

    (function() {
  const NAVBAR_MAP = {
    'dashboard': { title: 'Contract Dashboard', desc: 'Real-time overview of project performance and health' },
    'contract': { title: 'Contract List', desc: 'Manage information and status of contracts in the system' },
    'submissionReview': { title: 'Submission Review', desc: 'Review and evaluate submission forms from contractors' },
    'payment': { title: 'Payment', desc: 'Manage payment periods and cumulative payment records' },
    'help': { title: 'Help Center', desc: 'Guidance on using the consIMS system and answering questions' },
    'settings': { title: 'Settings', desc: 'Configure system parameters and customize your account' }
  };

  function updateNavbarText(key) {
    const config = NAVBAR_MAP[key];
    if (!config) return;

    const titleEl = document.getElementById('navbar-title');
    const descEl = document.getElementById('navbar-description');

    if (titleEl) titleEl.textContent = config.title;
    if (descEl) descEl.textContent = config.desc;
  }

  // Lắng nghe sự kiện click bằng cơ chế Event Delegation (bắt từ document)
  document.addEventListener('click', function(event) {
    const target = event.target;
    const sidebarLink = target.closest('.consims-sidebar a.nav-link');
    
    if (sidebarLink) {
      // 1. Kiểm tra menu tĩnh trước
      const staticLink = sidebarLink.getAttribute('data-static-link');
      if (staticLink && NAVBAR_MAP[staticLink]) {
        updateNavbarText(staticLink);
        return;
      }

      // 2. Lấy tên hiển thị (text) bên trong menu để nhận diện chính xác tuyệt đối, tránh nhận nhầm URL lồng nhau
      const linkText = (sidebarLink.querySelector('.nav-link-text')?.textContent || '').trim().toLowerCase();
      const linkPath = (sidebarLink.getAttribute('data-link') || sidebarLink.getAttribute('href') || '').toLowerCase();
      
      // Ưu tiên nhận diện bằng Text hiển thị của Menu trước để chính xác 100%
      if (linkText.includes('submission') || linkText.includes('review')) {
        updateNavbarText('submissionReview');
      } else if (linkText.includes('payment')) {
        updateNavbarText('payment');
      } else if (linkText.includes('contract')) {
        updateNavbarText('contract');
      } else if (linkText.includes('dashboard')) {
        updateNavbarText('dashboard');
      } 
      // Phương án dự phòng (Fallback) quét theo URL giống cũ nếu text không khớp
      else if (linkPath) {
        if (linkPath === '/' || linkPath.includes('dashboard')) {
          updateNavbarText('dashboard');
        } else if (linkPath.includes('submission') || linkPath.includes('review')) {
          updateNavbarText('submissionReview');
        } else if (linkPath.includes('payment') || linkPath.includes('order')) {
          updateNavbarText('payment');
        } else if (linkPath.includes('contract')) {
          updateNavbarText('contract');
        }
      }
    }
  }, true); // Giữ nguyên capture: true để chạy thâu tóm sự kiện trước

  // Đồng thời xử lý trường hợp F5 (tải lại trang đầu tiên)
  // Đợi menu động render xong hoàn toàn mới check active link hiện tại
  setTimeout(() => {
    const activeText = ($('.consims-sidebar a.nav-link.active .nav-link-text').text() || '').trim().toLowerCase();
    if (activeText.includes('submission') || activeText.includes('review')) {
      updateNavbarText('submissionReview');
    }
  }, 300);
})();

  </script>
</nav>
