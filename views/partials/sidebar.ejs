    senapp.sidebar.getIconHtmlByKey = function (iconKey) {
      const icon = senapp.sidebar.icons[iconKey] || senapp.sidebar.icons.contract;
      return `${icon.outline || ""}${icon.filled || ""}`;
    };
    senapp.sidebar.getIconHtml = function (item) {
      return senapp.sidebar.getIconHtmlByKey(senapp.sidebar.iconKeyMap[item.menuname] || "contract");
    };
    senapp.sidebar.hydrateStaticIcons = function () {
      document.querySelectorAll(".consims-sidebar [data-icon-key]").forEach(function (el) {
        el.innerHTML = senapp.sidebar.getIconHtmlByKey(el.getAttribute("data-icon-key"));
      });
    };
