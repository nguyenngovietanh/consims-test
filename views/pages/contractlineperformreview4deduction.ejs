    contractlineperformreviewobject.lineobject.accept = async function (element) {
      //hàm chấp thuận dòng
      //console.log('Accept line');
    };
    contractlineperformreviewobject.lineobject.viewfile = async function (element) {
      //hàm xem file đính kèm của dòng
      const data = contractlineperformreviewobject.form.data;
      const id = data[contractlineperformreviewobject.form.keyfield];
      const assignmentid = element.getAttribute('data-assignmentid') || 0;
      const url = `${'/common/files?viewname=contractlineperformfiles'}&submissionid=${id}&assignmentid=${assignmentid}&displaymode=by_assignment&worktype=${encodeURIComponent(contractlineperformreviewobject.model.url.query.worktype || '')}`;
