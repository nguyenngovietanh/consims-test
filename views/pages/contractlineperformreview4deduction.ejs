      roleSelect.addEventListener('change', function () {
        const roleValue = roleSelect.value;
        //tìm  field 'Role' trong filterRows và cập nhật giá trị
        const filter = contractlineperformreviewobject.lineobject.filterRows.find(item => item.field === 'Role');
        if (filter) {
          filter.value = roleValue;
        } else {
          contractlineperformreviewobject.lineobject.filterRows.push({ field: 'Role', operator: 'equals', value: roleValue });
        }
        contractlineperformreviewobject.lineobject.localFilter(roleSelect);
      });
      statusSelect.addEventListener('change', function () {
        const statusValue = statusSelect.value == 'All' ? '' : statusSelect.value;

        const filter = contractlineperformreviewobject.lineobject.filterRows.find(item => item.field === 'ApprovalStatus');
        if (filter) {
          filter.value = statusValue;
        } else {
          contractlineperformreviewobject.lineobject.filterRows.push({ field: 'ApprovalStatus', operator: 'equals', value: statusValue });
        }
        contractlineperformreviewobject.lineobject.localFilter(statusSelect);
      });

      checkboxMyDutyOnly.addEventListener('change', function () {
        const isChecked = checkboxMyDutyOnly.checked;
        const filter = contractlineperformreviewobject.lineobject.filterRows.find(item => item.field === 'MyDuty');
        if (filter) {
          filter.value = isChecked ? 'Yes' : '';
        } else {
          contractlineperformreviewobject.lineobject.filterRows.push({ field: 'MyDuty', operator: 'equals', value: isChecked ? 'Yes' : '' });
        }
        contractlineperformreviewobject.lineobject.localFilter(checkboxMyDutyOnly);
      });

