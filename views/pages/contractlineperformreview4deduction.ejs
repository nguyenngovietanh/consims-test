        title: `Files of ${data["SubmissionName"] || ''}`,
        url: url,
        size: 'md'
      });

      // //console.log('View Files');
    };
    contractlineperformreviewobject.lineobject.loadLine = async function () {
      const formobject = contractlineperformreviewobject.form;
      const masterdata = formobject.data;

      // const urldata = JSON.parse(JSON.stringify(contractlineperformreviewobject.lineobject.urldata));
      // let datanew =JSON.parse(JSON.stringify(contractlineperformreviewobject.lineobject.model.datanew));
      // datanew.ParentId = formobject.data[contractlineperformreviewobject.form.keyfield];
      // urldata.listnews += `?pagesize=0&ParentId=${datanew.ParentId}`;

      let tblline = new senapp.utils.table({
        // datanew: datanew,
        meta: contractlineperformreviewobject.lineobject.model.meta,
        urldata: {
          update: '/contractlineperform/editline?itemworktype=' + encodeURIComponent(contractlineperformreviewobject.model.url.query.itemworktype || ''),
        },
        container: formobject.container.querySelector('#contractlineperformreview-line-section'),//khu vực chứa danh sách
        filterrow: false,
        allowsorting: false, //cho phép sắp xếp hay không
        addrow: false, // cho phép thêm mới
        editrow: true, // cho phép sửa
        deleterow: false, // cho phép xóa
        addnewfirst: false, //thêm mới vào đầu danh sách
        readonly: false,
        actionbuttons: { savenews: false }, //hiển thị các nút hành động
        loadmoreonvisible: true, // tự động tải thêm dữ liệu khi cuộn đến cuối danh sách   
        metacolumns: [
          { field: 'SysAction', visible: false, colorder: -9 },
          { field: 'Ext01', description: 'Decision', colorder: 810, visible: false, show: true, gridwidth: 120 },
          { field: 'Ext02', description: 'Attachments', colorder: 850, visible: true, show: true, gridwidth: 120 },

        ],
        customcolumns: ['Ext01', 'Ext02'], // Danh sách các cột tùy chỉnh khi render cell        

      });

      tblline.genCellDataCustom = function ({ data, metacolumn }) {
        if (!metacolumn || !metacolumn.field) {
          return null; // Trả về null nếu không có metacolumn hoặc field
        }
        // Hàm này sẽ được sử dụng để tạo dữ liệu cho các cột tùy chỉnh
        const tableobject = this;
        const td = document.createElement('td');
        td.setAttribute('data-field', metacolumn.field);
        //nếu field.visible là false hoặc field.show là false thì không hiển thị cột này  gán class d-none
        if (!metacolumn.show || !metacolumn.visible) { td.classList.add('d-none'); }
        switch (metacolumn.field) {
          case 'Ext01':
            td.innerHTML = `<a href="javascript:;" onclick="contractlineperformreviewobject.lineobject.accept(this)" title="Accept">Accept</a>`;
            break;
          case 'Ext02':
            td.innerHTML = `<a href="javascript:;" data-assignmentid="${data['AssignmentId'] || 0}" onclick="contractlineperformreviewobject.lineobject.viewfile(this)" title="View Files">View</a>`;
            break;
          default:
            //nếu không phải là cột tùy chỉnh thì trả về giá trị của trường đó
            td.innerHTML = data[metacolumn.field] || '';
            break;
        }
        return td;
      }

      //tạm khóa không cần lưu khi thay đổi dòng
      tblline.synData = async function ({ data, type, mode } = {}) {
        data.SysDataStatus = 'Update';
        return { status: 1, message: '', data: {}, errors: {} };
      };

      //hàm map quyền editable cho cell dùng cho override
      tblline.mapCellEditableExt = function ({ td, data, metacolumn }) {
        return data['MyDuty'] === 'Yes';
      }

      //hàm genCellData để tạo dữ liệu cho bảng
      tblline.genCellData = function ({ data, metacolumn }) {
        //nếu metacolumn.field chứa trong customcolumns thì gọi hàm genCellDataCustom
        if (this.customcolumns && this.customcolumns.includes(metacolumn.field)) {
          return this.genCellDataCustom({ data, metacolumn });
        }

        //nếu metacolumn.field là 'SysNo' thì nội dung bằng số dòng trong tbody tr trong bảng
        if (metacolumn.field === 'SysNo') {
          return this.genCellDataNo({ data: data, metacolumn: metacolumn });
        }

        //nếu metacolumn.field là 'SysSelect' thì trả về tdselect
        if (metacolumn.field === 'SysSelect') {
          return this.genCellDataSelect({ data: data, metacolumn: metacolumn });
        }

        //nếu metacolumn.field là 'SysAction' thì trả về tdaction
        if (metacolumn.field === 'SysAction') {
          return this.genCellDataAction({ data: data, metacolumn: metacolumn });
        }
        if (metacolumn.visible === false) { return null; }
        const td = document.createElement('td');
        td.setAttribute('data-field', metacolumn.field);
        //set tabindex
        td.setAttribute('tabindex', '0');
        //nếu field.show là false thì không hiển thị cột này  gán class d-none
        if (!metacolumn.show) { td.classList.add('d-none'); }

        //nếu trường có tồn tại data thì map giá trị với data 
        if (metacolumn.data) {
          const mappedValue = metacolumn.data.find(item => item.id === data[metacolumn.field]);
          td.textContent = mappedValue ? mappedValue.label : '';
          //gán quyền chỉnh sửa cho cell
          this.mapCellEditable({ td: td, data: data, metacolumn: metacolumn });
          return td;
        }

        //nếu có inputtype== 'checkbox' 
        if (metacolumn.inputtype && metacolumn.inputtype === 'checkbox' && (metacolumn.type === 'bool' || metacolumn.type === 'boolean')) {
          // check của fontawesome  nếu data[metacolumn.field] là true thì checked nếu false thì unchecked
          // td.innerHTML = `<div class="form-check"> <input style="opacity:1;" class="form-check-input" type="checkbox" disabled ${data[metacolumn.field] ? 'checked' : ''}></div>`;
          // td.innerHTML = `<div class="form-check form-switch"> <input class="form-check-input" type="checkbox" disabled ${data[metacolumn.field] ? 'checked' : ''}></div>`;
          // td.innerHTML = `<i class="fa-regular ${data[metacolumn.field] ? 'fa-square-check' : 'fa-square'}"></i>`;

          const checkbox = document.createElement('input');
          checkbox.type = 'checkbox';
          checkbox.className = 'form-check-input';
          checkbox.classList.add('cell-editor');
          checkbox.value = data[metacolumn.field];
          checkbox.style.opacity = '1';
          //nếu data[metacolumn.field]==true thì checkbox chọn
          if (data[metacolumn.field] == true) { checkbox.checked = true; }
          //khi thay đổi thì gọi hàm updateData của  tableobject
          checkbox.onchange = function () {
            data[metacolumn.field] = this.checked;
            // phát sự kiện nếu thay đổi
            td.dispatchEvent(new CustomEvent("cellchange", {
              bubbles: true,
              detail: { oldValue: !data[metacolumn.field], newValue: this.checked, cell: td }
            }));
            //tableobject.updateByKey(data[tableobject.keyfield]);
          };
          td.appendChild(checkbox);
          //gán quyền chỉnh sửa cho cell
          this.mapCellEditable({ td: td, data: data, metacolumn: metacolumn });
          return td;
        }

        td.innerHTML = senapp.data.stringifyValue(data[metacolumn.field], metacolumn);
        //gán quyền chỉnh sửa cho cell
        this.mapCellEditable({ td: td, data: data, metacolumn: metacolumn });
        return td;
      };

      tblline.genRowDataExtClass = function ({ tr, data }) {
        //nếu data.ApprovalStatus == 'Accepted' thì gán class row-accepted
        if (data.MyDuty !== 'Yes') {
          tr.classList.add('bg-light');
        }
      }

      //hàm genRowData để tạo dữ liệu cho bảng
      tblline.genRowData = function ({ data }) {
        const tableobject = this;
        const tr = document.createElement('tr');
        //gán giá trị keyfield vào thuộc tính data-id của tr
        tr.setAttribute('data-id', data[tableobject.keyfield]);
        tr.className = 'row-data';

        this.metacolumns.forEach(column => {
          const td = tableobject.genCellData({ data: data, metacolumn: column });
          // Bắt event trực tiếp ở chính cell
          if (td) {
            td.addEventListener("cellchange", async (e) => {
              // //console.log("Old:", e.detail.oldValue, "New:", e.detail.newValue);
              if (e.detail.oldValue === e.detail.newValue) return;
              //nếu giá trị cũ khác giá trị mới thì mới thì đánh dấu dòng thay đổi
              tr.classList.add('edited');
              await tableobject.onChangeCell({ td: td, data: data });
            });
            //gán class kiểu dữ liệu
            td.classList.add('type-' + (column.type || 'string').toLowerCase());
            tr.appendChild(td);
          }

        });

        tr.addEventListener("focusin", () => {
          // tr.classList.add("table-active");
          // //console.log("focus in row", tr.rowIndex);
        });

        tr.addEventListener("focusout", async (e) => {
          // e.relatedTarget = phần tử chuẩn bị được focus tiếp theo
          // nếu phần tử đó vẫn nằm trong cùng tr thì KHÔNG xoá active
          if (!tr.contains(e.relatedTarget)) {
            // tr.classList.remove("table-active");
            await tableobject.onChangeRow({ tr: tr, data: data });
          }
        });

        this.genRowDataExtClass({ tr: tr, data: data });

        return tr;
      }

      //hàm tạo lookupparam để gửi lên server
      tblline.lookupparam = function ({ lookup, data }) {
        //console.log('lookupparam:', lookup, data);
        return `lookupType=contractlineperformreviewstatusupdate&role=${data.Role}&pagesize=${lookup.pagesize || 0}&filter=${encodeURIComponent(JSON.stringify(lookup.filter))}`;
      }

      tblline.loadDataCurrent = async function ({ datas } = {}) {
        if (!datas) { datas = this.datas; }
        const tableobject = this;
        senapp.window.loading.show(tableobject.tableelement.parentElement);
        try {
          //gán dữ liệu cho tableobject.datas
          tableobject.datas.length = 0; //xóa dữ liệu cũ
          tableobject.datas.push(...datas);
          //xóa dữ liệu cũ trên giao diện
          const tbody = tableobject.tableelement.querySelector('tbody.row-datas');
          datas.forEach(data => {
            const tr = tableobject.genRowData({ data: data });
            tbody.appendChild(tr);
          });
          senapp.window.loading.hide(tableobject.tableelement.parentElement);
        } catch (err) {
          console.error(err);
          alert("Error loading data");
          senapp.window.loading.hide(tableobject.tableelement.parentElement);
        }
      };

      await tblline.initTable();
      // tblline.datas.push(...masterdata.datas);
      tblline.loadDataCurrent({ datas: masterdata.Data || [] });


      //console.log(tblline.datas);
      contractlineperformreviewobject.lineobject.tblline = tblline;
      contractlineperformreviewobject.lineobject.tbllines[masterdata[formobject.keyfield]] = tblline;
    };

    //#endregion line

    //#region form saveBefore
    contractlineperformreviewobject.form.saveBefore = async function () {
      const formobject = this;
      let valid = true;
      senapp.window.loading.show(this.container); // Hiển thị loading
      // Gửi dữ liệu đến server để cập nhật data
      //map dữ liệu từ form vào model
      senapp.utils.input2datas({ meta: this.meta, data: this.data, container: this.container });
      const url = new URL(formobject.urldata.path, window.location.origin);
      url.searchParams.append('mode', 'validate'); //chỉ kiểm tra hợp lệ không thêm mới
      //gọi api validate
      const response = await senapp.data.synServer({ url: url, data: this.data, meta: this.meta });
      senapp.window.loading.hide(); // Ẩn loading
      if (response.status == 0) {
        this.mapErrors(response);
        valid = false;
      }
      //kiểm tra dữ liệu bảng con
      for (const key in contractlineperformreviewobject.lineobject.tbllines) {
        const tblline = contractlineperformreviewobject.lineobject.tbllines[key];
        //quét tblline.datanews để validate từng dòng
        for (let i = 0; i < tblline.datanews.length; i++) {
          const item = tblline.datanews[i];
          const response = await tblline.validateServer({ data: item });
          if (response && response.status == 0) { valid = false; }
        }
        //kiểm tra xóa các dòng đã xóa trên giao diện mà là dữ liệu đã lưu trên server
        //lọc các dòng đã xóa có keyfield>0
        const deletedRows = tblline.datadeleteds.filter(item => item[tblline.keyfield] > 0);
        //cho vòng lặp kiểm tra từng dòng đã xóa
        for (let i = 0; i < deletedRows.length; i++) {
          const item = deletedRows[i];
          const response = await tblline.validateServer({ data: item, type: 'delete' });
          if (response && response.status == 0) { valid = false; }
        }
      }


      return valid;
    };
