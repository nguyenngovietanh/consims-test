    contractlineperformreviewobject.save = async function () {
      const formobject = contractlineperformreviewobject.form;
      // const changedRows = contractlineperformreviewobject.lineobject.tblline.datas.filter(row => row.SysDataStatus === 'Update' || row.SysDataStatus === 'Create' || row.SysDataStatus === 'Delete');
      const changedRows = contractlineperformreviewobject.lineobject.tblline.datas.filter(row => row.SysDataStatus === 'Update' && row.MyDuty === 'Yes');

      senapp.window.loading.show();
      const promises = changedRows.map(row =>
        contractlineperformreviewobject.lineobject.tblline.updateByKey(row[contractlineperformreviewobject.lineobject.tblline.keyfield])
          //cập nhật trạng thái về null sau khi lưu
          .then(() => { row.SysDataStatus = null; })
      );
      try {
        await Promise.all(promises);
        senapp.window.loading.hide();
        //console.log("Tất cả đã lưu xong!");

        //đóng modal nếu có
        const modal = formobject.container.closest('.modal');
        if (modal) {
          const bootstrapModal = bootstrap.Modal.getInstance(modal);
          bootstrapModal.hide();
        }
        else {
          //nếu có offcanvas thì đóng offcanvas
          const offcanvas = formobject.container.closest('.offcanvas');
          if (offcanvas) {
            const bootstrapOffcanvas = bootstrap.Offcanvas.getInstance(offcanvas);
            bootstrapOffcanvas.hide();
          }
        }
        //nếu có callback thì gọi callback
        if (formobject.urldata.query.callback) {
          senapp.utils.executefunctionbyname(formobject.urldata.query.callback, window, [response]);
        }
      } catch (err) {
        senapp.window.alert({ message: `⚠️ ${await senapp.utils.text.t('Có lỗi khi lưu:')}`, type: 'danger' });
        console.error("Có lỗi khi lưu:", err);
      }
    };

