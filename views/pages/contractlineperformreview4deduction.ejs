<div id="contractlineperformreview-section" class="" style="margin: 0 auto;">
  <form id="contractlineperformreview-form">
    <div class="card">
      <div class="card-header">
        <h4 class="mb-2"><%= title %></h4>
        <div class="text-body-tertiary mt-0 fw-bold">[<%= model.data.datas[0].ItemName %>]</div>
        <div class="text-body-tertiary mt-0 fw-bold">[<%= model.data.datas[0].SubmissionName %>]</div>
      </div>

      <div class="card-body">
        <!-- Thông báo tổng -->
        <div class="message-all callout d-none" role="alert"></div>
        <div class="row g-3 align-items-center mb-1">
          <div class="col-md-12">
            <div class="row mb-2">
              <div class="col-md-3">
                <label for="contractlineperformreview-OverallApprovalStatus" field-name="OverallApprovalStatus" class="control-label">Overall Approval Status:</label>
                <div id="contractlineperformreview-OverallApprovalStatus" name="OverallApprovalStatus" class="form-control bg-light sen-display"><div style="height:20px;"></div></div>
              </div>
              <div class="col-md-3">
                <label for="contractlineperformreview-RoleValidation" field-name="RoleValidation" class="control-label">Role Validation:</label>
                <div id="contractlineperformreview-RoleValidation" name="RoleValidation" class="form-control bg-light sen-display"><div style="height:20px;"></div></div>
              </div>

              <div class="col-md-3">
                <!-- //danh sách role raci -->
                <label for="contractlineperformreview-Role" field-name="Role" class="control-label">Role:</label>
                <select id="contractlineperformreview-Role" name="Role" class="form-select">
                  <option value="">All</option>
                </select>
              </div>
              <div class="col-md-3">
                <!-- //danh sách status -->
                <label for="contractlineperformreview-Status" field-name="Status" class="control-label">Status:</label>
                <select id="contractlineperformreview-Status" name="Status" class="form-select">
                </select>
              </div>
            </div>
            <div class="row">
              <div class="col-md-3">
                <label for="contractlineperformreview-Unit" field-name="Unit" class="control-label">Unit:</label>
                <div id="contractlineperformreview-Unit" name="Unit" class="form-control bg-light sen-display"><div style="height:20px;"></div></div>
              </div>
              <div class="col-md-3">
                <label for="contractlineperformreview-ContractedUnitPrice" field-name="ContractedUnitPrice" class="control-label">Unit Price:</label>
                <div id="contractlineperformreview-ContractedUnitPrice" name="ContractedUnitPrice" class="form-control bg-light sen-display"><div style="height:20px;"></div></div>
              </div>
              <div class="col-md-3">
                <!-- //danh sách role raci -->
                <label for="contractlineperformreview-MyDutyOnly" field-name="MyDutyOnly" class="control-label">My Duty Only:</label>
                <input type="checkbox" id="contractlineperformreview-MyDutyOnly" name="MyDutyOnly" class="form-check-input">
              </div>
              <div class="col-md-3">
                <!-- //hiển thị danh sách files -->
                <a href="javascript:void(0)" id="contractlineperformreview-attachment-link" class="btn btn-subtle-secondary">All Files</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card-body" id="contractlineperformreview-line-section">
        <div class="table-responsive">
          <table class="table table-sm fs-9 mb-5">
            <tbody class="list"> </tbody>
          </table>
        </div>
      </div>

      <div class="card-footer">
        <button type="button" class="btn btn-subtle-primary" onclick="contractlineperformreviewobject.save()">Save &
          Close</button>
        <button type="button" class="btn btn-subtle-secondary"
          onclick="contractlineperformreviewobject.form.cancel()">Cancel</button>
      </div>
    </div>
  </form>

