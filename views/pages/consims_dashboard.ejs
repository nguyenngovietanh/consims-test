    function wrapAxisLabel(value) {
      const text = String(value || "");
      const firstLineLimit = 15;
      const secondLineLimit = 14;
      if (text.length <= firstLineLimit) return text;

      const words = text.split(" ");
      let first = "";
      let rest = "";

      words.forEach(function (word) {
        if ((first + " " + word).trim().length <= firstLineLimit) {
          first = (first + " " + word).trim();
        } else {
          rest = (rest + " " + word).trim();
        }
      });

      if (!first) {
        first = text.slice(0, firstLineLimit);
        rest = text.slice(firstLineLimit);
      }

      if (rest.length > secondLineLimit) rest = rest.slice(0, secondLineLimit - 3).trim() + "...";
      return first + (rest ? "\n" + rest : "");
    }

