    function baseGrid() {
      return { left: 42, right: 18, top: 28, bottom: 56 };
    }

    function chart(name, option) {
      if (!window.echarts || chartInstances[name]) return;
      const el = root.querySelector('[data-dashboard-chart="' + name + '"]');
      if (!el || !el.offsetParent) return;
      const instance = echarts.init(el);
      instance.setOption(option);
      chartInstances[name] = instance;
      consimsScheduleChartResize(name);
    }

    function setChartOption(name, option) {
      if (!window.echarts) return;
      const el = root.querySelector('[data-dashboard-chart="' + name + '"]');
      if (!el || !el.offsetParent) return;
      if (!chartInstances[name]) chartInstances[name] = echarts.init(el);
      chartInstances[name].setOption(option, true);
      consimsScheduleChartResize(name);
    }

    function resizeCharts() {
      Object.keys(chartInstances).forEach(function (key) { chartInstances[key].resize(); });
    }

    function consimsInitChartResizeObserver() {
      if (!window.ResizeObserver) return;

      const chartResizeObserver = new ResizeObserver(function () {
        window.requestAnimationFrame(resizeCharts);
      });

      root.querySelectorAll("[data-dashboard-chart]").forEach(function (chartEl) {
        chartResizeObserver.observe(chartEl);
      });
    }

    function consimsScheduleChartResize(name) {
      const resizeOne = function () {
        if (chartInstances[name]) chartInstances[name].resize();
      };

      window.requestAnimationFrame(function () {
        resizeOne();
        window.requestAnimationFrame(resizeOne);
      });
      window.setTimeout(resizeOne, 120);
      window.setTimeout(resizeOne, 320);
    }

    function lineOption(series, categories) {
      return {
        color: [palette.blue, palette.green, palette.orange],
        tooltip: { trigger: "axis" },
        legend: { bottom: 4, itemWidth: 10, itemHeight: 10, textStyle: { color: palette.text, fontSize: 11 } },
        grid: baseGrid(),
        xAxis: { type: "category", data: categories || months, axisTick: { show: false }, axisLine: { lineStyle: { color: "#aeb6c8" } } },
        yAxis: { type: "value", min: 0, max: 100, splitLine: { lineStyle: { color: palette.grid, type: "dashed" } } },
        series: series.map(function (item) { return { name: item.name, type: "line", smooth: true, symbolSize: 8, lineStyle: { width: 2 }, data: item.data }; })
      };
    }

    function consimsPadDatePart(value) {
      return String(value).padStart(2, "0");
    }

    function consimsParseApiDate(value) {
      const match = String(value ?? "").match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);
      if (match) return new Date(Number(match[1]), Number(match[2]) - 1, Number(match[3]));

      const date = new Date(value);
      return Number.isNaN(date.getTime()) ? null : date;
    }

    function consimsDateKey(date) {
      return [
        date.getFullYear(),
        consimsPadDatePart(date.getMonth() + 1),
        consimsPadDatePart(date.getDate())
      ].join("-");
    }

    function consimsFormatShortDate(date, includeYear) {
      const text = consimsPadDatePart(date.getDate()) + "/" + consimsPadDatePart(date.getMonth() + 1);
      return includeYear ? text + "/" + date.getFullYear() : text;
    }

    function consimsWeekStart(date) {
      const weekStart = new Date(date);
      const day = weekStart.getDay() || 7;
      weekStart.setDate(weekStart.getDate() - day + 1);
      weekStart.setHours(0, 0, 0, 0);
      return weekStart;
    }

    function consimsRevenueCostBucket(date, grain) {
      if (grain === "day") {
        return {
          key: consimsDateKey(date),
          label: consimsFormatShortDate(date, true),
          date: date
        };
      }

      if (grain === "week") {
        const start = consimsWeekStart(date);
        const end = new Date(start);
        end.setDate(start.getDate() + 6);
        return {
          key: consimsDateKey(start),
          label: consimsFormatShortDate(start, false) + " - " + consimsFormatShortDate(end, true),
          date: start
        };
      }

      return {
        key: date.getFullYear() + "-" + consimsPadDatePart(date.getMonth() + 1),
        label: (date.getMonth() + 1) + "/" + date.getFullYear(),
        date: new Date(date.getFullYear(), date.getMonth(), 1)
      };
    }

    function consimsReadRevenueCostMetric(row, keys) {
      for (let index = 0; index < keys.length; index += 1) {
        const value = row[keys[index]];
        if (value !== undefined && value !== null && value !== "") {
          const parsed = typeof value === "number" ? value : consimsParseNumberValue(value);
          return Number.isFinite(parsed) ? parsed : null;
        }
      }
      return null;
    }

    function consimsGroupRevenueCostRows(rows, grain) {
      const bucketMap = new Map();
      const normalizedRows = rows.map(function (row) {
        return {
          date: consimsParseApiDate(row.DateIs || row.Date || row.date),
          revenue: consimsReadRevenueCostMetric(row, ["CumRevenueAmount", "RevenueAmount", "Revenue"]),
          cost: consimsReadRevenueCostMetric(row, ["CumCostAmount", "CostAmount", "Cost"])
        };
      }).filter(function (row) {
        return row.date && row.revenue !== null && row.cost !== null;
      }).sort(function (a, b) {
        return a.date - b.date;
      });

      normalizedRows.forEach(function (row) {
        const bucket = consimsRevenueCostBucket(row.date, grain);
        bucketMap.set(bucket.key, {
          label: bucket.label,
          date: bucket.date,
          revenue: row.revenue,
          cost: row.cost
        });
      });

      return Array.from(bucketMap.values()).sort(function (a, b) {
        return a.date - b.date;
      });
    }

    function consimsFormatRevenueCostChartNumber(value, withCurrency) {
      const numeric = Number(value);
      if (!Number.isFinite(numeric)) return value;
      const sign = numeric < 0 ? "-" : "";
      const absoluteValue = Math.abs(numeric);
      const suffix = consimsGetContractCurrencySuffix() + (withCurrency ? " VN\u0110" : "");
      return sign + consimsTrimCompactNumber(absoluteValue) + suffix;
    }

    function contractRevenueCostOption(points, grain) {
      const categories = points.map(function (point) { return point.label; });
      const isDay = grain === "day";
      const isWeek = grain === "week";
      const isMonth = grain === "month";
      const shouldZoom = (isDay && categories.length > 45) || (isWeek && categories.length > 24) || (isMonth && categories.length > 18);
      const visibleCount = isDay ? 90 : isWeek ? 24 : 18;
      const visiblePercent = categories.length > visibleCount ? (visibleCount / categories.length) * 100 : 100;
      const zoomStart = shouldZoom ? Math.max(0, 100 - visiblePercent) : 0;
      const formatXAxisLabel = function (value) {
        if (isWeek && typeof value === "string") {
          return value
            .replace(/\s+/g, "")
            .replace(/\/20(\d{2})/g, "/$1");
        }

        return value;
      };

      return {
        color: [palette.blue, palette.green],
        animationDurationUpdate: 350,
        tooltip: {
          trigger: "axis",
          valueFormatter: function (value) { return consimsFormatRevenueCostChartNumber(value, true); }
        },
        legend: {
          bottom: shouldZoom ? 34 : 6,
          itemWidth: 10,
          itemHeight: 10,
          textStyle: { color: palette.text, fontSize: 11 }
        },
        grid: { left: 44, right: 8, top: 30, bottom: shouldZoom ? 86 : 60, containLabel: true },
        dataZoom: shouldZoom ? [
          { type: "inside", start: zoomStart, end: 100 },
          { type: "slider", start: zoomStart, end: 100, left: 44, right: 8, bottom: 12, height: 14, showDetail: false, brushSelect: false }
        ] : [],
        xAxis: {
          type: "category",
          data: categories,
          axisTick: { show: false },
          axisLine: { lineStyle: { color: "#aeb6c8" } },
          axisLabel: {
            color: "#8e98b2",
            hideOverlap: true,
            interval: "auto",
            margin: 12,
            formatter: formatXAxisLabel
          }
        },
        yAxis: {
          type: "value",
          min: 0,
          splitLine: { lineStyle: { color: palette.grid, type: "dashed" } },
          axisLabel: { formatter: function (value) { return consimsFormatRevenueCostChartNumber(value, false); } }
        },
        series: [
          {
            name: "Revenue",
            type: "line",
            smooth: true,
            showSymbol: !shouldZoom,
            symbolSize: shouldZoom ? 0 : 7,
            lineStyle: { width: 2 },
            data: points.map(function (point) { return point.revenue; })
          },
          {
            name: "Cost",
            type: "line",
            smooth: true,
            showSymbol: !shouldZoom,
            symbolSize: shouldZoom ? 0 : 7,
            lineStyle: { width: 2 },
            data: points.map(function (point) { return point.cost; })
          }
        ]
      };
    }

    function renderContractRevenueCostChart() {
      const grain = contractRevenueCostGrainSelect ? contractRevenueCostGrainSelect.value : "month";
      const apiPoints = contractRevenueCostRows.length ? consimsGroupRevenueCostRows(contractRevenueCostRows, grain) : [];
      const points = apiPoints.length ? apiPoints : [];

      setChartOption("contract-revenue-cost", contractRevenueCostOption(points, grain));
    }

    function contractScurveOption() {
      const metric = contractScurveSelect ? contractScurveSelect.value : "revenue";
      return lineOption(contractScurveSeries[metric] || contractScurveSeries.revenue);
    }

    function renderContractScurveChart() {
      const option = contractScurveOption();
      if (chartInstances["contract-planned-actual"]) {
        chartInstances["contract-planned-actual"].setOption(option, true);
        return;
      }
      chart("contract-planned-actual", option);
