    function donutOption(data, colors, center) {
      return {
        color: colors || [palette.blue, palette.green, palette.orange, palette.red, palette.cyan, palette.yellow],
        tooltip: { trigger: "item" },
        legend: { right: 12, top: "middle", orient: "vertical", itemWidth: 9, itemHeight: 9, textStyle: { fontSize: 11 } },
        series: [{ type: "pie", radius: ["42%", "68%"], center: center || ["38%", "50%"], avoidLabelOverlap: true, label: { show: false }, data: data }]
