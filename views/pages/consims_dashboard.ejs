      ]
    };

    function fillTable(selector, rows) {
      const body = root.querySelector(selector);
      if (body) body.innerHTML = rows.join("");
    }

    function valueCell(value, className) {
      const text = String(value);
      const negativeClass = text.trim().charAt(0) === "-" ? " consims-negative-value" : "";
      return '<td class="' + (className || "text-end") + negativeClass + '">' + text + '</td>';
    }

    function consimsMetricKey(value) {
      return String(value ?? "").toLowerCase().replace(/[^a-z0-9]+/g, "");
    }

    function consimsApplySignedText(element, value) {
      if (!element) return;
      const text = String(value ?? "");
      element.textContent = text;
      element.classList.toggle("consims-negative-value", text.trim().charAt(0) === "-");
    }

    function consimsParseNumberValue(value, compactSuffix) {
      let numberText = String(value ?? "").replace(/[^\d.,]/g, "");
      if (!numberText) return NaN;

      if (compactSuffix) return Number(numberText.replace(",", "."));

      const dotCount = (numberText.match(/\./g) || []).length;
      const commaCount = (numberText.match(/,/g) || []).length;

      if (dotCount > 1 && commaCount === 0) return Number(numberText.replace(/\./g, ""));
      if (commaCount > 1 && dotCount === 0) return Number(numberText.replace(/,/g, ""));

      if (dotCount && commaCount) {
        const decimalSeparator = numberText.lastIndexOf(".") > numberText.lastIndexOf(",") ? "." : ",";
        const thousandsSeparator = decimalSeparator === "." ? "," : ".";
        numberText = numberText.replace(new RegExp("\\" + thousandsSeparator, "g"), "");
        return Number(numberText.replace(decimalSeparator, "."));
      }

      if (dotCount === 1) {
        const parts = numberText.split(".");
        return Number(parts[1].length === 3 ? numberText.replace(".", "") : numberText);
      }

      if (commaCount === 1) {
        const parts = numberText.split(",");
        return Number(parts[1].length === 3 ? numberText.replace(",", "") : numberText.replace(",", "."));
      }

      return Number(numberText);
    }

    function consimsTrimCompactNumber(value) {
      return value.toFixed(value >= 10 ? 1 : 2).replace(/\.?0+$/, "");
    }

    function consimsGetContractCurrencyUnit() {
      return contractCurrencyUnitSelect && contractCurrencyUnitSelect.value === "Million" ? "Million" : "Billion";
    }

    function consimsGetContractCurrencySuffix() {
      return consimsGetContractCurrencyUnit() === "Million" ? "M" : "B";
    }

    function consimsFormatContractKpiAmount(value) {
      const text = String(value ?? "").trim();
      if (!text || text.includes("%")) return text;

      const upperText = text.toUpperCase();
      const suffixMatch = upperText.match(/([MB])\b/);
      const parsedNumber = consimsParseNumberValue(text, Boolean(suffixMatch));
      if (!Number.isFinite(parsedNumber)) return text.replace(/\$/g, "").trim();

      const sign = parsedNumber < 0 || text.trim().charAt(0) === "-" ? "-" : "";
      const absoluteValue = Math.abs(parsedNumber);

      if (suffixMatch) return sign + consimsTrimCompactNumber(absoluteValue) + suffixMatch[1] + " VNĐ";
      return sign + absoluteValue.toLocaleString("vi-VN") + " VNĐ";
    }

    function consimsApplySignedRatio(element, value) {
      if (!element) return;
      const text = String(value ?? "");
      element.textContent = text;
      element.classList.remove("positive", "negative");
      element.classList.add(text.trim().charAt(0) === "-" ? "negative" : "positive");
    }

    function consimsRenderContractKpiFromFinanceRows(rows) {
      const financeByLabel = {};
      rows.forEach(function (row) {
        financeByLabel[consimsMetricKey(row.label)] = row;
      });

      root.querySelectorAll("[data-consims-contract-kpi]").forEach(function (kpi) {
        const financeRow = financeByLabel[consimsMetricKey(kpi.dataset.consimsContractKpi)];
        if (!financeRow) return;
        consimsApplySignedText(kpi.querySelector("[data-consims-kpi-amount]"), consimsFormatContractKpiAmount(financeRow.amount));
        consimsApplySignedRatio(kpi.querySelector("[data-consims-kpi-rcv]"), financeRow.rcv);
      });
    }

    function consimsRenderContractFinanceRows(rows) {
      fillTable('[data-dashboard-table="contract-finance"]', rows.map(function (row) {
        return '<tr><td>' + row.label + '</td>' + valueCell(consimsFormatContractKpiAmount(row.amount)) + valueCell(row.rcv) + '</tr>';
      }));
      consimsRenderContractKpiFromFinanceRows(rows);
    }

    function consimsFormatApiPercent(value) {
      if (value === null || value === undefined || value === "") return "";
      const text = String(value).trim();
      if (text.includes("%")) return text;

      const parsed = Number(text);
      if (!Number.isFinite(parsed)) return text;
      return consimsTrimCompactNumber(parsed) + "%";
    }

    function consimsMapContractFinanceRows(rows) {
      const references = {};
      const mappedRows = rows.map(function (row) {
        const label = row.Description || row.Label || row.Name || "";
        const amountValue = row.OriginalContractValue ?? row.Amount ?? row.Value;
        const amountNumber = typeof amountValue === "number" ? amountValue : consimsParseNumberValue(amountValue);

        if (label && Number.isFinite(amountNumber)) {
          references[consimsMetricKey(label)] = amountNumber;
        }

        return {
          label: label,
          amount: Number.isFinite(amountNumber) ? String(amountNumber) + consimsGetContractCurrencySuffix() : "0",
          rcv: consimsFormatApiPercent(row.PercentVSRCV ?? row.PercentOfRCV ?? row.RCV)
        };
      }).filter(function (row) {
        return row.label !== "";
      });

      contractFinanceReference = references;
      return mappedRows;
    }

    function consimsReadFinanceReference(label) {
      const value = contractFinanceReference[consimsMetricKey(label)];
      return Number.isFinite(value) ? value : null;
    }

    function consimsEscapeHtml(value) {
      return String(value ?? "").replace(/[&<>"']/g, function (char) {
        return ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;" })[char];
      });
    }

    function consimsApiSuccess(payload) {
      return payload && (payload.Success === true || payload.Success === "true");
    }

    function consimsReadList(payload, key) {
      if (!payload) return [];
      if (payload.Headings && Array.isArray(payload.Headings[key])) return payload.Headings[key];
      if (payload.Data && Array.isArray(payload.Data[key])) return payload.Data[key];
      if (Array.isArray(payload[key])) return payload[key];
      if (Array.isArray(payload.Data)) return payload.Data;
      return [];
    }

    function consimsRefreshSelect(select) {
      if (select && typeof select.consimsRefreshOptions === "function") select.consimsRefreshOptions();
    }

    function consimsReadContractId(item) {
      return item.ContractId ?? item.ProjectId ?? item.Id ?? item.Value ?? item.value ?? "";
    }

    function consimsReadContractName(item) {
      return item.Description || item.ContractName || item.ProjectName || item.Name || item.Text || item.text || consimsReadContractId(item);
    }

    function consimsSetContractOptions(items, preferredContractId) {
      if (!contractProjectSelect || !Array.isArray(items) || !items.length) return;

      const options = items.map(function (item) {
        return {
          id: consimsReadContractId(item),
          name: consimsReadContractName(item)
        };
      }).filter(function (item) {
        return item.id !== "" && item.name !== "";
      });

      if (!options.length) return;

      contractProjectSelect.innerHTML = '<option value="">Project/Contract</option>';
      options.forEach(function (item) {
        const option = document.createElement("option");
        option.value = String(item.id);
        option.textContent = item.name;
        contractProjectSelect.appendChild(option);
      });

      const preferredId = preferredContractId || consimsDefaultContractId;
      const defaultOption = options.find(function (item) { return String(item.id) === String(preferredId); });
      contractProjectSelect.value = defaultOption ? String(defaultOption.id) : "";
      consimsRefreshSelect(contractProjectSelect);
    }

    function consimsRenderContractInformation(info) {
      if (!info) return;

      const rows = [
        ["Contract Id", "ContractId"],
        ["Description", "Description"],
        ["Company Name", "CompanyName"],
        ["Start Date", "StartDate"],
        ["End Date", "EndDate"],
        ["Contract Date", "ContractDate"],
        ["Contract Code", "ContractCode"],
        ["Actual Start", "ActualStart"],
        ["Contract Type", "ContractType"],
        ["Contract Format", "ContractFormat"]
      ];

      fillTable('[data-dashboard-table="contract-information"]', rows.map(function (row) {
        const value = info[row[1]] ?? "";
        return '<tr><td>' + consimsEscapeHtml(row[0]) + '</td><td class="text-end consims-contract-info-value">' + consimsEscapeHtml(value) + '</td></tr>';
      }));
    }

    async function consimsFetchJson(url) {
      const response = await fetch(url, { headers: { "Accept": "application/json" } });
      if (!response.ok) throw new Error("Request failed: " + response.status);
      return response.json();
    }

    async function consimsLoadContractDashboardData(contractId) {
      const selectedContractId = contractId || consimsDefaultContractId;
      const requestId = ++contractDataRequestId;

      try {
        const unit = consimsGetContractCurrencyUnit();
        const payload = await consimsFetchJson("/consims-dashboard/contract-data?contractId=" + encodeURIComponent(selectedContractId) + "&unit=" + encodeURIComponent(unit));
        if (requestId !== contractDataRequestId) return;
        if (!consimsApiSuccess(payload)) {
          console.warn("Contract dashboard API returned false", payload);
          return;
        }

        const projectList = consimsReadList(payload, "ProjectList");
        if (projectList.length && contractProjectSelect && contractProjectSelect.options.length <= 1) {
          consimsSetContractOptions(projectList, selectedContractId);
        }

        const contractInfo = consimsReadList(payload, "ContractInfo")[0];
        if (contractInfo) consimsRenderContractInformation(contractInfo);

        const financeRows = consimsReadList(payload, "FinancePerformance");
        if (financeRows.length) {
          consimsRenderContractFinanceRows(consimsMapContractFinanceRows(financeRows));
        }

        const progressRows = consimsReadList(payload, "ProgressPerformance");
        if (progressRows.length) {
          consimsRenderContractFinanceRows(consimsMapContractFinanceRows(progressRows));
        }

        const revenueCostRows = consimsReadList(payload, "RevenueVSCost");
        if (revenueCostRows.length) {
          contractRevenueCostRows = revenueCostRows;
          renderContractRevenueCostChart();
        } else {
          contractRevenueCostRows = [];
          renderContractRevenueCostChart();
        }
      } catch (error) {
        contractRevenueCostRows = [];
        renderContractRevenueCostChart();
        console.warn("Could not load contract dashboard data", error);
      }
    }

    async function consimsLoadContractProjectList() {
      if (!contractProjectSelect) return;

      try {
        const payload = await consimsFetchJson("/consims-dashboard/project-list?displayMode=contract_to_dashboard");
        if (!consimsApiSuccess(payload)) {
          console.warn("Contract project list API returned false", payload);
          return;
        }

        const projectList = consimsReadList(payload, "ProjectList");
        consimsSetContractOptions(projectList);
      } catch (error) {
        console.warn("Could not load contract project list", error);
      }
    }

