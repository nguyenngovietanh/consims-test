    function activateTab(tabName) {
      const activeButton = tabButtons.find(function (button) { return button.dataset.dashboardTab === tabName; }) || tabButtons[0];
      const activeView = views.find(function (view) { return view.dataset.dashboardView === activeButton.dataset.dashboardTab; });
      const currentView = views.find(function (view) { return view.classList.contains("active"); });
      const nextTab = activeButton.dataset.dashboardTab;

      window.clearTimeout(tabTransitionTimer);

      tabButtons.forEach(function (button) {
        const isActive = button === activeButton;
        button.classList.toggle("active", isActive);
        button.setAttribute("aria-selected", isActive ? "true" : "false");
      });

      if (titleEl) titleEl.textContent = activeButton.dataset.dashboardTitle;
      if (descEl) descEl.textContent = activeButton.dataset.dashboardDesc;
      root.dataset.activeDashboard = nextTab;

      if (currentView === activeView) {
        activeView.classList.remove("is-leaving", "is-entering");
        initCharts(nextTab);
        return;
      }

      if (currentView) {
        currentView.classList.add("is-leaving");
      }

      tabTransitionTimer = window.setTimeout(function () {
        views.forEach(function (view) {
          const isActive = view === activeView;
          view.classList.toggle("active", isActive);
          view.classList.remove("is-leaving");
          view.classList.toggle("is-entering", isActive);
        });
        initCharts(nextTab);

        window.requestAnimationFrame(function () {
          window.requestAnimationFrame(function () {
            activeView.classList.remove("is-entering");
            resizeCharts();
          });
        });
      }, currentView ? 130 : 0);
    }

    function enhanceConsimsSelects() {
      root.querySelectorAll(".dashboard-filter-row select.form-select, select[data-consims-select-source='true']").forEach(function (select) {
        if (select.dataset.consimsEnhanced === "true") return;
        select.dataset.consimsEnhanced = "true";
        select.classList.add("consims-select-native");

        const wrapper = document.createElement("div");
        wrapper.className = "dropdown consims-select";
        if (select.dataset.consimsSelectSize) wrapper.classList.add("consims-select-" + select.dataset.consimsSelectSize);
        wrapper.setAttribute("data-consims-select", "");
        select.parentNode.insertBefore(wrapper, select);
        wrapper.appendChild(select);

        const button = document.createElement("button");
        button.type = "button";
        button.className = "consims-select-control";
        button.setAttribute("data-bs-toggle", "dropdown");
        button.setAttribute("data-bs-offset", "0,4");
        button.setAttribute("aria-expanded", "false");
        button.setAttribute("aria-label", select.getAttribute("aria-label") || "Select");

        const label = document.createElement("span");
        label.className = "consims-select-label";
        button.appendChild(label);

        const menu = document.createElement("div");
        menu.className = "dropdown-menu consims-select-menu";

        function updateSelectedOption() {
          const currentOption = select.options[select.selectedIndex] || select.options[0];
          label.textContent = currentOption ? currentOption.textContent : (select.getAttribute("aria-label") || "Select");
          menu.querySelectorAll(".consims-select-option").forEach(function (item) {
            item.classList.toggle("active", item.dataset.value === select.value);
          });
        }

        Array.from(select.options).forEach(function (option) {
          const item = document.createElement("button");
          item.type = "button";
          item.className = "dropdown-item consims-select-option";
          item.dataset.value = option.value;
          item.textContent = option.textContent;
          item.addEventListener("click", function () {
            select.value = option.value;
            select.dispatchEvent(new Event("change", { bubbles: true }));
            updateSelectedOption();
            if (window.bootstrap && window.bootstrap.Dropdown) {
              window.bootstrap.Dropdown.getOrCreateInstance(button).hide();
            }
          });
          menu.appendChild(item);
        });

        wrapper.insertBefore(button, select);
        wrapper.appendChild(menu);
        select.addEventListener("change", updateSelectedOption);
        updateSelectedOption();
      });
    }

    function initConsimsDatepickers() {
      const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
      const weekdays = ["Mo", "Tu", "We", "Th", "Fr", "Sa", "Su"];
      const widgets = Array.from(root.querySelectorAll("[data-consims-datepicker]"));

      function pad(value) {
        return String(value).padStart(2, "0");
      }

      function formatDate(date) {
        return pad(date.getDate()) + "/" + pad(date.getMonth() + 1) + "/" + date.getFullYear();
      }

      function isSameDate(left, right) {
        return left && right && left.getFullYear() === right.getFullYear() && left.getMonth() === right.getMonth() && left.getDate() === right.getDate();
      }

      function isBetweenDates(day, start, end) {
        return start && end && day.getTime() > start.getTime() && day.getTime() < end.getTime();
      }

      function closeDatepickers(exceptPanel) {
        widgets.forEach(function (widget) {
          const panel = widget.querySelector("[data-consims-datepicker-panel]");
          if (panel && panel !== exceptPanel) panel.hidden = true;
        });
      }

      widgets.forEach(function (widget) {
        if (widget.dataset.consimsDatepickerReady === "true") return;
        widget.dataset.consimsDatepickerReady = "true";

        const input = widget.querySelector("[data-consims-datepicker-input]");
        const toggle = widget.querySelector("[data-consims-datepicker-toggle]");
        const isRange = widget.dataset.consimsDatepickerMode === "range";
        const display = document.createElement("span");
        display.className = "consims-datepicker-display";
        display.setAttribute("aria-hidden", "true");
        widget.insertBefore(display, toggle);
        const today = new Date();
        let selectedDate = null;
        let rangeStart = null;
        let rangeEnd = null;
        let viewDate = new Date(today.getFullYear(), today.getMonth(), 1);
        let pickerMode = null;
        const panel = document.createElement("div");
        panel.className = "consims-datepicker-panel";
        panel.hidden = true;
        panel.setAttribute("data-consims-datepicker-panel", "");
        widget.appendChild(panel);

        function updateInputValue() {
          if (!isRange) {
            input.value = selectedDate ? formatDate(selectedDate) : "";
            display.innerHTML = selectedDate ? '<span>' + formatDate(selectedDate) + '</span>' : '<span class="consims-datepicker-display-placeholder">' + input.placeholder + '</span>';
            return;
          }

          if (rangeStart && rangeEnd) {
            input.value = formatDate(rangeStart) + " - " + formatDate(rangeEnd);
            display.innerHTML = '<span>' + formatDate(rangeStart) + '</span><span>&nbsp;-&nbsp;</span><span>' + formatDate(rangeEnd) + '</span>';
          } else if (rangeStart) {
            input.value = formatDate(rangeStart) + " - DD/MM/YYYY";
            display.innerHTML = '<span>' + formatDate(rangeStart) + '</span><span>&nbsp;-&nbsp;</span><span class="consims-datepicker-display-placeholder">DD/MM/YYYY</span>';
          } else {
            input.value = "";
            display.innerHTML = '<span class="consims-datepicker-display-placeholder">' + input.placeholder + '</span>';
          }
        }

        updateInputValue();

        function renderCalendar() {
          const year = viewDate.getFullYear();
          const month = viewDate.getMonth();
          const firstDay = new Date(year, month, 1);
          const startOffset = (firstDay.getDay() + 6) % 7;
          const firstGridDate = new Date(year, month, 1 - startOffset);
          const days = [];

          for (let index = 0; index < 42; index += 1) {
            days.push(new Date(firstGridDate.getFullYear(), firstGridDate.getMonth(), firstGridDate.getDate() + index));
          }

          const pickerContent = pickerMode === "month"
            ? '<div class="consims-datepicker-picker consims-datepicker-month-picker">' +
                monthNames.map(function (monthName, monthIndex) {
                  const activeClass = monthIndex === month ? " is-active" : "";
                  return '<button class="consims-datepicker-picker-option' + activeClass + '" type="button" data-consims-datepicker-month-option="' + monthIndex + '">' + monthName + '</button>';
                }).join("") +
              '</div>'
            : pickerMode === "year"
              ? '<div class="consims-datepicker-picker consims-datepicker-year-picker">' +
                  Array.from({ length: 12 }, function (_, index) {
                    const optionYear = year - 5 + index;
                    const activeClass = optionYear === year ? " is-active" : "";
                    return '<button class="consims-datepicker-picker-option' + activeClass + '" type="button" data-consims-datepicker-year-option="' + optionYear + '">' + optionYear + '</button>';
                  }).join("") +
                '</div>'
              : '<div class="consims-datepicker-weekdays">' + weekdays.map(function (day) { return '<span>' + day + '</span>'; }).join("") + '</div>' +
                '<div class="consims-datepicker-days">' +
                  days.map(function (day) {
                    const mutedClass = day.getMonth() === month ? "" : " is-muted";
                    const selectedClass = isRange
                      ? (isSameDate(day, rangeStart) || isSameDate(day, rangeEnd) ? " is-selected" : "")
                      : (isSameDate(day, selectedDate) ? " is-selected" : "");
                    const rangeClass = isRange && isBetweenDates(day, rangeStart, rangeEnd) ? " is-in-range" : "";
                    return '<button class="consims-datepicker-day' + mutedClass + selectedClass + rangeClass + '" type="button" data-consims-datepicker-day="' + day.getTime() + '">' + day.getDate() + '</button>';
                  }).join("") +
                '</div>';

          panel.innerHTML =
            '<div class="consims-datepicker-head">' +
              '<button class="consims-datepicker-nav" type="button" data-consims-datepicker-prev aria-label="Previous month"><svg xmlns="http://www.w3.org/2000/svg" width="16px" height="16px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-chevron-left"><polyline points="15 18 9 12 15 6"></polyline></svg></button>' +
              '<button class="consims-datepicker-current" type="button" data-consims-datepicker-month>' + monthNames[month] + '</button>' +
              '<button class="consims-datepicker-current" type="button" data-consims-datepicker-year>' + year + '</button>' +
              '<button class="consims-datepicker-nav" type="button" data-consims-datepicker-next aria-label="Next month"><svg xmlns="http://www.w3.org/2000/svg" width="16px" height="16px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-chevron-right"><polyline points="9 18 15 12 9 6"></polyline></svg></button>' +
            '</div>' +
            pickerContent;

          bindCalendarControls();
        }

        function openCalendar() {
          closeDatepickers(panel);
          renderCalendar();
          panel.hidden = false;
        }

        function toggleCalendar() {
          if (panel.hidden) {
            openCalendar();
          } else {
            panel.hidden = true;
          }
        }

        function moveView(direction) {
          if (pickerMode === "year") {
            viewDate = new Date(viewDate.getFullYear() + (direction * 12), viewDate.getMonth(), 1);
          } else if (pickerMode === "month") {
            viewDate = new Date(viewDate.getFullYear() + direction, viewDate.getMonth(), 1);
          } else {
            viewDate = new Date(viewDate.getFullYear(), viewDate.getMonth() + direction, 1);
          }
          renderCalendar();
        }

        function chooseMonth(monthIndex) {
          pickerMode = null;
          viewDate = new Date(viewDate.getFullYear(), monthIndex, 1);
          renderCalendar();
        }

        function chooseYear(year) {
          pickerMode = null;
          viewDate = new Date(year, viewDate.getMonth(), 1);
          renderCalendar();
        }

        function bindCalendarControls() {
          const prevButton = panel.querySelector("[data-consims-datepicker-prev]");
          const nextButton = panel.querySelector("[data-consims-datepicker-next]");
          const monthButton = panel.querySelector("[data-consims-datepicker-month]");
          const yearButton = panel.querySelector("[data-consims-datepicker-year]");

          if (prevButton) {
            prevButton.addEventListener("click", function (event) {
              event.preventDefault();
              event.stopPropagation();
              moveView(-1);
            });
          }

          if (nextButton) {
            nextButton.addEventListener("click", function (event) {
              event.preventDefault();
              event.stopPropagation();
              moveView(1);
            });
          }

          if (monthButton) {
            monthButton.addEventListener("click", function (event) {
              event.preventDefault();
              event.stopPropagation();
              pickerMode = pickerMode === "month" ? null : "month";
              renderCalendar();
            });
          }

          if (yearButton) {
            yearButton.addEventListener("click", function (event) {
              event.preventDefault();
              event.stopPropagation();
              pickerMode = pickerMode === "year" ? null : "year";
              renderCalendar();
            });
          }

          panel.querySelectorAll("[data-consims-datepicker-month-option]").forEach(function (button) {
            button.addEventListener("click", function (event) {
              event.preventDefault();
              event.stopPropagation();
              chooseMonth(Number(button.dataset.consimsDatepickerMonthOption));
            });
          });

          panel.querySelectorAll("[data-consims-datepicker-year-option]").forEach(function (button) {
            button.addEventListener("click", function (event) {
              event.preventDefault();
              event.stopPropagation();
              chooseYear(Number(button.dataset.consimsDatepickerYearOption));
            });
          });
        }

        input.addEventListener("click", toggleCalendar);
        toggle.addEventListener("click", toggleCalendar);
        panel.addEventListener("click", function (event) {
          const prev = event.target.closest("[data-consims-datepicker-prev]");
          const next = event.target.closest("[data-consims-datepicker-next]");
          const monthToggle = event.target.closest("[data-consims-datepicker-month]");
          const yearToggle = event.target.closest("[data-consims-datepicker-year]");
          const monthOption = event.target.closest("[data-consims-datepicker-month-option]");
          const yearOption = event.target.closest("[data-consims-datepicker-year-option]");
          const dayButton = event.target.closest("[data-consims-datepicker-day]");

          if (prev) {
            if (pickerMode === "year") {
              viewDate = new Date(viewDate.getFullYear() - 12, viewDate.getMonth(), 1);
            } else if (pickerMode === "month") {
              viewDate = new Date(viewDate.getFullYear() - 1, viewDate.getMonth(), 1);
            } else {
              viewDate = new Date(viewDate.getFullYear(), viewDate.getMonth() - 1, 1);
            }
            renderCalendar();
            return;
          }

          if (next) {
            if (pickerMode === "year") {
              viewDate = new Date(viewDate.getFullYear() + 12, viewDate.getMonth(), 1);
            } else if (pickerMode === "month") {
              viewDate = new Date(viewDate.getFullYear() + 1, viewDate.getMonth(), 1);
            } else {
              viewDate = new Date(viewDate.getFullYear(), viewDate.getMonth() + 1, 1);
            }
            renderCalendar();
            return;
          }

          if (monthToggle) {
            pickerMode = pickerMode === "month" ? null : "month";
            renderCalendar();
            return;
          }

          if (yearToggle) {
            pickerMode = pickerMode === "year" ? null : "year";
            renderCalendar();
            return;
          }

          if (monthOption) {
            pickerMode = null;
            viewDate = new Date(viewDate.getFullYear(), Number(monthOption.dataset.consimsDatepickerMonthOption), 1);
            renderCalendar();
            return;
          }

          if (yearOption) {
            pickerMode = null;
            viewDate = new Date(Number(yearOption.dataset.consimsDatepickerYearOption), viewDate.getMonth(), 1);
            renderCalendar();
            return;
          }

          if (dayButton) {
            const pickedDate = new Date(Number(dayButton.dataset.consimsDatepickerDay));
            viewDate = new Date(pickedDate.getFullYear(), pickedDate.getMonth(), 1);

            if (isRange) {
              if (!rangeStart || rangeEnd || pickedDate.getTime() < rangeStart.getTime()) {
                rangeStart = pickedDate;
                rangeEnd = null;
                updateInputValue();
                input.dispatchEvent(new Event("change", { bubbles: true }));
                renderCalendar();
                return;
              }

              rangeEnd = pickedDate;
              updateInputValue();
              input.dispatchEvent(new Event("change", { bubbles: true }));
              panel.hidden = true;
              return;
            }

            selectedDate = pickedDate;
            updateInputValue();
            input.dispatchEvent(new Event("change", { bubbles: true }));
            panel.hidden = true;
          }
        });
      });

      document.addEventListener("click", function (event) {
        if (!event.target.closest("[data-consims-datepicker]")) closeDatepickers();
      });
    }

    enhanceConsimsSelects();
    initConsimsDatepickers();
    if (contractScurveSelect) contractScurveSelect.addEventListener("change", renderContractScurveChart);
    seedTables();
    tabButtons.forEach(function (button) {
      button.addEventListener("click", function () { activateTab(button.dataset.dashboardTab); });
    });
    activateTab("contract");
    window.addEventListener("resize", resizeCharts);
  })();
</script>
