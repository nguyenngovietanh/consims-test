<div id="senobjectmaster-section">
  <div class="mb-9">
    <h2 class="mb-4"><%- title %></h2>
    <div class="mb-1">
      <div class="">
        <!-- <div class="btn-group me-1">
          <div class="dropdown">
            <a class="btn btn-subtle-secondary" href="#" role="button" data-bs-toggle="dropdown" aria-haspopup="true"
              aria-expanded="false"><i class="fa-solid fa-ellipsis-vertical"></i></a>
            <div class="dropdown-menu">
              <a class="dropdown-item" onclick="senobjectobject.tbl.deleteBySelected()">Delete Selected</a>
            </div>
          </div>
        </div> -->
        <div class="btn-group me-1">
          <a onclick="senobjectobject.tbl.create()" class="btn btn-subtle-primary">Create New</a>
        </div>
      </div>
    </div>
    <div class="row-fluid">
      <div class="card">
        <div class="card-body">
          <div class="search-box mb-3 mx-auto">
            <div class="position-relative">
              <input class="form-control search-input search form-control-sm" type="search" placeholder="Search"
                aria-label="Search" />
              <span class="fas fa-search search-box-icon"></span>
            </div>
          </div>
          <div class="table-responsive">
            <table class="table table-sm fs-9 mb-5">
              <tbody class="list">
                <!-- Table datas will be added here -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    var senobjectobject = {};
    senobjectobject.model = JSON.parse('<%- JSON.stringify(model) %>');
    senobjectobject.container = document.getElementById("senobjectmaster-section");//khu vực chứa danh sách
    senobjectobject.urldata = {
      lists: '/senobject/list',
      item: '/senobject/item',
      create: '/senobject/create?viewname=senobjectmasterupdate&callback=' + encodeURIComponent('senobjectobject.createcallback'),
      edit: '/senobject/edit?viewname=senobjectmasterupdate&callback=' + encodeURIComponent('senobjectobject.editcallback'),
      delete: '/senobject/delete',
      update: '/senobject/edit'
    };

    senobjectobject.createcallback = function (response) {
      //nếu response[0] tồn tại thì hiển thị thông báo lỗi
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        senobjectobject.tbl.onAddRowData({ data: response[0].data });
        //senapp.sidebar.menuclickbydatalink('/senobject');
      }
    };
    senobjectobject.editcallback = function (response) {
      //nếu response[0] tồn tại thì hiển thị thông báo lỗi
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        senobjectobject.tbl.onChangeRowData({ data: response[0].data });
        //nếu tồn tại dòng chi tiết thì load lại
        const id = response[0].data[senobjectobject.tbl.keyfield];
        if (senobjectobject.lineobject.tbllines[id]) {
          senobjectobject.lineobject.tbllines[id].refreshDataDisplay();
        }
      }
    };
    senobjectobject.deletecallback = async function ({ response, data, row }) {
      //nếu response[0] tồn tại thì hiển thị thông báo lỗi
      if (response.status !== 0) {
        //nếu tồn tại dòng chi tiết thì xóa đi
        const id = data[senobjectobject.tbl.keyfield];
        if (senobjectobject.lineobject.tbllines[id]) {
          senobjectobject.lineobject.tbllines[id].container.remove();
          delete senobjectobject.lineobject.tbllines[id];
        }
      }
    };

    // Khởi tạo bảng
    senobjectobject.tbl = new senapp.utils.table({
      meta: senobjectobject.model.meta,
      urldata: senobjectobject.urldata,
      container: senobjectobject.container,
      tableelement: senobjectobject.container.querySelector('table'),
      modal: true,
      selectcolumn: true, // có hiển thị cột chọn hay không
      addrow: true, // cho phép thêm mới
      editrow: true, // cho phép sửa
      deleterow: true, // cho phép xóa
      readonly: false, //chế độ chỉ đọc
      filterrow: true, // có hiển thị filter row hay không
      filtercompact: false,
      loadmoreonvisible: true, // tự động tải thêm dữ liệu khi cuộn đến cuối danh sách      
      sysnoviewcard: true, // cho phép xem card khi click vào số thứ tự
      metacolumns: [
        { field: 'ExtLine', description: 'Line', colorder: -1, visible: true, show: true },
        // { field: 'Ext01', description: 'Ext01', colorder: 1, visible: true, show: true },
        // { field: 'Ext02', description: 'Ext02', colorder: 2, visible: true, show: true },
        // { field: 'SysNo', description: 'Số thứ tự', colorder: -50, visible: true, show: false },
        // { field: 'SysSelect', description: 'SysSelect', colorder: -7, visible: true, show: true },
        // { field: 'String', description: 'Chuỗi', width: 150, visible: true, show: true },
        // { field: 'Id', description: 'ID', width: 100, visible: true, show: true }
      ],
      customcolumns: ['ExtLine'],// ['SysNo', 'String', 'Id'], // Danh sách các cột tùy chỉnh khi render cell
      // filtercompact: true, // hiển thị filter row ở dạng compact
      allowexport2excel: true,//cho phép xuất Excel
      datanew: senobjectobject.model.datanew,
      deletecallback: senobjectobject.deletecallback //gán hàm callback sau khi xóa
    });

    //#region test
    senobjectobject.tbl.genCellDataCustom = function ({ data, metacolumn }) {
      if (!metacolumn || !metacolumn.field) {
        return null; // Trả về null nếu không có metacolumn hoặc field
      }
      // Hàm này sẽ được sử dụng để tạo dữ liệu cho các cột tùy chỉnh
      const tableobject = this;
      const td = document.createElement('td');
      td.setAttribute('data-field', metacolumn.field);
      //nếu field.visible là false hoặc field.show là false thì không hiển thị cột này  gán class d-none
      if (!metacolumn.show) { td.classList.add('d-none'); }

      switch (metacolumn.field) {
        case 'ExtLine':
          //nếu metacolumn.field là 'ExtLine' thì nội dung là số thứ tự của dòng trong bảng
          const index = tableobject.datas.indexOf(data);
          td.innerHTML = `<a data-load="false" href="javascript:;" onclick="senobjectobject.lineobject.loadLine(this)">${data["Id"] || ''}</a>`;
          break;
        case 'Ext01':
          td.innerHTML = `<a href="javascript:;" onclick="senobjectobject.loadLine(this)">${data["String"] || ''}</a>`;
          break;
        case 'Ext02':
          const alink = document.createElement('a');
          alink.href = 'javascript:;';
          alink.onclick = function () {
            tableobject.cardview({ datas: [data] });
          };
          alink.textContent = data["String"] || '';
          td.appendChild(alink);
          break;
        case 'SysNo':
          return this.genCellDataNo({ data, metacolumn });
          break;
        case 'String':
          //nếu metacolumn.field là 'String' thì nội dung là giá trị của
          td.innerHTML = `<strong>${data[metacolumn.field] || ''}</strong>`;
          break;
        case 'Id':
          //nếu metacolumn.field là 'Id' thì nội dung là giá trị của
          const editLink = document.createElement('a');
          editLink.dataset.id = data[tableobject.keyfield];
          editLink.href = 'javascript:;';
          editLink.onclick = function () { tableobject.edit(this); };
          editLink.textContent = data[metacolumn.field];
          td.appendChild(editLink);
          break;
        default:
          //nếu không phải là cột tùy chỉnh thì trả về giá trị của trường đó
          td.innerHTML = data[metacolumn.field] || '';
          break;
      }
      return td;
    }

    //#endregion

    //#region dev
    senobjectobject.tbl.datanews.length = 0;//xóa dữ liệu cũ
    for (let i = 1; i <= 3; i++) {
      senobjectobject.tbl.datanews.push({
        GId: `gid-${i}`,
        Id: i * (-1),
        Bigint: 1000000000 + i,
        Numeric: 100.5 + i,
        String: `Sample String ${i}`,
        Options: `${i % 3}`,
        Lookup: `Lookup${i % 5}`,
        LookupMulti: `LookupMulti${i % 4},LookupMulti${i % 2}`,
        DateTime: new Date(2024, 0, i, 10, 30, 0),
        Boolean: i % 2 === 0,
        Date: new Date(2024, 0, i),
        Text: `Sample text for row ${i}`
      });
    }

    //hàm onChangeCellAdd khi td mất focus và có thay đổi dữ liệu
    senobjectobject.tbl.onChangeCellAdd = async function ({ td, data } = {}) {
      //nếu chứa class edited thì cập nhật lên server
      if (td.parentElement.classList.contains('edited')) {
        const fieldName = td.getAttribute('data-field');
        switch (fieldName) {
          case 'Bigint':
            if (data.Bigint !== 0) {
              // senapp.window.toast({ message: `Bigint must be ${data.Bigint}`, type: 'info' });
              data.Numeric = data.Bigint;
              //this.updateCellByData(data, 'Numeric');
              this.refreshCellDisplayByData({ data, fields: ['Numeric'] });
              // this.refreshRowDisplayByData({data});
              return;
            }
            break;
        }
      }
    }
    //#endregion

    //#region line

    senobjectobject.lineobject = { model: {} };

    senobjectobject.lineobject.urldata = {
      lists: '/senobjectline/list',
      item: '/senobjectline/item',
      create: '/senobjectline/create',
      edit: '/senobjectline/edit',
      delete: '/senobjectline/delete',
      update: '/senobjectline/edit',
      meta: '/senobjectline/meta'
    };

    senobjectobject.lineobject.tbllines = [];

    senobjectobject.lineobject.loadLine = async function (element) {
      const tableobject = senobjectobject.tbl;
      const tr = element.closest('tr');
      const id = parseInt(tr.getAttribute('data-id'));
      const data = tableobject.datas.find(item => item[tableobject.keyfield] === id);

      //nếu element có data-load=true thì collapse toggle tr extline và return không làm gì cả
      if (element.getAttribute('data-load') === 'true') {
        const extline = tr.nextElementSibling;
        if (extline && extline.classList.contains('extline')) {
          //ẩn hiện tr extline
          if (extline.style.display === 'none') {
            extline.style.display = '';
          } else {
            extline.style.display = 'none';
          }
        }
        return;
      }

      // //tạo tr chèn vào dưới tr hiện tại
      // if (tr.nextElementSibling && tr.nextElementSibling.classList.contains('extline')) {
      //   //nếu đã có tr extline thì xóa đi
      //   tr.nextElementSibling.remove();
      //   return;
      // }
      // tạo id cho dòng chi tiết
      element.setAttribute('data-load', 'true');
      const containerlineid = `${senobjectobject.container.id}-line-${id}`;
      //nếu tồn tại rồi thì không tạo nữa
      if (document.querySelector(`tr.extline[data-id='${containerlineid}']`)) {
        const extline = tr.nextElementSibling;
        if (extline && extline.classList.contains('extline')) {
          //ẩn hiện tr extline
          if (extline.style.display === 'none') {
            extline.style.display = '';
          } else {
            extline.style.display = 'none';
          }
        }
        return;
      }

      const extline = document.createElement('tr');
      extline.classList.add('extline');
      extline.setAttribute('data-id', containerlineid);
      extline.innerHTML = `<td colspan="100%">Loading...</td>`;
      tr.parentNode.insertBefore(extline, tr.nextSibling);
      extline.innerHTML = `<td colspan="100%">
          <div>
            <div class="row-fluid d-none">
              <strong>Details for ${data["String"] || ''} (ID: ${data["Id"] || ''})</strong>
              <p>Bigint: ${data["Bigint"] || ''}</p>
              <p>Numeric: ${data["Numeric"] || ''}</p>
              <p>Options: ${data["Options"] || ''}</p>
              <p>Lookup: ${data["Lookup"] || ''}</p>
              <p>LookupMulti: ${data["LookupMulti"] || ''}</p>
              <p>DateTime: ${data["DateTime"] ? new Date(data["DateTime"]).toLocaleString() : ''}</p>
              <p>Boolean: ${data["Boolean"] ? 'Yes' : 'No'}</p>
              <p>Date: ${data["Date"] ? new Date(data["Date"]).toLocaleDateString() : ''}</p>
              <p>Text: ${data["Text"] || ''}</p>
            </div>            
            <div class="row-fluid">
              <div class="card">
                <div class="card-body">
                  <div class="table-responsive">
                    <table class="table table-sm fs-9 mb-5">
                      <tbody class="list"></tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </td>`;
      const urldata = JSON.parse(JSON.stringify(senobjectobject.lineobject.urldata));
      let datanew = JSON.parse(JSON.stringify(senobjectobject.lineobject.model.datanew));
      datanew.ParentId = id;
      urldata.lists += `?ParentId=${id}`;
      let tblline = new senapp.utils.table({
        datanew: datanew,
        meta: senobjectobject.lineobject.model.meta,
        urldata: urldata,
        container: extline,
        addrow: true, // cho phép thêm mới
        editrow: true, // cho phép sửa
        deleterow: true, // cho phép xóa
        addnewfirst: false, //thêm mới vào đầu danh sách
        loadmoreonvisible: true, // tự động tải thêm dữ liệu khi cuộn đến cuối danh sách  

      });

      //hàm onChangeCellAdd khi td mất focus và có thay đổi dữ liệu
      tblline.onChangeCellAdd = async function ({ td, data } = {}) {
        //nếu chứa class edited thì cập nhật lên server
        if (td.parentElement.classList.contains('edited')) {
          const fieldName = td.getAttribute('data-field');
          switch (fieldName) {
            case 'Bigint':
              if (data.Bigint !== 0) {
                data.Numeric = data.Bigint;
                this.refreshCellDisplayByData({ data, fields: ['Numeric'] });
                return;
              }
              break;
          }
        }
      }

      await tblline.initTable();
      senobjectobject.lineobject.tbllines[id] = tblline;

    };

    //#endregion line

    $(async function () {
      await senobjectobject.tbl.initTable();
      senobjectobject.lineobject.model = await senapp.data.getMeta({ url: senobjectobject.lineobject.urldata.meta });
    });
  </script>
</div>