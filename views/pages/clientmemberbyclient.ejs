<div id="clientmemberbyclient-section">
  <div class="mb-9">
    <!-- <h2 class="mb-4"><%- title %></h2> -->
    <div class="mb-1">
      <div class="">
        <!-- <a onclick="clientmemberbyclientobject.tbl.create()" class="btn btn-subtle-primary">Create New</a> -->
        <a onclick="clientmemberbyclientobject.tbl.deleteBySelected()" class="btn btn-subtle-secondary">Delete
          Selected</a>
      </div>
    </div>
    <div class="row-fluid">
      <div class="card">
        <div class="card-body">
          <div class="search-box mb-3 mx-auto d-none">
            <div class="position-relative">
              <input class="form-control search-input search form-control-sm" type="search" placeholder="Search"
                aria-label="Search" />
              <span class="fas fa-search search-box-icon"></span>
            </div>
          </div>
          <div class="table-responsive">
            <table class="table table-sm fs-9 mb-5">
              <tbody class="list">
                <!-- Table datas will be added here -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    var clientmemberbyclientobject = {};
    clientmemberbyclientobject.model = JSON.parse('<%- JSON.stringify(model) %>');
    clientmemberbyclientobject.container = document.getElementById("clientmemberbyclient-section");//khu vực chứa danh sách
    clientmemberbyclientobject.urldata = {
      lists: `/clientmember/memberbyclient?id=${clientmemberbyclientobject.model.url.query.id}`,
      item: '/clientmember/item',
      create: '/clientmember/create?callback=' + encodeURIComponent('clientmemberbyclientobject.createcallback'),
      edit: '/clientmember/edit?callback=' + encodeURIComponent('clientmemberbyclientobject.editcallback'),
      delete: '/clientmember/delete'
    };

    console.log(clientmemberbyclientobject.model);


    clientmemberbyclientobject.createcallback = function (response) {
      //nếu response[0] tồn tại thì hiển thị thông báo lỗi
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        //clientmemberbyclientobject.tbl.onAddRowData({ data: response[0].data.data });
        senapp.sidebar.menuclickbydatalink('/clientmemberbyclient');
      }
    };

    clientmemberbyclientobject.editcallback = function (response) {
      //nếu response[0] tồn tại thì hiển thị thông báo lỗi
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        //clientmemberbyclientobject.tbl.onChangeRowData({ data: response[0].data.data });
        senapp.sidebar.menuclickbydatalink('/clientmemberbyclient');
      }
    };
    //ẩn hết các trường chỉ để lại trường cần thiết
    clientmemberbyclientobject.model.meta.forEach(element => {
      const excludedFields = ['Email']; // Danh sách các trường không cần thiết
      if (!excludedFields.includes(element.field)) { element.visible = false; }
    });

    // Khởi tạo bảng
    clientmemberbyclientobject.tbl = new senapp.utils.table({
      meta: clientmemberbyclientobject.model.meta,
      urldata: clientmemberbyclientobject.urldata,
      container: clientmemberbyclientobject.container,
      tableelement: clientmemberbyclientobject.container.querySelector('table'),
      modal: true,
      selectcolumn: true,
      filterrow: false, // không hiển thị filter row
      //filtercompact: false // hiển thị filter row ở dạng compact
      loadmoreonvisible: true, // tự động tải thêm dữ liệu khi cuộn đến cuối danh sách
      //loadmoreshowtoast: true,
      metacolumns: [
        { field: 'SysAction', visible: false },
      ],
    });

    clientmemberbyclientobject.tbl.deleteparaext = function (data) {
      //dùng cho override
      return `?UserId=${encodeURIComponent(data.UserId)}&ClientId=${encodeURIComponent(data.ClientId)}`;
    }

    $(function () { clientmemberbyclientobject.tbl.initTable(); });

  </script>

</div>