        // senapp.window.openAttachmentWindow({
        //   parentid: contractlineperformreviewobject.form.data[contractlineperformreviewobject.form.keyfield],
        //   parenttype: contractlineperformreviewobject.model.metareview.senobject,
        //   title: 'All Files'
        // });
      });

    });

  </script>

</div>