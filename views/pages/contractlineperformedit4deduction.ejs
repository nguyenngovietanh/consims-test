    //   const responseworkcategory = await fetch(urlworkcategory, { method: 'GET', });
    //   return await responseworkcategory.json();
    // };

    // contractlineperformupdateobject.getMember = async function () {
    //   const url = `/contractlinemember/list4perform?id=${contractlineperformupdateobject.model.data.ItemId}`;
    //   const response = await fetch(url, { method: 'GET', });
    //   return await response.json();
    // };

    contractlineperformupdateobject.getItem = async function (itemid) {
      const url = `/contractline/item?ItemId=${itemid}`;
      const response = await fetch(url, { method: 'GET', });
      return await response.json();
    };

    contractlineperformupdateobject.getWorkType = async function () {
      const urlworkcategory = `/common/lookup?lookupType=workcategory&type=deduction`;
      const responseworkcategory = await fetch(urlworkcategory, { method: 'GET', });
      return await responseworkcategory.json();
    };

    // contractlineperformupdateobject.getMember = async function () {
    //   //do khong co add nen khong dung contractlineperformupdateobject.model.url.query.worktype
    //   const url = `/contractlinemember/list4perform?id=${contractlineperformupdateobject.model.url.query.contractid}&worktype=deduction`;
    //   const response = await fetch(url, { method: 'GET', });
    //   return await response.json();
    // };

    contractlineperformupdateobject.workcatid = contractlineperformupdateobject.model.url.query.itemid || 0;
    contractlineperformupdateobject.getMember = async function () {
      //do khong co add nen khong dung contractlineperformupdateobject.model.url.query.worktype
      const url = `/contractlinemember/list4perform?id=${contractlineperformupdateobject.model.url.query.contractid}&worktype=deduction&itemid=${contractlineperformupdateobject.workcatid}`;
      const response = await fetch(url, { method: 'GET', });
      return await response.json();
    };

    contractlineperformupdateobject.initMember = async function () {
      //lấy dữ liệu member
      const resultmember = await contractlineperformupdateobject.getMember();
      // console.log('Member data:', resultmember);
      // console.log(JSON.stringify(resultmember, null, 2));

      contractlineperformupdateobject.form.data.Assignment = resultmember.datas.map((item, i) => ({
        UserId: item.UserId,
        Role: item.Role,
        FullName: item.FullName,
        RoleAction: item.RoleAction,
        Description: ''
      }));
      contractlineperformupdateobject.assignmentcontainer.innerHTML = contractlineperformupdateobject.form.data.Assignment.map((item, index) => `
      <div class="row align-items-center border-bottom g-2 p-2">
        
        <!-- Thông tin user -->
        <div class="col-md-4">
          <strong>${item.FullName}</strong><br>
          <small class="text-muted">
            ${item.RoleAction}
          </small>
        </div>

        <!-- Input mô tả -->
        <div class="col-md-8">
          <input
            type="text"
            class="form-control"
            name="Assignment[${index}][Description]"
            placeholder="Nhập mô tả..."
          >
        </div>

      </div>
    `).join("");


    };

    contractlineperformupdateobject.SubmissionTypeChange = async function (element) {
      const selectedValue = element.value;
      // console.log('Selected SubmissionType:', selectedValue);
      // contractlineperformupdateobject.form.data.SubmissionType = selectedValue;
      const item = contractlineperformupdateobject.workcategorydata.find(wc => wc.Alias === selectedValue);
      if (item) {
        contractlineperformupdateobject.workcatid = item.TypeId;
        await contractlineperformupdateobject.initMember();
      }


    };

    contractlineperformupdateobject.workcategorydata = [];
    $(async function () {
      //map lại trường từ Deduction sang Submission
      contractlineperformupdateobject.model.data.ItemId = contractlineperformupdateobject.model.url.query.itemid;
      contractlineperformupdateobject.model.data.ContractId = contractlineperformupdateobject.model.url.query.contractid;
      contractlineperformupdateobject.model.data.SubmissionDate = contractlineperformupdateobject.model.data.DeductionDate;
      contractlineperformupdateobject.model.data.SubmissionName = contractlineperformupdateobject.model.data.Description;
      contractlineperformupdateobject.model.data.Qnty = contractlineperformupdateobject.model.data.SubmittedQnty;


      //gán dữ liệu cho WorkCategory
      const resultworkcategory = await contractlineperformupdateobject.getWorkType();
      if (resultworkcategory.datas) {
        contractlineperformupdateobject.workcategorydata = resultworkcategory.datas;
        const workcategorymeta = contractlineperformupdateobject.form.meta.find(m => m.field === 'SubmissionType');
        //map trường trước khi return
        const mappedData = resultworkcategory.datas.map(item => ({
          id: item.Alias,
          value: item.Alias,
          label: item.Description
        }));
        workcategorymeta.data = mappedData;
      }
      // Populate the WorkCategory select element
      // console.log('WorkCategory data:', resultworkcategory);
      //lấy dữ liệu item
      const resultitem = await contractlineperformupdateobject.getItem(contractlineperformupdateobject.model.data.ItemId);
      // console.log('Item data:', resultitem);
      if (resultitem) {
        //lấy section với calss sen-label và data-field="ItemName" gán giá trị
        const itemNameSection = contractlineperformupdateobject.container.querySelector('.sen-label[data-field="ItemName"]');
        if (itemNameSection) {
          itemNameSection.textContent = resultitem.Description || '';
          //Huỳnh thống nhất lấy WorkName làm ItemName
          itemNameSection.textContent = contractlineperformupdateobject.model.url.query.workname || '';
        }
        // // Gán dữ liệu item vào form        
        // contractlineperformupdateobject.form.data.Unit = resultitem.Unit || contractlineperformupdateobject.form.data.Unit;
        // contractlineperformupdateobject.form.data.UnitPrice = resultitem.UnitPrice || contractlineperformupdateobject.form.data.UnitPrice;
      }

      //   //lấy dữ liệu member
      //   const resultmember = await contractlineperformupdateobject.getMember();
      //   // console.log('Member data:', resultmember);
      //   // console.log(JSON.stringify(resultmember, null, 2));

      //   contractlineperformupdateobject.form.data.Assignment = resultmember.datas.map((item, i) => ({
      //     UserId: item.UserId,
      //     Role: item.Role,
      //     FullName: item.FullName,
      //     RoleAction: item.RoleAction,
      //     Description: ''
      //   }));
      //   contractlineperformupdateobject.assignmentcontainer.innerHTML = contractlineperformupdateobject.form.data.Assignment.map((item, index) => `
      //   <div class="row align-items-center border-bottom g-2 p-2">

      //     <!-- Thông tin user -->
      //     <div class="col-md-4">
      //       <strong>${item.FullName}</strong><br>
      //       <small class="text-muted">
      //         ${item.RoleAction}
      //       </small>
      //     </div>

      //     <!-- Input mô tả -->
      //     <div class="col-md-8">
      //       <input
      //         type="text"
      //         class="form-control"
      //         name="Assignment[${index}][Description]"
      //         placeholder="Nhập mô tả..."
      //       >
      //     </div>

      //   </div>
      // `).join("");


      // contractlineperformupdateobject.form.data.ItemId = contractlineperformupdateobject.model.url.query.itemid;
      contractlineperformupdateobject.form.data.WorkType = contractlineperformupdateobject.model.url.query.worktype || '';
      const alias = contractlineperformupdateobject.model.url.query.alias || '';
      const workname = contractlineperformupdateobject.model.url.query.workname || '';
      contractlineperformupdateobject.form.data.SubmissionType = alias;

      await contractlineperformupdateobject.initMember();
      await contractlineperformupdateobject.form.initForm();

      const attachmentLink = document.getElementById('contractlineperformedit-attachment-link');
      attachmentLink.addEventListener('click', function () {
        const data = contractlineperformupdateobject.form.data;
        const id = data[contractlineperformupdateobject.form.keyfield];
        const url = `${'/common/files?viewname=contractlineperformfiles'}&submissionid=${id}&assignmentid=0&displaymode=by_submissions&parenttype=edit&worktype=${encodeURIComponent(contractlineperformupdateobject.model.url.query.worktype || '')}`;
        senapp.window.offcanvas({
          title: `Files`,
          url: url,
          size: 'md'
