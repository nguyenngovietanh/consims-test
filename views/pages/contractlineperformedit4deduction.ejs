<div id="contractlineperformupdate-section" class="" style="margin: 0 auto;">
  <form id="contractlineperformupdate-form" enctype="multipart/form-data">
    <div class="card">
      <div class="card-header">
        <!-- <h4 class="mb-0">
          <%= title %>
        </h4> -->
        <div class="row g-2 m-0">
          <div class="col-9 d-flex align-items-center">
            <h4 class="sen-label" data-field="ItemName"></h4>
          </div>
          <div class="col-3 d-flex align-items-center gap-2 text-right pe-3">
            <label for="contractlineperformupdate-Stage" class="mb-0">Stage:</label>
            <select id="contractlineperformupdate-Stage" name="Stage" class="form-control">
              <option value="implement">Implement</option>
              <option value="plan">Plan</option>
            </select>
          </div>
        </div>
      </div>
      <div class="card-body">
        <!-- Thông báo tổng -->
        <div class="message-all callout d-none" contractlineperform="alert"></div>
        <!-- <div class="row g-2 m-0">
          <div class="col-9 d-flex align-items-center">
            <h4 class="sen-label" data-field="ItemName"></h4>
          </div>
          <div class="col-3 d-flex align-items-center gap-2 text-right">
            <label for="contractlineperformupdate-Stage" class="mb-0">Stage:</label>
            <select id="contractlineperformupdate-Stage" name="Stage" class="form-control">
              <option value="implement">Implement</option>
              <option value="plan">Plan</option>
            </select>
          </div>
        </div> -->


        <div class="row g-3 align-items-center mb-3">
          <div class="col-md-12">
            <label for="contractlineperformupdate-SubmissionName" field-name="SubmissionName"
              class="control-label">Submission Name:</label>
            <textarea id="contractlineperformupdate-SubmissionName" name="SubmissionName" class="form-control"
              rows="3"></textarea>
          </div>
        </div>

        <div class="row g-3 align-items-center mb-3">
          <div class="col-md-4">
            <label for="contractlineperformupdate-SubmissionDate" field-name="SubmissionDate"
              class="control-label">Submission Date:</label>
            <input type="date" id="contractlineperformupdate-SubmissionDate" name="SubmissionDate" class="form-control">
          </div>
          <div class="col-md-4">
            <label for="contractlineperformupdate-Unit" field-name="Unit" class="control-label">Unit:</label>
            <!-- <p id="contractlineperformreview-Unit" name="Unit" class="form-control bg-light mb-0">
            </p> -->
            <!-- <input type="text" id="contractlineperformupdate-Unit" name="Unit" class="form-control d-none" readonly> -->
            <select id="contractlineperformupdate-Unit" name="Unit" class="form-control">
            </select>
          </div>
          <div class="col-md-4">
            <label for="contractlineperformupdate-SubmissionType" field-name="SubmissionType" class="control-label">Work
              Category:</label>
            <select id="contractlineperformupdate-SubmissionType" name="SubmissionType" class="form-control"
              onchange="contractlineperformupdateobject.SubmissionTypeChange(this);">
            </select>
          </div>

          <!-- <div class="col-md-4">
            <label for="contractlineperformupdate-WorkType" field-name="WorkType" class="control-label">Work
              Category:</label>
            <select id="contractlineperformupdate-WorkType" name="WorkType" class="form-control">
            </select>
          </div> -->
        </div>

        <div class="row g-3 align-items-center mb-3">

          <div class="col-md-6">
            <label for="contractlineperformupdate-Qnty" field-name="Qnty" class="control-label">Quantity:</label>
            <input type="number" id="contractlineperformupdate-Qnty" name="Qnty" class="form-control">
          </div>

          <div class="col-md-6">
            <label for="contractlineperformupdate-UnitPrice" field-name="UnitPrice" class="control-label">Unit
              Price:</label>
            <input type="number" id="contractlineperformupdate-UnitPrice" name="UnitPrice" class="form-control">
          </div>
        </div>

        <div class="row g-3 align-items-center mb-3">
          <div class="col-md-12">
            <label for="contractlineperformupdate-Remarks" field-name="Remarks" class="control-label">Remarks:</label>
            <textarea id="contractlineperformupdate-Remarks" name="Remarks" class="form-control" rows="2"></textarea>
          </div>
        </div>

        <div class="row g-3 align-items-center mb-3">
          <div class="col-md-12">
            <!-- //hiển thị danh sách files -->
            <a href="javascript:void(0)" id="contractlineperformedit-attachment-link"
              class="btn btn-subtle-secondary">All Files</a>
          </div>

          <div class="col-md-12 d-none">
            <label for="contractlineperformupdate-Attachments" field-name="Attachments"
              class="control-label">Attachments:</label>
            <input type="file" id="contractlineperformupdate-Attachments" name="Attachments" class="form-control"
              multiple>
          </div>
        </div>

        <div class="row g-3 align-items-center mb-3">
          <div class="col-md-12">
            <label for="contractlineperformupdate-StartProcessNow" field-name="StartProcessNow"
              class="control-label">Start Process Now:</label>
            <input type="checkbox" id="contractlineperformupdate-StartProcessNow" name="StartProcessNow"
              class="form-check-input" data-load="false"
              onclick="contractlineperformupdateobject.onclickStartProcessNow(this);">
          </div>
          <div class="col-md-12">
            <div id="assignmentsection" class="d-none">
            </div>

          </div>

        </div>
      </div>

      <div class="card-footer">
        <button type="submit" class="btn btn-subtle-primary">Save & Close</button>
        <button type="button" class="btn btn-subtle-secondary"
          onclick="contractlineperformupdateobject.form.cancel()">Cancel</button>
      </div>
    </div>
  </form>

  <script>
    var contractlineperformupdateobject = {};
    // contractlineperformupdateobject.model = <%- JSON.stringify(model) %>;// dùng cách này là ok nhất nhưng bị cảnh báo
    // contractlineperformupdateobject.model = JSON.parse(('<%- JSON.stringify(model) %>').replace(/\r?\n|\r/g, "\\n"));//xử lí xuống dòng trong chuỗi json
    contractlineperformupdateobject.model = JSON.parse('<%- JSON.stringify(model) %>');
    contractlineperformupdateobject.model.data = JSON.parse('<%- JSON.stringify(model.data) %>');//xử lí xuống dòng trong chuỗi json

    contractlineperformupdateobject.container = document.getElementById("contractlineperformupdate-section");//khu vực chứa form nghiệp vụ
    contractlineperformupdateobject.assignmentcontainer = document.getElementById("assignmentsection");//khu vực chứa form nghiệp vụ

    console.log(contractlineperformupdateobject.model);
    // Khởi tạo bảng
    contractlineperformupdateobject.form = new senapp.utils.form({
      meta: contractlineperformupdateobject.model.meta,
      data: contractlineperformupdateobject.model.data,
      urldata: contractlineperformupdateobject.model.url,
      container: contractlineperformupdateobject.container,
      mode: (contractlineperformupdateobject.model.url.path == '/contractlineperform/edit') ? 'edit' : 'create',
    });


    contractlineperformupdateobject.form.saveBefore = async function () {
      //gán lại dữ liệu mô tả cho Assignment
      contractlineperformupdateobject.form.data.Assignment = contractlineperformupdateobject.form.data.Assignment.map((item, i) => ({
        UserId: item.UserId,
        Role: item.Role,
        Description: document.querySelector(
          `[name="Assignment[${i}][Description]"]`
        ).value
      }));


      const url = `/common/uploadfile`;
      const formData = new FormData();

      // Lấy toàn bộ input file
      this.container.querySelectorAll('input[type="file"]').forEach(input => {
        for (const file of input.files) {
          formData.append(input.name, file);
        }
      });

      //nếu không có file thì return true luôn
      if (formData.getAll('Attachments').length === 0) { return true; }
      const response = await fetch('/common/uploadfile', { method: 'POST', body: formData });
      const result = await response.json();
      if (result.status === 'false' || result.status === 0) {
        // Gán lại danh sách file url vào dữ liệu form
        senapp.window.toast({ message: result.message, type: 'danger' });
        return false;
      }
      contractlineperformupdateobject.form.data['files'] = result.datas;
      // console.log('Uploaded files:', contractlineperformupdateobject.form.data['files'],result.datas);
      return true;
    };


    contractlineperformupdateobject.form.save = async function () {
      const formobject = this;
      if (!(await this.saveBefore())) return;
      senapp.window.loading.show(this.container); // Hiển thị loading
      // Gửi dữ liệu đến server để cập nhật data
      //map dữ liệu từ form vào model
      senapp.utils.input2datas({ meta: this.meta, data: this.data, container: this.container });
      const url = this.urldata.path;

      console.log('Saving data to URL:', url, this.data);
      const response = await senapp.data.synServer({ url: url, data: this.data, meta: this.meta });
      senapp.window.loading.hide(); // Ẩn loading

      if (!(await this.saveAfter(response))) return;

      if (response.status == 'false' || response.status == 0) {
        this.mapErrors(response);
      } else {
        //alert(response.message);
        //đóng modal nếu có
        const modal = formobject.container.closest('.modal');
        if (modal) {
          const bootstrapModal = bootstrap.Modal.getInstance(modal);
          bootstrapModal.hide();
        }
        else {
          //nếu có offcanvas thì đóng offcanvas
          const offcanvas = formobject.container.closest('.offcanvas');
          if (offcanvas) {
            const bootstrapOffcanvas = bootstrap.Offcanvas.getInstance(offcanvas);
            bootstrapOffcanvas.hide();
          }
        }
        //nếu có callback thì gọi callback
        if (formobject.urldata.query.callback) {
          senapp.utils.executefunctionbyname(formobject.urldata.query.callback, window, [response]);
        }
      }

    };


    contractlineperformupdateobject.onclickStartProcessNow = function (element) {
      const isChecked = element.checked;
      if (isChecked) {
        contractlineperformupdateobject.assignmentcontainer.classList.remove('d-none');
      } else {
        contractlineperformupdateobject.assignmentcontainer.classList.add('d-none');
      }
    };

    // contractlineperformupdateobject.getItem = async function (itemid) {
    //   const url = `/contractline/item?ItemId=${itemid}`;
    //   const response = await fetch(url, { method: 'GET', });
    //   return await response.json();
    // };

