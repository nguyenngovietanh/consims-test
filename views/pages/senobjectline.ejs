<div id="senobjectline-section">
  <div class="mb-9">
    <h2 class="mb-4"><%- title %></h2>
    <div class="mb-1">
      <div class="">
        <div class="btn-group me-1">

          <div class="dropdown">
            <a class="btn btn-subtle-secondary" href="#" role="button" data-bs-toggle="dropdown" aria-haspopup="true"
              aria-expanded="false"><i class="fa-solid fa-ellipsis-vertical"></i></a>
            <div class="dropdown-menu">
              <a class="dropdown-item" onclick="senobjectlineobject.tbl.deleteBySelected()">Delete Selected</a>
            </div>
          </div>

        </div>
        <div class="btn-group me-1">
          <a onclick="senobjectlineobject.tbl.create()" class="btn btn-subtle-primary">Create New</a>
        </div>
        <div class="btn-group me-1">
          <a onclick="senobjectlineobject.tbl.deleteBySelected()" class="btn btn-subtle-secondary">Delete Selected</a>
          <a onclick="senobjectlineobject.tbl.saveNews()" class="btn btn-subtle-secondary">Save News</a>
          <a onclick="senobjectlineobject.shownews()" class="btn btn-subtle-secondary">View Card</a>
        </div>

      </div>
    </div>
    <div class="row-fluid">
      <div class="card">
        <div class="card-body">
          <div class="search-box mb-3 mx-auto">
            <div class="position-relative">
              <input class="form-control search-input search form-control-sm" type="search" placeholder="Search"
                aria-label="Search" />
              <span class="fas fa-search search-box-icon"></span>
            </div>
          </div>
          <div class="table-responsive">
            <table class="table table-sm fs-9 mb-5">
              <tbody class="list">
                <!-- Table datas will be added here -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    var senobjectlineobject = {};
    senobjectlineobject.model = JSON.parse('<%- JSON.stringify(model) %>');
    senobjectlineobject.container = document.getElementById("senobjectline-section");//khu vực chứa danh sách
    senobjectlineobject.urldata = {
      lists: '/senobjectline/list',
      item: '/senobjectline/item',
      create: '/senobjectline/create?callback=' + encodeURIComponent('senobjectlineobject.createcallback'),//+'&id=1',
      edit: '/senobjectline/edit?callback=' + encodeURIComponent('senobjectlineobject.editcallback'),
      delete: '/senobjectline/delete',
      update: '/senobjectline/edit'
    };

    senobjectlineobject.createcallback = function (response) {
      //nếu response[0] tồn tại thì hiển thị thông báo lỗi
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        senobjectlineobject.tbl.onAddRowData({ data: response[0].data });
        //senapp.sidebar.menuclickbydatalink('/senobjectline');
      }
    };
    senobjectlineobject.editcallback = function (response) {
      //nếu response[0] tồn tại thì hiển thị thông báo lỗi
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        senobjectlineobject.tbl.onChangeRowData({ data: response[0].data });
        //senapp.sidebar.menuclickbydatalink('/senobjectline');
      }
    };
    // Khởi tạo bảng
    senobjectlineobject.tbl = new senapp.utils.table({
      meta: senobjectlineobject.model.meta,
      urldata: senobjectlineobject.urldata,
      container: senobjectlineobject.container,
      tableelement: senobjectlineobject.container.querySelector('table'),
      modal: true,
      selectcolumn: true, // có hiển thị cột chọn hay không
      addrow: true, // cho phép thêm mới
      editrow: true, // cho phép sửa
      deleterow: true, // cho phép xóa
      readonly: false, //chế độ chỉ đọc
      filterrow: true, // có hiển thị filter row hay không
      filtercompact: false,
      loadmoreonvisible: true, // tự động tải thêm dữ liệu khi cuộn đến cuối danh sách      
      sysnoviewcard: true, // cho phép xem card khi click vào số thứ tự
      metacolumns: [
        // { field: 'Ext01', description: 'Ext01', colorder: 1, visible: true, show: true },
        // { field: 'Ext02', description: 'Ext02', colorder: 2, visible: true, show: true },
        // { field: 'SysNo', description: 'Số thứ tự', colorder: -50, visible: true, show: false },
        // { field: 'SysSelect', description: 'SysSelect', colorder: -7, visible: true, show: true },
        // { field: 'String', description: 'Chuỗi', width: 150, visible: true, show: true },
        // { field: 'Id', description: 'ID', width: 100, visible: true, show: true }
      ],
      // customcolumns: ['Ext01', 'Ext02'],// ['SysNo', 'String', 'Id'], // Danh sách các cột tùy chỉnh khi render cell
      // filtercompact: true, // hiển thị filter row ở dạng compact
      allowexport2excel: true,//cho phép xuất Excel
      datanew: senobjectlineobject.model.datanew,
    });

    //#region test
    senobjectlineobject.tbl.genCellDataCustom = function ({ data, metacolumn }) {
      if (!metacolumn || !metacolumn.field) {
        return null; // Trả về null nếu không có metacolumn hoặc field
      }
      // Hàm này sẽ được sử dụng để tạo dữ liệu cho các cột tùy chỉnh
      const tableobject = this;
      const td = document.createElement('td');
      td.setAttribute('data-field', metacolumn.field);
      //nếu field.visible là false hoặc field.show là false thì không hiển thị cột này  gán class d-none
      if (!metacolumn.show) { td.classList.add('d-none'); }

      switch (metacolumn.field) {
        case 'Ext01':
          td.innerHTML = `<a href="javascript:;" onclick="senobjectlineobject.loadLine(this)">${data["String"] || ''}</a>`;
          break;
        case 'Ext02':
          const alink = document.createElement('a');
          alink.href = 'javascript:;';
          alink.onclick = function () {
            tableobject.cardview({ datas: [data] });
          };
          alink.textContent = data["String"] || '';
          td.appendChild(alink);
          break;
        case 'SysNo':
          return this.genCellDataNo({ data, metacolumn });
          break;
        case 'String':
          //nếu metacolumn.field là 'String' thì nội dung là giá trị của
          td.innerHTML = `<strong>${data[metacolumn.field] || ''}</strong>`;
          break;
        case 'Id':
          //nếu metacolumn.field là 'Id' thì nội dung là giá trị của
          const editLink = document.createElement('a');
          editLink.dataset.id = data[tableobject.keyfield];
          editLink.href = 'javascript:;';
          editLink.onclick = function () { tableobject.edit(this); };
          editLink.textContent = data[metacolumn.field];
          td.appendChild(editLink);
          break;
        default:
          //nếu không phải là cột tùy chỉnh thì trả về giá trị của trường đó
          td.innerHTML = data[metacolumn.field] || '';
          break;
      }
      return td;
    }

    //#region dev
    senobjectlineobject.tbl.datanews.length = 0;//xóa dữ liệu cũ
    for (let i = 1; i <= 3; i++) {
      senobjectlineobject.tbl.datanews.push({
        ParentId: 1,
        GId: `gid-${i}`,
        Id: i * (-1),
        Bigint: 1000000000 + i,
        Numeric: 100.5 + i,
        String: `Sample String ${i}`,
        Options: `${i % 3}`,
        Lookup: `Lookup${i % 5}`,
        LookupMulti: `LookupMulti${i % 4},LookupMulti${i % 2}`,
        DateTime: new Date(2024, 0, i, 10, 30, 0),
        Boolean: i % 2 === 0,
        Date: new Date(2024, 0, i),
        Text: `Sample text for row ${i}`
      });
    }
    
    senobjectlineobject.shownews = function () {
      const tableobject = senobjectlineobject.tbl;
      const datas = [tableobject.datanew];
      tableobject.cardview();
    };

    //hàm onChangeCellAdd khi td mất focus và có thay đổi dữ liệu
    senobjectlineobject.tbl.onChangeCellAdd = async function ({ td, data } = {}) {
      // console.log('onChangeCellAdd:', td, data);
      //nếu chứa class edited thì cập nhật lên server
      if (td.parentElement.classList.contains('edited')) {
        const fieldName = td.getAttribute('data-field');
        switch (fieldName) {
          case 'Bigint':
            if (data.Bigint !== 0) {
              // senapp.window.toast({ message: `Bigint must be ${data.Bigint}`, type: 'info' });
              data.Numeric = data.Bigint;
              //this.updateCellByData(data, 'Numeric');
              this.refreshCellDisplayByData({ data, fields: ['Numeric'] });
              // this.refreshRowDisplayByData({data});
              return;
            }
            break;
        }

        // const tableobject = this;
        // if (!this.addrow || this.readonly) {
        //   // senapp.window.toast({ message: 'Bạn không có quyền sửa dòng này', type: 'danger' });
        //   senapp.window.toast({ message: 'You do not have permission to edit this row', type: 'danger' });
        //   return;
        // }
        // //nếu data rỗng thì lấy data từ tableobject.datas theo keyfield
        // if (!data) {
        //   const keyvalue = td.parentElement.getAttribute('data-id');
        //   data = tableobject.datas.find(item => item[tableobject.keyfield] == keyvalue);
        // }
      }
    }

    //#endregion
    $(function () { senobjectlineobject.tbl.initTable(); });
  </script>
</div>