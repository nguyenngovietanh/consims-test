    contractlineperformfilesobject.tbl.delete = async function (row) {
      if (!this.deleterow || this.readonly) {
        //senapp.window.toast({ message: 'Bạn không có quyền xóa dòng này', type: 'danger' });
        senapp.window.toast({ message: 'You do not have permission to delete this row', type: 'danger' });
        return;
      }

      const tableobject = this;
      const id = $(row).attr('data-id');
      const deletedData = tableobject.datas.find(d => d[tableobject.keyfield] == id);
      const response = await this.synData({ data: deletedData, type: 'delete' });
      console.log('Delete response:', response);
      if (response.status == 'false' || response.status == 0) {
        senapp.window.toast({ message: response.message, type: 'danger' });
      } else {
        senapp.window.toast({ message: response.message, type: 'success' });
        // Xóa row khỏi DOM
        $(row).remove();
        // Cập nhật lại số thứ tự
        tableobject.resetSysNo();
        // Lưu vào danh sách deleted
        if (deletedData) {
          tableobject.datadeleteds.push(deletedData);
          // Xóa khỏi mảng datas
          tableobject.datas.splice(tableobject.datas.indexOf(deletedData), 1);
        }
      }
      //gọi hàm callback nếu có
      if (this.deletecallback && typeof this.deletecallback === 'function') {
        await this.deletecallback({ response, data: deletedData, row });
      }

    };

    //#region UI file upload
    contractlineperformfilesobject.fileInput = document.getElementById('uploadfile-Attachments');
    contractlineperformfilesobject.fileList = document.getElementById('contractlineperformfiles-fileList');
    contractlineperformfilesobject.dt = new DataTransfer();
    /* ===== thêm file ===== */
    contractlineperformfilesobject.addFiles = function (files) {
      for (const file of files) {
        // // ví dụ validate 10MB
        // if (file.size > 10 * 1024 * 1024) {
        //   alert(file.name + ' > 10MB');
        //   continue;
        // }
        this.dt.items.add(file);
      }
      this.fileInput.files = this.dt.files;
      this.render();
    }
    /* ===== render danh sách ===== */
    contractlineperformfilesobject.render = function () {
      this.fileList.innerHTML = '';
      [...this.dt.files].forEach((file, i) => {
        const li = document.createElement('span');
        //thêm class cho span
        // badge badge-phoenix fs--2 badge-phoenix-success
        li.className = 'badge badge-phoenix fs--2 badge-phoenix-secondary m-1 p-2 d-inline-flex align-items-center';
        li.style.fontSize = '10px';
        //tạo span gán tên file và kích thước
        const span = document.createElement('span');
        span.textContent = `${file.name} (${(file.size / 1024).toFixed(1)} KB)`;
        li.appendChild(span);
        //tạo nút xóa file bằng thẻ a và gán sự kiện onclick
        const removeButton = document.createElement('a');
        removeButton.href = 'javascript:;';
        removeButton.className = 'ms-2 text-decoration-none text-muted';
        removeButton.innerHTML = 'x';
        removeButton.onclick = () => { this.removeFile(i); };
        li.appendChild(removeButton);
        // li.innerHTML = `
        //         <span>${file.name} (${(file.size / 1024).toFixed(1)} KB)</span>
        //         <button onclick="contractlineperformfilesobject.removeFile(${i})">❌</button>
        //     `;
        this.fileList.appendChild(li);
      });
    }

    /* ===== xóa file ===== */
    contractlineperformfilesobject.removeFile = function (index) {
      this.dt.items.remove(index);
      this.fileInput.files = this.dt.files;
      this.render();
    }
    //#endregion UI file upload 

    $(async function () {
      /* ===== chọn file ===== */
      contractlineperformfilesobject.fileInput.addEventListener('change', e => {
        contractlineperformfilesobject.addFiles(e.target.files);
      });

      const menu = contractlineperformfilesobject.container.querySelector('#contractlineperformfiles-menu-section');
      if (contractlineperformfilesobject.model.url.query.parenttype !== 'edit') {
        const roleuploadresponse = await fetch(contractlineperformfilesobject.urldata.checkroleupload);
        const roleuploadresult = await roleuploadresponse.json();
        if (roleuploadresult.IsAbleToAddFile === "No") {
          // menu.style.display = 'none'; 
          menu.querySelector('#contractlineperformfiles-form').style.display = 'none'; //ẩn phần upload file nếu không có quyền chỉnh sửa
          menu.querySelector('#contractlineperformfiles-deleteselected').style.display = 'none'; //ẩn nút xóa nếu không có quyền chỉnh sửa
        }
      }

      if (contractlineperformfilesobject.editable === false) {
        // menu.style.display = 'none'; //tạm không ẩn hết 
        menu.querySelector('#contractlineperformfiles-form').style.display = 'none'; //ẩn phần upload file nếu không có quyền chỉnh sửa
        menu.querySelector('#contractlineperformfiles-deleteselected').style.display = 'none'; //ẩn nút xóa nếu không có quyền chỉnh sửa
      }
      contractlineperformfilesobject.tbl.initTable();
    });

  </script>

