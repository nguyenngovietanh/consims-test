    contractlineperformfilesobject.signfile = function (element, viewonly = false) {
      // console.log('Sign File function called');
      const id = element.getAttribute('data-fileid') || 0;
      const url = `${this.urldata.sign}&fileid=${id}&view=${viewonly}&callback=contractlineperformfilesobject.signfilecallback`;
      senapp.window.offcanvas({
        title: `Signing status`,
        url: url,
        size: 'md'
      });
    }
    contractlineperformfilesobject.signfilecallback = function (data) {
      console.log('Sign file callback data:', data);
      contractlineperformfilesobject.tbl.refreshDataDisplay();
    };
    contractlineperformfilesobject.uploadfile = async function (element) {
      const url = `/contractlineperform/uploadfile`;
      const formData = new FormData();

      formData.append('sourceid', contractlineperformfilesobject.model.url.query.submissionid || 0);
      formData.append('assignmentid', contractlineperformfilesobject.model.url.query.assignmentid || 0);
      formData.append('displaymode', 'Modified Upload');
      formData.append('worktype', contractlineperformfilesobject.model.url.query.worktype || 'construction_work');

      const input = document.getElementById('uploadfile-Attachments');
      for (const file of input.files) { formData.append(input.name, file); }

      const response = await fetch(url, { method: 'POST', body: formData });
      const result = await response.json();
      console.log('Upload response:', result);
      if (result.status === 'false' || result.status === 0) {
        // Gán lại danh sách file url vào dữ liệu form
        senapp.window.toast({ message: result.message, type: 'danger' });
        return false;
      }
      console.log('Uploaded files:', result.datas);
      contractlineperformfilesobject.tbl.refreshDataDisplay();

      return true;

    }
    
