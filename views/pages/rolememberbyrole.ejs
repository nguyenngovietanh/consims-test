<div id="rolememberbyrole-section">
  <div class="mb-9">
    <!-- <h2 class="mb-4"><%- title %></h2> -->
    <div class="mb-1">
      <div class="">
        <!-- <a onclick="rolememberbyroleobject.tbl.create()" class="btn btn-subtle-primary">Create New</a> -->
        <a onclick="rolememberbyroleobject.tbl.deleteBySelected()" class="btn btn-subtle-secondary">Delete
          Selected</a>
      </div>
    </div>
    <div class="row-fluid">
      <div class="card">
        <div class="card-body">
          <div class="search-box mb-3 mx-auto d-none">
            <div class="position-relative">
              <input class="form-control search-input search form-control-sm" type="search" placeholder="Search"
                aria-label="Search" />
              <span class="fas fa-search search-box-icon"></span>
            </div>
          </div>
          <div class="table-responsive">
            <table class="table table-sm fs-9 mb-5">
              <tbody class="list">
                <!-- Table datas will be added here -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    var rolememberbyroleobject = {};
    rolememberbyroleobject.model = JSON.parse('<%- JSON.stringify(model) %>');
    rolememberbyroleobject.container = document.getElementById("rolememberbyrole-section");//khu vực chứa danh sách
    rolememberbyroleobject.urldata = {
      lists: `/rolemember/memberbyrole?id=${rolememberbyroleobject.model.url.query.id}&pagesize=100`,
      item: '/rolemember/item',
      create: '/rolemember/create?callback=' + encodeURIComponent('rolememberbyroleobject.createcallback'),
      edit: '/rolemember/edit?callback=' + encodeURIComponent('rolememberbyroleobject.editcallback'),
      delete: '/rolemember/delete'
    };

    console.log(rolememberbyroleobject.model);


    rolememberbyroleobject.createcallback = function (response) {
      //nếu response[0] tồn tại thì hiển thị thông báo lỗi
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        //rolememberbyroleobject.tbl.onAddRowData({ data: response[0].data.data });
        senapp.sidebar.menuclickbydatalink('/rolememberbyrole');
      }
    };

    rolememberbyroleobject.editcallback = function (response) {
      //nếu response[0] tồn tại thì hiển thị thông báo lỗi
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        //rolememberbyroleobject.tbl.onChangeRowData({ data: response[0].data.data });
        senapp.sidebar.menuclickbydatalink('/rolememberbyrole');
      }
    };
    //ẩn hết các trường chỉ để lại trường cần thiết
    rolememberbyroleobject.model.meta.forEach(element => {
      const excludedFields = ['Email']; // Danh sách các trường không cần thiết
      if (!excludedFields.includes(element.field)) { element.visible = false; }
    });

    // Khởi tạo bảng
    rolememberbyroleobject.tbl = new senapp.utils.table({
      meta: rolememberbyroleobject.model.meta,
      urldata: rolememberbyroleobject.urldata,
      container: rolememberbyroleobject.container,
      tableelement: rolememberbyroleobject.container.querySelector('table'),
      modal: true,
      selectcolumn: true,
      filterrow: false, // không hiển thị filter row
      //filtercompact: false // hiển thị filter row ở dạng compact
      loadmoreonvisible: true, // tự động tải thêm dữ liệu khi cuộn đến cuối danh sách
      //loadmoreshowtoast: true,
      metacolumns: [
        { field: 'SysAction', visible: false },
      ],
    });

    rolememberbyroleobject.tbl.deleteparaext = function (data) {
      //dùng cho override
      return `?UserId=${encodeURIComponent(data.UserId)}&RoleId=${encodeURIComponent(rolememberbyroleobject.model.url.query.id)}`;
    }

    $(function () { rolememberbyroleobject.tbl.initTable(); });

  </script>

</div>