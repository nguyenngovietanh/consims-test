 <style>
    :root{
      --border:#000;
      --grid:#000;
      --text:#000;
      --muted:#444;
      --approved:#d40000;
      --bg:#fff;
    }
    body{
      margin:0;
      padding:24px;
      background:#f5f5f5;
      font-family: Arial, Helvetica, sans-serif;
      color:var(--text);
    }
    .sheet{
      width: 860px;
      max-width: 100%;
      margin: 0 auto;
      background: var(--bg);
      border: 2px solid var(--border);
      box-shadow: 0 2px 10px rgba(0,0,0,.08);
    }
    .row{
      display:flex;
      width:100%;
    }
    .cell{
      border: 1px solid var(--grid);
      padding: 6px 8px;
      font-size: 12px;
      line-height: 1.25;
    }
    .cell.tight{ padding:4px 6px; }
    .cell.center{ text-align:center; }
    .cell.right{ text-align:right; }
    .cell.bold{ font-weight:700; }
    .cell.muted{ color:var(--muted); }
    .no-border{ border:none !important; }

    /* Header top strip */
    .logo{
      width: 34%;
      display:flex;
      align-items:center;
      gap:10px;
      font-weight:700;
      font-size:16px;
      padding:10px 12px;
    }
    .logo-badge{
      width:28px; height:28px;
      border:2px solid #1f4e79;
      border-radius:50%;
      position:relative;
      box-sizing:border-box;
    }
    .logo-badge:before{
      content:"";
      position:absolute;
      inset:6px;
      border:2px solid #c00000;
      border-left-color:transparent;
      border-bottom-color:transparent;
      border-radius:50%;
      transform:rotate(45deg);
    }
    .meta{
      width: 46%;
      padding:0;
    }
    .meta .row .cell{
      border-left:1px solid var(--grid);
      border-right:1px solid var(--grid);
    }
    .status{
      width: 20%;
      padding:0;
    }
    .status .approved{
      background: var(--approved);
      color:#fff;
      font-weight:700;
      text-align:center;
      padding:10px 8px;
      border:1px solid var(--grid);
      font-size:14px;
    }

    /* Title */
    .title{
      text-align:center;
      font-weight:800;
      padding:10px 8px;
      border-top:1px solid var(--grid);
      border-bottom:1px solid var(--grid);
      font-size:14px;
      letter-spacing:.2px;
    }
    .subtitle{
      text-align:center;
      font-weight:800;
      padding:0 8px 10px;
      margin-top:-6px;
      font-size:13px;
    }

    /* Info grid */
    table{
      border-collapse:collapse;
      width:100%;
    }
    .info td{
      border:1px solid var(--grid);
      padding:6px 8px;
      font-size:12px;
      vertical-align:top;
    }
    .info td.label{
      width: 13%;
      font-weight:700;
    }
    .info td.value{
      width: 37%;
    }
    .info td.label2{
      width: 13%;
      font-weight:700;
    }
    .info td.value2{
      width: 37%;
    }

    /* Main table */
    .main th, .main td{
      border:1px solid var(--grid);
      padding:6px 8px;
      font-size:12px;
      vertical-align:top;
    }
    .main th{
      font-weight:800;
      text-align:center;
    }
    .main td.num{
      width:56px;
      text-align:center;
      white-space:nowrap;
    }
    .main td.content{
      width:auto;
    }
    .main td.amount{
      width:210px;
      text-align:right;
      white-space:nowrap;
      font-variant-numeric: tabular-nums;
    }
    .section{
      font-weight:800;
    }
    .indent-1{ padding-left:18px !important; }
    .indent-2{ padding-left:34px !important; }
    .indent-3{ padding-left:50px !important; }

    /* Footer approvals */
    .footer-title{
      font-weight:800;
      padding:8px;
      border-top:1px solid var(--grid);
      border-bottom:1px solid var(--grid);
      font-size:12px;
    }
    .approvals th, .approvals td{
      border:1px solid var(--grid);
      padding:6px 8px;
      font-size:12px;
      vertical-align:top;
    }
    .approvals th{
      text-align:center;
      font-weight:800;
    }
  </style>
