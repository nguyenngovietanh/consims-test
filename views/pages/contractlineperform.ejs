    contractobject.cachesessionid = '';
    contractobject.lineperformobject.linefilterchange = async function (element) {
      const tableolinebject = contractobject.lineperformobject.tbl;

      const filtercontainer = contractobject.container; //element.closest('table');// element.closest('.mb-1');
      const filterstage = filtercontainer.querySelector('select[name="filter-stage"]').value;
      const filterworktype = filtercontainer.querySelector('select[name="filter-worktype"]').value;
      const filterlevel = filtercontainer.querySelector('select[name="filter-level"]').value;
      const filterstatus = filtercontainer.querySelector('select[name="filter-status"]').value;
      const filterrole = filtercontainer.querySelector('select[name="filter-role"]').value;
      const filterkeyword = filtercontainer.querySelector('input[name="filter-keyword"]').value.trim();
      const filterfromdate = filtercontainer.querySelector('input[name="filter-fromdate"]').value;
      const filtertodate = filtercontainer.querySelector('input[name="filter-todate"]').value;
      const filterhavingsubmission = filtercontainer.querySelector('input[name="filter-havingsubmission"]').checked;
      const filteroverallapprovalstatus = filtercontainer.querySelector('input[name="filter-overallapprovalstatus"]').checked;
      const filterworkcat = filtercontainer.querySelector('select[name="filter-workcategory"]').value;
      const filtercontract = filtercontainer.querySelector('select[name="filter-contract"]').value;

      let filter = `filterworktype=${encodeURIComponent(filterworktype)}`;
      filter += `&filterrole=${encodeURIComponent(filterrole)}`;
      filter += `&filterfromdate=${encodeURIComponent(filterfromdate)}`;
      filter += `&filtertodate=${encodeURIComponent(filtertodate)}`;
      filter += `&filterkeyword=${encodeURIComponent(filterkeyword)}`;
      filter += `&filterapprovalstatus=${encodeURIComponent(filterstatus)}`;
      filter += `&filterstage=${encodeURIComponent(filterstage)}`;
      filter += `&filtertolevel=${encodeURIComponent(filterlevel)}`;
      filter += `&filterhavingsubmission=${filterhavingsubmission ? "Yes" : "No"}`;
      filter += `&filteroverallapprovalstatus=${filteroverallapprovalstatus ? "Yes" : "No"}`;
      // filter += `&filterworkcat=${encodeURIComponent(filterworkcat)}`;//yêu cầu chỉnh sau này
      filter += `&filterworkcat=All`;//yêu cầu ngầm định All
      filter += `&filtercontract=${encodeURIComponent(filtercontract)}`;

      // filter += `&cachesessionid=${encodeURIComponent(contractobject.cachesessionid)}`;

      // if (contractobject.cachesessionid === '') {
      //   senapp.window.loading.show();
      //   const url = `${tableolinebject.urldata.lists0}?${filter}&pagesize=1`;
      //   const res = await fetch(`${url}`, { method: 'GET', });
      //   const resjson = await res.json();
      //   contractobject.cachesessionid = resjson.cachesessionid || '';
      //   senapp.window.loading.hide();
      // }

      senapp.window.loading.show();
      const url = `${tableolinebject.urldata.lists0}?${filter}&pagesize=1`;
      const res = await fetch(`${url}`, { method: 'GET', });
      const resjson = await res.json();
      contractobject.cachesessionid = resjson.cachesessionid || '';
      senapp.window.loading.hide();


      filter += `&cachesessionid=${encodeURIComponent(contractobject.cachesessionid)}`;

      tableolinebject.urldata.lists = `${tableolinebject.urldata.lists0}?${filter}`;

      //fetch lại dữ liệu



      contractobject.filterworktype = filterworktype;
      await contractobject.getWorkCategory();

      tableolinebject.refreshDataDisplay();
    };
