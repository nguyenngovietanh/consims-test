          { field: 'RemarksOnApproval', description: 'Remarks', gridwidth: 136, readonly: false },
          { field: 'ReviewedQnty', description: 'Qnty', gridwidth: 88, readonly: false },
          { field: 'ReviewedUnitPrice', description: 'Unit price', gridwidth: 104, readonly: false },
          { field: 'ReviewedAmount', description: 'Total', gridwidth: 104, readonly: false },
        ];

        tableobject.meta.forEach(column => {
          column.show = false;
          column.visible = column.key === true ? false : column.visible;
        });

        visibleColumns.forEach((config, index) => {
          let column = tableobject.meta.find(item => item.field === config.field);
          if (!column) {
            column = {
              field: config.field,
              type: config.type || 'string',
              key: false,
              isnullable: true,
              readonly: config.readonly !== false
            };
            tableobject.meta.push(column);
          }

          column.description = config.description;
          column.colorder = (index + 1) * 10;
          column.show = true;
          column.visible = true;
          column.gridwidth = config.gridwidth;
          column.readonly = config.readonly !== false;
        });

        tableobject.metacolumns = [
          { field: 'SysAction', visible: false, show: false, colorder: -9 },
          { field: 'Ext02', description: 'Details', colorder: 170, visible: true, show: true, gridwidth: 76, readonly: true },
        ];
      };

      contractobject.lineperformobject.configureSubmissionColumns();

      // contractobject.lineperformobject.tbl.meta.map(column => {
      //   column.description = `<span class="text-primary">${column.description || ''}</span>`;
      // });

      // contractobject.lineperformobject.tbl.meta.forEach(column => {
      //   const description=column.description || '';
      //   column.description = `<span class="text-primary">${description}</span>`;
      // });



      await contractobject.lineperformobject.tbl.initTable();

      contractobject.lineperformobject.updateActionState = function () {
        const quickApprovalButton = contractobject.container.querySelector('[data-consims-quick-approval]');
        if (!quickApprovalButton) return;
        let selectedCount = 0;
        try {
          selectedCount = contractobject.lineperformobject.tbl.getDataSelected().length;
        } catch (err) {
          selectedCount = 0;
        }
        quickApprovalButton.disabled = selectedCount === 0;
        quickApprovalButton.classList.toggle('is-disabled', selectedCount === 0);
      };

      contractobject.lineperformobject.updateEmptyState = function () {
        const emptyState = contractobject.container.querySelector('[data-consims-empty-state]');
        const tableBody = contractobject.container.querySelector('#contractlineperform-submission-table tbody');
        const contractSelect = contractobject.container.querySelector('[name="filter-contract"]');
        if (!emptyState || !tableBody) return;
        const hasSelectedContract = Boolean(contractSelect?.value);
        contractobject.container.classList.toggle('is-contract-empty', !hasSelectedContract);
        emptyState.hidden = hasSelectedContract;
      };

      contractobject.lineperformobject.updateSubmissionShellState = function () {
        contractobject.lineperformobject.updateEmptyState();
        contractobject.lineperformobject.updateActionState();
      };

      const originalOnChangeDataSelect = contractobject.lineperformobject.tbl.onChangeDataSelect.bind(contractobject.lineperformobject.tbl);
      contractobject.lineperformobject.tbl.onChangeDataSelect = function () {
        const result = originalOnChangeDataSelect(...arguments);
        contractobject.lineperformobject.updateActionState();
        return result;
      };

      const originalRefreshDataDisplay = contractobject.lineperformobject.tbl.refreshDataDisplay.bind(contractobject.lineperformobject.tbl);
      contractobject.lineperformobject.tbl.refreshDataDisplay = async function () {
        const result = await originalRefreshDataDisplay(...arguments);
        window.setTimeout(contractobject.lineperformobject.updateSubmissionShellState, 120);
        return result;
      };

      contractobject.container.querySelectorAll('.consims-submission-category').forEach(button => {
        button.addEventListener('click', () => {
          contractobject.container.querySelectorAll('.consims-submission-category').forEach(item => item.classList.remove('active'));
          button.classList.add('active');
        });
      });

      contractobject.container.querySelector('#contractlineperform-submission-table')?.addEventListener('change', event => {
        if (event.target.matches('td[data-field="SysSelect"] input[type="checkbox"], th[data-field="SysSelect"] input[type="checkbox"]')) {
          window.setTimeout(contractobject.lineperformobject.updateActionState, 0);
        }
      });

      //gÃ¡n Ä‘á»‹nh dáº¡ng tiÃªu Ä‘á» cá»™t Ä‘Æ°á»£c phÃ©p sá»­a
      const headers = contractobject.lineperformobject.tbl.container.querySelectorAll('th');
      headers.forEach(th => {
        const field = th.getAttribute('data-field');
        const metacolumn = contractobject.lineperformobject.tbl.metacolumns.find(col => col.field === field);
        if (metacolumn) {
          const isEditable = metacolumn.readonly !== true;// metacolumn.edit;
          if (isEditable) {
            th.classList.add('text-primary');
          }
        }
      });


      //khá»Ÿi táº¡o Ä‘iá»u kiá»‡n lá»c cho chi tiáº¿t há»£p Ä‘á»“ng
      await contractobject.getWorkType();
      if (contractobject.itemworktype.length > 0) {
        contractobject.filterworktype = contractobject.itemworktype[0].id;
      }

      await contractobject.getStatus();
      await contractobject.getWorkCategory();
      await contractobject.getRoles();
      // console.log('contractobject.itemstage:', contractobject.itemstage);
      // console.log('contractobject.itemstatus:', contractobject.itemstatus);
      // console.log('contractobject.itemworktype:', contractobject.itemworktype);
      // console.log('contractobject.itemworkcategory:', contractobject.itemworkcategory);
      //gÃ¡n filter
      const linefilterhtml = contractobject.lineperformobject.filterline();
      contractobject.container.querySelector('#contractlineperform-table-filter').innerHTML = linefilterhtml;

      //ngáº§m Ä‘á»‹nh chon status = 'in-progress'
      contractobject.container.querySelector('select[name="filter-status"]').value = 'In-Progress';
      //gá»i hÃ m filterchange Ä‘á»ƒ load dá»¯ liá»‡u


      await contractobject.lineperformobject.linefilterchange(contractobject.container.querySelector('input[name="filter-keyword"]'));

      const contractInput = contractobject.container.querySelector('#contractlineperform-contract-select');
      const contractPicker = contractobject.container.querySelector('[data-consims-contract-picker]');
      const contractToggle = contractPicker?.querySelector('[data-consims-contract-toggle]');
      const contractMenu = contractPicker?.querySelector('[data-consims-contract-menu]');
      const contractSearch = contractPicker?.querySelector('[data-consims-contract-search]');
      const contractOptionsEl = contractPicker?.querySelector('[data-consims-contract-options]');
      const lookup = contractobject.lineperformobject.lookupfiltercontract;

      let contractLookupRequest = 0;
      let contractOptions = [];
      const selectedContractValues = new Set();
      const contractOptionLabels = new Map();
      const escapeContractHtml = value => `${value ?? ''}`
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

      contractobject.lineperformobject.loadContractChoices = async function (keyword = '') {
        const requestId = ++contractLookupRequest;
        lookup.filter.conditions[0].value = (keyword || '').trim();
        try {
          const res = await fetch(`${lookup.url}?lookupType=contract&pagesize=${lookup.pagesize || 100}&filter=${JSON.stringify(lookup.filter)}`);
          if (requestId !== contractLookupRequest) return lookup.data || [];
          if (res.ok) {
            const data = await res.json();
            lookup.data = Array.isArray(data.datas)
              ? data.datas.map(item => {
                const value = `${item.ContractId ?? ''}`;
                const label = [item.ContractCode, item.ContractName].filter(Boolean).join(' - ') || value;
                contractOptionLabels.set(value, label);
                return { id: value, value, label };
              }).filter(item => item.value)
              : [];
            return lookup.data;
          }
        } catch (err) { console.error('Loi khi goi API:', err); }
        lookup.data = [];
        return lookup.data;
      };

      const getLoadedContractValues = () => contractOptions.map(item => `${item.value}`).filter(Boolean);
      const hasAllLoadedContractsSelected = () => {
        const allValues = getLoadedContractValues();
        return allValues.length > 0 && allValues.every(value => selectedContractValues.has(value));
      };

      const updateContractLabel = () => {
        if (!contractSearch || !contractInput) return;
        const selectedValues = Array.from(selectedContractValues);
        if (contractInput.value === 'All') {
          contractSearch.value = 'All contracts';
          contractSearch.classList.add('has-value');
        } else if (selectedValues.length === 1) {
          contractSearch.value = contractOptionLabels.get(selectedValues[0]) || '1 contract selected';
          contractSearch.classList.add('has-value');
        } else if (selectedValues.length > 1) {
          contractSearch.value = `${selectedValues.length} contracts selected`;
          contractSearch.classList.add('has-value');
        } else {
          contractSearch.value = '';
          contractSearch.classList.remove('has-value');
        }
      };

      const syncContractValue = (shouldFilter = false) => {
        if (!contractInput) return;
        const selectedValues = Array.from(selectedContractValues);
        contractInput.value = selectedValues.length
          ? (hasAllLoadedContractsSelected() ? 'All' : selectedValues.join(','))
          : '';
        updateContractLabel();
        if (shouldFilter) {
          contractobject.lineperformobject.linefilterchange(contractInput);
        }
      };

      const renderContractOptions = () => {
        if (!contractOptionsEl || !contractInput) return;
        const allActive = contractInput.value === 'All';
        const optionRows = [
          `<button type="button" class="consims-contract-option ${allActive ? 'is-selected' : ''}" data-consims-contract-option data-contract-all="true">
            <span class="consims-contract-option-label">All contracts</span>
            <span class="consims-contract-option-check"><span class="fas fa-check" aria-hidden="true"></span></span>
          </button>`,
          ...contractOptions.map(option => {
            const isSelected = selectedContractValues.has(`${option.value}`);
            return `<button type="button" class="consims-contract-option ${isSelected ? 'is-selected' : ''}" data-consims-contract-option data-contract-value="${escapeContractHtml(option.value)}">
              <span class="consims-contract-option-label">${escapeContractHtml(option.label)}</span>
              <span class="consims-contract-option-check"><span class="fas fa-check" aria-hidden="true"></span></span>
            </button>`;
          })
        ];
        contractOptionsEl.innerHTML = optionRows.join('');
      };

      const closeContractDropdown = () => {
        if (!contractMenu || !contractToggle) return;
        contractMenu.hidden = true;
        contractToggle.setAttribute('aria-expanded', 'false');
      };

      contractobject.lineperformobject.openContractDropdown = async function () {
        if (!contractMenu || !contractSearch || !contractToggle) return;
        if (!contractOptions.length) {
          contractOptions = await contractobject.lineperformobject.loadContractChoices('');
        }
        renderContractOptions();
        contractMenu.hidden = false;
        contractToggle.setAttribute('aria-expanded', 'true');
        contractSearch.focus();
      };

      let contractSearchTimer = null;
      contractSearch?.addEventListener('input', function () {
        window.clearTimeout(contractSearchTimer);
        contractSearchTimer = window.setTimeout(async () => {
          contractOptions = await contractobject.lineperformobject.loadContractChoices(contractSearch.value || '');
          renderContractOptions();
          if (contractMenu && contractMenu.hidden) {
            contractMenu.hidden = false;
            contractToggle?.setAttribute('aria-expanded', 'true');
          }
        }, 220);
      });

      contractSearch?.addEventListener('focus', () => {
        if (contractMenu?.hidden) {
          contractobject.lineperformobject.openContractDropdown();
        }
      });

      contractSearch?.addEventListener('keydown', event => {
        if (event.key === 'Escape') {
          closeContractDropdown();
          contractSearch.blur();
        }
      });

      contractToggle?.addEventListener('click', event => {
        event.preventDefault();
        if (contractMenu && !contractMenu.hidden) {
          closeContractDropdown();
          return;
        }
        contractobject.lineperformobject.openContractDropdown();
      });

      contractOptionsEl?.addEventListener('click', event => {
        const optionButton = event.target.closest('[data-consims-contract-option]');
        if (!optionButton) return;
        event.preventDefault();
        if (optionButton.dataset.contractAll === 'true') {
          if (contractInput?.value === 'All') {
            selectedContractValues.clear();
          } else {
            getLoadedContractValues().forEach(value => selectedContractValues.add(value));
          }
        } else {
          const value = optionButton.dataset.contractValue;
          if (selectedContractValues.has(value)) {
            selectedContractValues.delete(value);
          } else {
            selectedContractValues.add(value);
          }
        }
        syncContractValue(true);
        renderContractOptions();
      });

      document.addEventListener('click', event => {
        if (!contractPicker || contractPicker.contains(event.target)) return;
        closeContractDropdown();
      });

      contractobject.container.querySelectorAll('[data-consims-open-contract]').forEach(button => {
        button.addEventListener('click', event => {
          event.preventDefault();
          contractobject.lineperformobject.openContractDropdown();
        });
      });

      contractOptions = await contractobject.lineperformobject.loadContractChoices('');
      renderContractOptions();
      updateContractLabel();
      contractobject.lineperformobject.updateSubmissionShellState();

    });
  </script>

</div>
