<div id="contractlineperform-section" class="consims-submission-review is-contract-empty">
  <div class="consims-submission-page">
    <div class="consims-submission-category-row" aria-label="Submission contract categories">
      <button type="button" class="consims-submission-category active">Main contract <span>20</span></button>
      <button type="button" class="consims-submission-category">Sub contract <span>52</span></button>
      <button type="button" class="consims-submission-category">Supplier contract <span>21</span></button>
      <button type="button" class="consims-submission-category">Other contract <span>20</span></button>
    </div>

    <section class="consims-submission-filter-card" aria-label="Submission filters">
      <div id="contractlineperform-table-filter">
        <!-- Filter controls will be added here -->
      </div>
    </section>

    <section class="consims-submission-table-card" aria-label="Submission review table">
      <div class="table-responsive consims-submission-table-wrap">
        <table id="contractlineperform-submission-table" class="table table-sm fs-9 mb-0 consims-submission-table">
          <tbody class="list">
            <!-- Table datas will be added here -->
          </tbody>
        </table>
      </div>
      <div class="consims-submission-empty" data-consims-empty-state hidden>
        <div class="consims-submission-empty-illustration" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="92" height="92" viewBox="0 0 92 92" fill="none">
            <circle cx="46" cy="46" r="43" fill="#F4F7FC"/>
            <path d="M31 24.5H55.5L66 35V66.5C66 69.2614 63.7614 71.5 61 71.5H31C28.2386 71.5 26 69.2614 26 66.5V29.5C26 26.7386 28.2386 24.5 31 24.5Z" fill="#FFFFFF" stroke="#D6DEEC" stroke-width="2"/>
            <path d="M55 25V35.5H65.5" stroke="#D6DEEC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="45" cy="49" r="13" fill="#F9FBFE" stroke="#CBD6E8" stroke-width="2"/>
            <path d="M54.5 58.5L64 68" stroke="#CBD6E8" stroke-width="3" stroke-linecap="round"/>
            <path d="M35 39H49M35 31.5H50" stroke="#D6DEEC" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <button type="button" class="consims-submission-empty-link" data-consims-open-contract>Select a Contract</button>
        <span>Please select a contract from the filter above to view its submissions.</span>
      </div>
    </section>

    <div class="consims-submission-actions consims-submission-actions-bottom">
      <button type="button" onclick="contractobject.lineperformobject.tbl.quickapprove()" class="consims-submission-action consims-submission-action-muted" data-consims-quick-approval disabled>Quick Approval <span class="fas fa-check" aria-hidden="true"></span></button>
      <button type="button" onclick="contractobject.lineperformobject.tbl.savechanged()" class="consims-submission-action consims-submission-action-primary" data-consims-save-changed>Save changed <span class="far fa-save" aria-hidden="true"></span></button>
    </div>
  </div>

  <script>
    var contractobject = {};
    contractobject.model = JSON.parse('<%- JSON.stringify(model) %>');
    contractobject.container = document.getElementById("contractlineperform-section");//khu vá»±c chá»©a danh sÃ¡ch
    contractobject.urldata = {
      lists: '/contract/list',
      item: '/contract/item',
      // create: '/contract/create?viewname=contractlineperformupdate&callback=' + encodeURIComponent('contractobject.createcallback'),
      // edit: '/contract/edit?viewname=contractlineperformupdate&callback=' + encodeURIComponent('contractobject.editcallback'),
      // delete: '/contract/delete',
      // update: '/contract/edit'
      assignToUser: '/contractmember/create',
      assignToSubmission: '/contractlinemember/create',
      memberbycontract: '/contractmember/memberbycontract',
      management: '/contract/management'
    };

    //#region submission
    contractobject.lineperformobject = { model: {}, tbls: [] };
    contractobject.lineperformobject.urldata = {
      lists0: '/contractlineperform/listall',
      lists: '/contractlineperform/listall',
      // item: '/contractlineperform/item',
      // create: '/contractlineperform/create',
      // edit: '/contractlineperform/edit',
      // delete: '/contractlineperform/delete',
      // update: '/contractlineperform/edit',
      update: '/contractlineperform/editlineall',
      meta: '/contractlineperform/metaall',
      review: '/contractlineperform/review',
      files: '/common/files?viewname=contractlineperformfiles'
    };

    //chá»‰nh sá»­a table submission
    contractobject.lineperformobject.tbl = new senapp.utils.table({
      // datanew: datanew,
      // meta: this.model.meta,
      urldata: contractobject.lineperformobject.urldata,
      container: contractobject.container,
      tableelement: contractobject.container.querySelector('#contractlineperform-submission-table'),
      allowloaddataininit: false,
      selectcolumn: true, // cÃ³ hiá»ƒn thá»‹ cá»™t chá»n hay khÃ´ng
      filterrow: false, // cÃ³ hiá»ƒn thá»‹ filter row hay khÃ´ng
      addrow: false, // cho phÃ©p thÃªm má»›i
      editrow: true, // cho phÃ©p sá»­a
      deleterow: false, // cho phÃ©p xÃ³a
      addnewfirst: false, //thÃªm má»›i vÃ o Ä‘áº§u danh sÃ¡ch
      // loadmoreonvisible: true, // tá»± Ä‘á»™ng táº£i thÃªm dá»¯ liá»‡u khi cuá»™n Ä‘áº¿n cuá»‘i danh sÃ¡ch
      metacolumns: [
        { field: 'SysAction', visible: false, colorder: -9 },
        { field: 'Ext02', description: 'Review', colorder: -8, visible: true, show: true, gridwidth: 80, readonly: true },
        // { field: 'Ext01', description: '<i class="fa-solid fa-file" title="Files"></i>', colorder: -1, visible: false, show: true, gridwidth: 32 },

        // { field: 'Ext03', description: ' ', colorder: 800, visible: true, show: true, gridwidth: 132 },
      ],
      customcolumns: ['Ext01', 'Ext02', 'Ext03'], // Danh sÃ¡ch cÃ¡c cá»™t tÃ¹y chá»‰nh khi render cell
      allowloaddataininit: false,//khÃ´ng tá»± Ä‘á»™ng load data khi khá»Ÿi táº¡o
    });

    contractobject.lineperformobject.tbl.genCellDataCustom = function ({ data, metacolumn }) {
      if (!metacolumn || !metacolumn.field) {
        return null; // Tráº£ vá» null náº¿u khÃ´ng cÃ³ metacolumn hoáº·c field
      }
      // HÃ m nÃ y sáº½ Ä‘Æ°á»£c sá»­ dá»¥ng Ä‘á»ƒ táº¡o dá»¯ liá»‡u cho cÃ¡c cá»™t tÃ¹y chá»‰nh
      const tableobject = this;
      const td = document.createElement('td');
      td.setAttribute('data-field', metacolumn.field);
      //náº¿u field.visible lÃ  false hoáº·c field.show lÃ  false thÃ¬ khÃ´ng hiá»ƒn thá»‹ cá»™t nÃ y  gÃ¡n class d-none
      if (!metacolumn.show || !metacolumn.visible) { td.classList.add('d-none'); }
      switch (metacolumn.field) {
        case 'Ext03':
          //táº¡o link quick approval
          const alink = document.createElement('a');
          //táº¡o sá»± kiá»‡n onclick gá»i hÃ m accept cá»§a contractobject.lineperformobject
          //thÃªm class
          alink.className = 'btn btn-subtle-secondary btn-sm';
          alink.href = 'javascript:;';
          alink.title = 'Quick approval';
          alink.textContent = 'Quick approval';
          alink.onclick = function () {
            console.log('Quick approval clicked for Submission ID:', data['SubmissionId']);

            data['ReviewedWorkCat'] = data['SubmittedWorkCat'];

            data['ReviewedQnty'] = data['SubmittedQnty'];
            data['ReviewedUnitPrice'] = data['SubmittedUnitPrice'];
            data['ReviewedAmount'] = data['SubmittedAmount'];
            data['RemarksOnApproval'] = data['SubmittedRemarks'];
            data.SysDataStatus = 'Update';
            tableobject.updateRowData({ data });


            //contractobject.lineperformobject.accept(this);
          };
          td.appendChild(alink);
          // td.innerHTML = `<a href="javascript:;" onclick="contractobject.lineperformobject.accept(this)" title="Quick approval">Quick approval</a>`;
          break;
        // case 'Ext01':
        //   td.innerHTML = `<a href="javascript:;" onclick="contractlineperformreviewobject.lineobject.accept(this)" title="Accept">Accept</a>`;
        //   break;
        case 'Ext02':
          td.innerHTML = `<a class="text-muted" href="javascript:;" onclick="contractobject.lineperformobject.loadreviewall(this)" title="Review"><i class="fa fa-list"></i></a>`;
          if (contractobject.filterworktype == "payment_order") {
            const ipcPrintLink = `<a class="ms-1" data-paymentid="${data.SubmissionId}" href="javascript:;" onclick="contractobject.ipcobject.print({ el: this })" title="Print IPC"><i class="fas fa-print text-muted"></i></a>`;
            td.innerHTML += ` ${ipcPrintLink}`;
          }

          // if (data.IsAssigned == 'No') {
          //   td.innerHTML = `<a class="text-muted me-2" href="javascript:;" onclick="contractobject.lineperformobject.lineeditperformall(this)" title="Edit Submission"><i class="fa fa-edit"></i></a>`;
          // }
          // else {
          //   td.innerHTML = `<a class="text-muted" href="javascript:;" onclick="contractobject.lineperformobject.loadreviewall(this)" title="Review"><i class="fa fa-list"></i></a>`;
          // }
          break;
        default:
          //náº¿u khÃ´ng pháº£i lÃ  cá»™t tÃ¹y chá»‰nh thÃ¬ tráº£ vá» giÃ¡ trá»‹ cá»§a trÆ°á»ng Ä‘Ã³
          td.innerHTML = data[metacolumn.field] || '';
          break;
      }
      return td;
    }

    //táº¡m khÃ³a khÃ´ng cáº§n lÆ°u khi thay Ä‘á»•i dÃ²ng
    contractobject.lineperformobject.tbl.synData = async function ({ data, type, mode } = {}) {
      data.SysDataStatus = 'Update';
      return { status: 1, message: '', data: {}, errors: {} };
    };
    //hÃ m map quyá»n editable cho cell dÃ¹ng cho override
    contractobject.lineperformobject.tbl.mapCellEditableExt = function ({ td, data, metacolumn }) {
      return data.ApprovalStatus !== 'Approved' || data.SysDataStatus === 'Update';
    }
    //hÃ m genCellData Ä‘á»ƒ táº¡o dá»¯ liá»‡u cho báº£ng
    contractobject.lineperformobject.tbl.genCellData = function ({ data, metacolumn }) {
      //náº¿u metacolumn.field chá»©a trong customcolumns thÃ¬ gá»i hÃ m genCellDataCustom
      if (this.customcolumns && this.customcolumns.includes(metacolumn.field)) {
        return this.genCellDataCustom({ data, metacolumn });
      }

      //náº¿u metacolumn.field lÃ  'SysNo' thÃ¬ ná»™i dung báº±ng sá»‘ dÃ²ng trong tbody tr trong báº£ng
      if (metacolumn.field === 'SysNo') {
        return this.genCellDataNo({ data: data, metacolumn: metacolumn });
      }

      //náº¿u metacolumn.field lÃ  'SysSelect' thÃ¬ tráº£ vá» tdselect
      if (metacolumn.field === 'SysSelect') {
        return this.genCellDataSelect({ data: data, metacolumn: metacolumn });
      }

      //náº¿u metacolumn.field lÃ  'SysAction' thÃ¬ tráº£ vá» tdaction
      if (metacolumn.field === 'SysAction') {
        return this.genCellDataAction({ data: data, metacolumn: metacolumn });
      }
      if (metacolumn.visible === false) { return null; }
      const td = document.createElement('td');
      td.setAttribute('data-field', metacolumn.field);
      //set tabindex
      td.setAttribute('tabindex', '0');
      //náº¿u field.show lÃ  false thÃ¬ khÃ´ng hiá»ƒn thá»‹ cá»™t nÃ y  gÃ¡n class d-none
      if (!metacolumn.show) { td.classList.add('d-none'); }

      //náº¿u trÆ°á»ng cÃ³ tá»“n táº¡i data thÃ¬ map giÃ¡ trá»‹ vá»›i data
      if (metacolumn.data) {
        const mappedValue = metacolumn.data.find(item => item.id === data[metacolumn.field]);
        td.textContent = mappedValue ? mappedValue.label : '';
        //gÃ¡n quyá»n chá»‰nh sá»­a cho cell
        this.mapCellEditable({ td: td, data: data, metacolumn: metacolumn });
        return td;
      }

      //náº¿u cÃ³ inputtype== 'checkbox'
      if (metacolumn.inputtype && metacolumn.inputtype === 'checkbox' && (metacolumn.type === 'bool' || metacolumn.type === 'boolean')) {
        // check cá»§a fontawesome  náº¿u data[metacolumn.field] lÃ  true thÃ¬ checked náº¿u false thÃ¬ unchecked
        // td.innerHTML = `<div class="form-check"> <input style="opacity:1;" class="form-check-input" type="checkbox" disabled ${data[metacolumn.field] ? 'checked' : ''}></div>`;
        // td.innerHTML = `<div class="form-check form-switch"> <input class="form-check-input" type="checkbox" disabled ${data[metacolumn.field] ? 'checked' : ''}></div>`;
        // td.innerHTML = `<i class="fa-regular ${data[metacolumn.field] ? 'fa-square-check' : 'fa-square'}"></i>`;

        const checkbox = document.createElement('input');
        checkbox.type = 'checkbox';
        checkbox.className = 'form-check-input';
        checkbox.classList.add('cell-editor');
        checkbox.value = data[metacolumn.field];
        checkbox.style.opacity = '1';
        //náº¿u data[metacolumn.field]==true thÃ¬ checkbox chá»n
        if (data[metacolumn.field] == true) { checkbox.checked = true; }
        //khi thay Ä‘á»•i thÃ¬ gá»i hÃ m updateData cá»§a  tableobject
        checkbox.onchange = function () {
          data[metacolumn.field] = this.checked;
          // phÃ¡t sá»± kiá»‡n náº¿u thay Ä‘á»•i
          td.dispatchEvent(new CustomEvent("cellchange", {
            bubbles: true,
            detail: { oldValue: !data[metacolumn.field], newValue: this.checked, cell: td }
          }));
          //tableobject.updateByKey(data[tableobject.keyfield]);
        };
        td.appendChild(checkbox);
        //gÃ¡n quyá»n chá»‰nh sá»­a cho cell
        this.mapCellEditable({ td: td, data: data, metacolumn: metacolumn });
        return td;
      }

      td.innerHTML = senapp.data.stringifyValue(data[metacolumn.field], metacolumn);
      //gÃ¡n quyá»n chá»‰nh sá»­a cho cell
      this.mapCellEditable({ td: td, data: data, metacolumn: metacolumn });
      return td;
    };

    contractobject.lineperformobject.tbl.genRowDataExtClass = function ({ tr, data }) {
      //náº¿u data.ApprovalStatus == 'Accepted' thÃ¬ gÃ¡n class row-accepted
      if (data.ApprovalStatus === 'Approved' && data.SysDataStatus !== 'Update') {
        tr.classList.add('bg-light');
      }
    }



    //hÃ m genRowData Ä‘á»ƒ táº¡o dá»¯ liá»‡u cho báº£ng
    contractobject.lineperformobject.tbl.genRowData = function ({ data }) {
      const tableobject = this;
      const tr = document.createElement('tr');
      //gÃ¡n giÃ¡ trá»‹ keyfield vÃ o thuá»™c tÃ­nh data-id cá»§a tr
      tr.setAttribute('data-id', data[tableobject.keyfield]);
      tr.className = 'row-data';

      this.metacolumns.forEach(column => {
        const td = tableobject.genCellData({ data: data, metacolumn: column });
        // Báº¯t event trá»±c tiáº¿p á»Ÿ chÃ­nh cell
        if (td) {
          td.addEventListener("cellchange", async (e) => {
            // //console.log("Old:", e.detail.oldValue, "New:", e.detail.newValue);
            if (e.detail.oldValue === e.detail.newValue) return;
            //náº¿u giÃ¡ trá»‹ cÅ© khÃ¡c giÃ¡ trá»‹ má»›i thÃ¬ má»›i thÃ¬ Ä‘Ã¡nh dáº¥u dÃ²ng thay Ä‘á»•i
            tr.classList.add('edited');
            await tableobject.onChangeCell({ td: td, data: data });
          });
          //gÃ¡n class kiá»ƒu dá»¯ liá»‡u
          td.classList.add('type-' + (column.type || 'string').toLowerCase());
          tr.appendChild(td);
        }

      });

      tr.addEventListener("focusin", () => {
        // tr.classList.add("table-active");
        // //console.log("focus in row", tr.rowIndex);
      });

      tr.addEventListener("focusout", async (e) => {
        // e.relatedTarget = pháº§n tá»­ chuáº©n bá»‹ Ä‘Æ°á»£c focus tiáº¿p theo
        // náº¿u pháº§n tá»­ Ä‘Ã³ váº«n náº±m trong cÃ¹ng tr thÃ¬ KHÃ”NG xoÃ¡ active
        if (!tr.contains(e.relatedTarget)) {
          // tr.classList.remove("table-active");
          await tableobject.onChangeRow({ tr: tr, data: data });
        }
      });

      this.genRowDataExtClass({ tr: tr, data: data });

      return tr;
    }

    //hÃ m táº¡o lookupparam Ä‘á»ƒ gá»­i lÃªn server
    contractobject.lineperformobject.tbl.lookupparam = function ({ lookup, data }) {
      //console.log('lookupparam:', lookup, data);
      return `lookupType=contractlineperformreviewstatusupdate&role=${data.Role}&pagesize=${lookup.pagesize || 0}&filter=${encodeURIComponent(JSON.stringify(lookup.filter))}`;
    }

    contractobject.lineperformobject.tbl.updateparaext = function (data) {
      //dÃ¹ng cho override
      const paraext = `?itemworktype=${encodeURIComponent(data.WorkType || '')}`
      return ``;
    }

    //hÃ m lÆ°u dá»¯ liá»‡u Ä‘Ã£ chá»‰nh sá»­a
    contractobject.lineperformobject.tbl.savechanged = async function () {
      //confirm trÆ°á»›c khi lÆ°u
      if (senapp.window.confirm({ message: `${await senapp.utils.text.t('Are you sure you want to save changes?')}` }) === false) {
        return;
      }

      const tableobject = this;
      // const changedRows = contractlineperformreviewobject.lineobject.tblline.datas.filter(row => row.SysDataStatus === 'Update' || row.SysDataStatus === 'Create' || row.SysDataStatus === 'Delete');
      const changedRows = tableobject.datas.filter(row => row.SysDataStatus === 'Update');
      senapp.window.loading.show();
      const promises = changedRows.map(row =>
        tableobject.updateByKey(row[tableobject.keyfield])
          //cáº­p nháº­t tráº¡ng thÃ¡i vá» null sau khi lÆ°u
          .then(() => { row.SysDataStatus = null; })
      );
      try {
        await Promise.all(promises);
        senapp.window.loading.hide();
        console.log("Táº¥t cáº£ Ä‘Ã£ lÆ°u xong!");

      } catch (err) {
        senapp.window.alert({ message: `âš ï¸ ${await senapp.utils.text.t('CÃ³ lá»—i khi lÆ°u:')}`, type: 'danger' });
        console.error("CÃ³ lá»—i khi lÆ°u:", err);
      }
    };

    contractobject.lineperformobject.tbl.quickapprove = async function () {
      const tableobject = this;
      //láº¥y dÃ²ng Ä‘Æ°á»£c chá»n
      const unapprovedRows = tableobject.getDataSelected();
      const promises = unapprovedRows.map(data => {
        if (data.ApprovalStatus !== 'Approved') {
          data['ReviewedWorkCat'] = data['SubmittedWorkCat'];

          data['ReviewedQnty'] = data['SubmittedQnty'];
          data['ReviewedUnitPrice'] = data['SubmittedUnitPrice'];
          data['ReviewedAmount'] = data['SubmittedAmount'];
          data['RemarksOnApproval'] = data['SubmittedRemarks'];

          const itemlabel = contractobject.itemstatus.find(item => item.id === 'Approved')?.label || 'Approved' || '';
          data['ApprovalStatus'] = itemlabel;


          data.SysDataStatus = 'Update';
          tableobject.updateRowData({ data });
        }
      });

    };

    //danh sÃ¡ch role raci
    contractobject.lineperformobject.roles = async function () {
      const url = `/common/lookup?lookupType=raci_list`;
      const response = await fetch(url, { method: 'GET', });
      const resjson = await response.json();
      if (resjson.datas) {
        //map trÆ°á»ng trÆ°á»›c khi return
        const mappedData = resjson.datas.map(item => ({
          id: item.Role,
          value: item.Role,
          label: item.RoleName
        }));
        return mappedData;
      }
      return [];
    };

    //danh sÃ¡ch status
    contractobject.lineperformobject.statuses = async function () {
      const url = `/common/lookup?lookupType=contractlineperformreviewstatus`;
      const response = await fetch(url, { method: 'GET', });
      const resjson = await response.json();
      if (resjson.datas) {
        //map trÆ°á»ng trÆ°á»›c khi return
        const mappedData = resjson.datas.map(item => ({
          id: item.Description,
          value: item.Description,
          label: item.Description
        }));
        return mappedData;
      }
      return [];
    };

    //danh sÃ¡ch worktype
    contractobject.lineperformobject.getWorkType = async function () {
      const url = `/common/lookup?lookupType=workcategory`;
      const response = await fetch(url, { method: 'GET', });
      const resjson = await response.json();
      if (resjson.datas) {
        //map trÆ°á»ng trÆ°á»›c khi return
        const mappedData = resjson.datas.map(item => ({
          id: item.Alias,
          value: item.Alias,
          label: item.Alias
        }));
        return mappedData;
      }
      return [];
    };

    contractobject.lineperformobject.loadreviewall = function (element) {
      const tableobject = contractobject.lineperformobject.tbl;
      const id = parseInt(element.closest('tr').getAttribute('data-id'));
      const data = tableobject.datas.find(item => item[tableobject.keyfield] === id);
      // const url = `${this.urldata.review}?submissionid=${data.SubmissionId}&itemworktype=${encodeURIComponent(data.WorkType || '')}`;

      const itemworktype = data.WorkType || '';
      let url = `${this.urldata.review}?submissionid=${data.SubmissionId}&worktype=${encodeURIComponent(itemworktype)}&itemworktype=${encodeURIComponent(itemworktype)}`;
      if (['add', 'deduction'].includes(itemworktype)) {
        url += `&viewname=contractlineperformreview4deduction`;
      }


      senapp.window.modal({
        title: `Review of ${data["SubmissionName"] || ''}`,
        url: url,
        size: 'xl'
      });
    };

    //end chá»‰nh sá»­a table submission


    contractobject.lineperformobject.linecreatePerformcallback = function (response) {
      //náº¿u response[0] tá»“n táº¡i thÃ¬ hiá»ƒn thá»‹ thÃ´ng bÃ¡o lá»—i
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        const data = response[0].data;
        const tableobject = this.tbls[data.ItemId];
        if (tableobject) {
          tableobject.refreshDataDisplay();
        }

        const NSubmission = contractobject.lineperformobject.elementcurrent.closest('tr').querySelector('a[title="View Submission"] span').getAttribute('data-nsubmission') || '0';
        const nsubmissionnew = parseInt(NSubmission) + 1;
        contractobject.lineperformobject.elementcurrent.closest('tr').querySelector('a[title="View Submission"] span').setAttribute('data-nsubmission', nsubmissionnew);
        contractobject.lineperformobject.elementcurrent.closest('tr').querySelector('a[title="View Submission"] span').innerText = `(${nsubmissionnew || 0})`;

        console.log('Created Perform:', response[0]);
        // senobjectobject.tbl.onAddRowData({ data: response[0].data });
      }
    };
    contractobject.lineperformobject.elementcurrent = null;
    contractobject.lineperformobject.linecreatePerform = function (element) {
      contractobject.lineperformobject.elementcurrent = element;
      const worktype = element.getAttribute('data-itemworktype') || '';
      const id = parseInt(element.closest('tr').getAttribute('data-id'));
      // const parentid = parseInt(contractobject.contractid);//dÃ¹ng cho contractmanagement
      const parentid = element.closest('.extline-container').getAttribute('data-id');
      const tableobject = contractobject.lineobject.tbls[parentid];
      const data = tableobject.datas.find(item => item[tableobject.keyfield] === id);

      // console.log('Create Perform for Contract Line ID:', id, 'Parent Contract ID:', parentid);
