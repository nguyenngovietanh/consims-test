<div id="workcategory-section">
  <div class="mb-9">
    <h2 class="mb-4"><%- title %></h2>
    <div id="workcategory-filter" class="mb-3">
      <!-- Filter form will be rendered here -->
    </div>
    <div class="mb-1">
      <div class="">
        <a onclick="workcategoryobject.tbl.create()" class="btn btn-subtle-primary">Create New</a>
        <a onclick="workcategoryobject.tbl.deleteBySelected()" class="btn btn-subtle-secondary">Delete Selected</a>
      </div>
    </div>

    <div class="row-fluid">
      <div class="card">
        <div class="card-body">
          <div class="search-box mb-3 mx-auto">
            <div class="position-relative">
              <input class="form-control search-input search form-control-sm" type="search" placeholder="Search"
                aria-label="Search" />
              <span class="fas fa-search search-box-icon"></span>
            </div>
          </div>
          <div class="table-responsive">
            <table class="table table-sm fs-9 mb-5">
              <tbody class="list">
                <!-- Table datas will be added here -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    var workcategoryobject = {};
    workcategoryobject.model = JSON.parse('<%- JSON.stringify(model) %>');
    workcategoryobject.container = document.getElementById("workcategory-section");//khu vực chứa danh sách
    workcategoryobject.urldata = {
      lists: '/workcategory/list',
      item: '/workcategory/item',
      create: '/workcategory/create?callback=' + encodeURIComponent('workcategoryobject.createcallback'),
      edit: '/workcategory/edit?callback=' + encodeURIComponent('workcategoryobject.editcallback'),
      delete: '/workcategory/delete'
    };
    workcategoryobject.createcallback = function (response) {
      //nếu response[0] tồn tại thì hiển thị thông báo lỗi
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        //workcategoryobject.tbl.onAddRowData({ data: response[0].data.data });
        senapp.sidebar.menuclickbydatalink('/workcategory');
      }
    };

    workcategoryobject.editcallback = function (response) {
      //nếu response[0] tồn tại thì hiển thị thông báo lỗi
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        //workcategoryobject.tbl.onChangeRowData({ data: response[0].data.data });
        senapp.sidebar.menuclickbydatalink('/workcategory');
      }
    };

    // Khởi tạo bảng
    workcategoryobject.tbl = new senapp.utils.table({
      meta: workcategoryobject.model.meta,
      urldata: workcategoryobject.urldata,
      container: workcategoryobject.container,
      tableelement: workcategoryobject.container.querySelector('table'),
      modal: true,
      selectcolumn:true,
      filterrow: false, // không hiển thị filter row
      //filtercompact: false // hiển thị filter row ở dạng compact
    });

    $(function () { workcategoryobject.tbl.initTable(); });

  </script>

</div>