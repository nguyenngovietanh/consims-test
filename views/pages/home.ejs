<script>
  (function () {
    const root = document.getElementById("dashboard-overview");
    if (!root) return;

    const financeRows = [
      "Original Contract Value",
      "Approved Variations",
      "Pending Variations",
      "Revised Contract Value",
      "Revenue Recognized (To date)",
      "Cost Incurred (To date)",
      "Forecast Final Cost (EAC)",
      "Forecast Profit",
      "Tender Margin",
      "Forecast Profit"
    ];
    const months = ["2/2026", "3/2026", "4/2026", "5/2026", "6/2026", "7/2026"];

    function fillTable(selector, rows) {
      const body = root.querySelector(selector);
      if (body) body.innerHTML = rows.join("");
    }

    fillTable('[data-dashboard-table="finance"]', financeRows.map(function (label) {
      return '<tr><td>' + label + '</td><td class="text-end">$52.600.000</td><td class="text-end">100%</td></tr>';
    }));

    fillTable('[data-dashboard-table="progress"]', financeRows.map(function (label) {
      return '<tr><td>' + label + '</td><td class="text-end">100%</td></tr>';
    }));

    const personnelRows = [
      ["9/2025", 100, 95, "2%"],
      ["10/2025", 150, 140, "5%"],
      ["11/2025", 200, 210, "12%"],
      ["12/2025", 250, 245, "20%"],
      ["1/2026", 270, 230, "25%"],
      ["2/2026", 280, 260, "32%"],
      ["3/2026", 300, 290, "45%"],
      ["4/2026", 320, 310, "55%"]
    ];
    fillTable('[data-dashboard-table="personnel"]', personnelRows.map(function (row) {
      return '<tr><td>' + row[0] + '</td><td class="text-end">' + row[1] + '</td><td class="text-end">' + row[2] + '</td><td class="text-end">' + row[3] + '</td></tr>';
    }));

    const materialRows = [
      ["9/2025", 2.5, 2.4, "0.5%"],
      ["10/2025", 4.2, 3.9, "1.5%"],
      ["11/2025", 8.1, 7.8, "1.2%"],
      ["12/2025", 12.5, 11.8, "3.5%"],
      ["1/2026", 9.0, 8.5, "2.8%"],
      ["2/2026", 7.5, 7.0, "3.2%"],
      ["3/2026", 15.2, 14.5, "4.5%"],
      ["4/2026", 10.4, 13.0, "2.5%"]
    ];
    fillTable('[data-dashboard-table="materials"]', materialRows.map(function (row) {
      return '<tr><td>' + row[0] + '</td><td class="text-end">' + row[1] + '</td><td class="text-end">' + row[2] + '</td><td class="text-end">' + row[3] + '</td></tr>';
    }));

    if (!window.echarts) return;

    const palette = {
      navy: "#1e2b58",
      blue: "#7b8cff",
      green: "#6ed49a",
      orange: "#ffae52",
      cyan: "#27c9d7",
      yellow: "#ffd75e",
      grid: "#d7dce8",
      text: "#454b5f"
    };

    const chartInstances = [];
    function chart(name, option) {
      const el = root.querySelector('[data-dashboard-chart="' + name + '"]');
      if (!el) return;
      const instance = echarts.init(el);
      instance.setOption(option);
      chartInstances.push(instance);
    }

    function baseGrid() {
      return { left: 42, right: 18, top: 28, bottom: 42 };
    }

    function lineOption(series) {
      return {
        color: [palette.blue, palette.green, palette.orange],
        tooltip: { trigger: "axis" },
        legend: { bottom: 0, itemWidth: 10, itemHeight: 10, textStyle: { color: palette.text, fontSize: 11 } },
        grid: baseGrid(),
        xAxis: { type: "category", data: months, axisTick: { show: false }, axisLine: { lineStyle: { color: "#aeb6c8" } } },
        yAxis: { type: "value", min: 0, max: 100, splitLine: { lineStyle: { color: palette.grid, type: "dashed" } } },
        series: series.map(function (item) {
          return {
            name: item.name,
            type: "line",
            smooth: true,
            symbolSize: 9,
            lineStyle: { width: 2 },
            data: item.data
          };
        })
      };
    }

    function donutOption(data, colors) {
      return {
        color: colors,
        tooltip: { trigger: "item" },
        legend: { right: 16, top: "middle", orient: "vertical", itemWidth: 9, itemHeight: 9, textStyle: { fontSize: 11 } },
        series: [{
          type: "pie",
          radius: ["44%", "72%"],
          center: ["38%", "50%"],
          avoidLabelOverlap: true,
          label: { show: false },
          data: data
        }]
      };
    }

    function horizontalBarOption(categories, values) {
      return {
        color: [palette.blue],
        tooltip: { trigger: "axis" },
        grid: { left: 88, right: 24, top: 12, bottom: 28 },
        xAxis: { type: "value", min: 0, max: 1, splitLine: { lineStyle: { color: palette.grid, type: "dashed" } } },
        yAxis: { type: "category", data: categories, axisTick: { show: false }, axisLine: { show: false } },
        series: [{ type: "bar", data: values, barWidth: 18, label: { show: true, position: "insideRight", color: "#fff" } }]
      };
    }

    chart("revenue-cost", lineOption([
      { name: "Revenue", data: [10, 10, 14, 34, 19, 14] },
      { name: "Cost", data: [25, 39, 41, 54, 62, 43] },
      { name: "Forecast EAC", data: [44, 62, 69, 83, 84, 75] }
    ]));

    chart("planned-actual", lineOption([
      { name: "Planned", data: [39, 54, 63, 66, 76, 78] },
      { name: "Actual", data: [15, 28, 33, 42, 54, 61] },
      { name: "Forecast", data: [14, 28, 33, 42, 54, 61] }
    ]));

    chart("milestone", donutOption([
      { value: 46, name: "Completed" },
      { value: 82, name: "On track" },
      { value: 10, name: "Overdue" }
    ], [palette.green, "#1296ed", palette.orange]));

    chart("variation-aging", horizontalBarOption(["0-30 days", "31-60 days", "61-90 days", "> 90 days"], [0.40, 0.71, 0.63, 0.51]));
    chart("variation-cause", donutOption([
      { value: 32, name: "Design Changes" },
      { value: 26, name: "Client Requests" },
      { value: 18, name: "Site Conditions" },
      { value: 14, name: "Regulatory" },
      { value: 10, name: "Others" }
    ], [palette.blue, palette.green, palette.orange, palette.cyan, palette.yellow]));

    chart("claims-aging", horizontalBarOption(["0-30 days", "31-60 days", "61-90 days", "> 90 days"], [0.57, 0.82, 0.70, 0.60]));
    chart("claims-type", donutOption([
      { value: 30, name: "EOT" },
      { value: 28, name: "Cost" },
      { value: 32, name: "Disruption" },
      { value: 10, name: "Others" }
    ], [palette.blue, palette.green, palette.cyan, palette.yellow]));

    chart("receivables-aging", donutOption([
      { value: 4.2, name: "0-20 days" },
      { value: 3.1, name: "31-60 days" },
      { value: 2.05, name: "61-90 days" },
      { value: 2.1, name: "> 90 days" }
    ], [palette.blue, palette.green, palette.cyan, palette.orange]));

    chart("billing-collection", {
      color: [palette.blue, palette.green, palette.orange],
      tooltip: { trigger: "axis" },
      legend: { bottom: 0, itemWidth: 10, itemHeight: 10 },
      grid: baseGrid(),
      xAxis: { type: "category", data: ["11/2025", "12/2025", "1/2026", "2/2026", "3/2026", "4/2026"] },
      yAxis: [{ type: "value", min: 0, max: 100 }, { type: "value", min: 0, max: 100 }],
      series: [
        { name: "Billed", type: "bar", data: [55, 65, 80, 84, 70, 35], barWidth: 18 },
        { name: "Collected", type: "bar", data: [40, 80, 38, 45, 66, 26], barWidth: 18 },
        { name: "Collection %", type: "line", yAxisIndex: 1, smooth: true, data: [45, 47, 59, 73, 92, 70] }
      ]
    });

    function comboChart(name, bar1, bar2, line) {
      chart(name, {
        color: [palette.blue, palette.green, "#2454ff"],
        tooltip: { trigger: "axis" },
        legend: { bottom: 0, itemWidth: 10, itemHeight: 10 },
        grid: baseGrid(),
        xAxis: { type: "category", data: personnelRows.map(function (row) { return row[0]; }) },
        yAxis: [{ type: "value" }, { type: "value", min: 0, max: 75, axisLabel: { formatter: "{value}%" } }],
        series: [
          { name: "Planned", type: "bar", data: bar1, barWidth: 18 },
          { name: "Actual", type: "bar", data: bar2, barWidth: 18 },
          { name: "Progress", type: "line", yAxisIndex: 1, smooth: true, data: line }
        ]
      });
    }

    comboChart("personnel", [100, 150, 200, 250, 270, 280, 300, 320], [95, 140, 210, 245, 230, 260, 290, 310], [2, 5, 12, 20, 25, 32, 45, 55]);
