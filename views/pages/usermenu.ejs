<div class="mb-9">
  <h2 class="mb-4">Menu permissions</h2>
  <div class="mb-0">
    <div class="row">
      <div class="col-12">
        <a class="btn btn-primary mb-1" href="javascript:;" onclick="usermenu.applymenu(this)">Apply</a>
      </div>
      <div class="col-12">
        <div class="mb-0">
          <select class="form-select" id="organizerMultiple2" data-choices="data-choices" multiple="multiple" size="1" required="required" data-options='{"removeItemButton":true,"placeholder":true}'>
          </select>
          <div class="invalid-feedback">Please select one or multiple</div>
        </div>
      </div>
    </div>
  </div>
  <div class="row-fluid">
    <nav class="navbar navbar-vertical navbar-expand-lg px-3"
      style="position: inherit;    border: 0px;    width: 100%;height: auto;">
      <div class="collapse navbar-collapse" id="navbarVerticalCollapse-menu">
        <!-- scrollbar removed-->
        <div class="navbar-vertical-content" style="height: auto;">
          <ul class="navbar-nav flex-column" id="navbarVerticalNav-menu">
            <li class="nav-item mb-2">
              <div class="d-flex align-items-center">
                <input class="form-check-input me-2" id="flexCheckCheckedall" type="checkbox" value="">
              </div>
            </li>
          </ul>
        </div>
      </div>
    </nav>
  </div>
</div>


<script>

  var usermenu = {};
  usermenu.model = JSON.parse('<%- JSON.stringify(model) %>');
  senapp.menu.forEach(function (item, i) {
    const navItemMenu = `<li class="nav-item mb-2">
        <div class="d-flex align-items-center">
          <input class="form-check-input me-2" id="flexCheckChecked${i}" type="checkbox" value="">
          <label class="form-check-label" for="flexCheckChecked${i}"><span class="me-1"><span data-feather="${item.icon}"></span></span><span class="nav-link-text">${item.menuname}</span></label>
        </div>
      </li>`

    $("#navbarVerticalNav-menu").append(navItemMenu);
  });
  $("#flexCheckCheckedall").on("change", function () {
    const checked = this.checked;
    $("#navbarVerticalNav-menu input[type='checkbox']").prop("checked", checked);
  });

  usermenu.elements = document.querySelectorAll('[data-choices]');
  // usermenu.elements.forEach(function (el) { new Choices(el); });

    usermenu.users= [
    { username: "alice.nguyen@example.com", password: "123", name: "Alice Nguyễn", department: "Kế toán" },
