        { field: 'R', description: 'Responsible', colorder: 100, visible: true, show: true },
        { field: 'A', description: 'Accountable', colorder: 103, visible: true, show: true },
        { field: 'C', description: 'Consulted', colorder: 104, visible: true, show: true },
        { field: 'I', description: 'Informed', colorder: 105, visible: true, show: true },

      ],
      customcolumns: ['R', 'A', 'C', 'I'],

    });

    contractlinememberbycontractlineobject.tbl.deleteparaext = function (data) {
      //dùng cho override
      return `?Account=${encodeURIComponent(data.Account)}&Role=${encodeURIComponent(data.RoleAction)}&ItemId=${encodeURIComponent(contractlinememberbycontractlineobject.model.url.query.id)}&ContractId=${encodeURIComponent(contractlinememberbycontractlineobject.model.url.query.parentid)}`;
    }

    contractlinememberbycontractlineobject.inherit = async function () {
      //gọi api để kế thừa từ hợp đồng cha
      const contractId = contractlinememberbycontractlineobject.model.url.query.parentid;
      const itemId = contractlinememberbycontractlineobject.model.url.query.id;
      const url = `${contractlinememberbycontractlineobject.urldata.inherit}?ContractId=${encodeURIComponent(contractId)}&ItemId=${encodeURIComponent(itemId)}`;
      try {
        // Tạo mảng Promise bất đồng bộ
        const promises = contractlinememberbycontractlineobject.tbl.datas.flatMap(async memberraci => {
          const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(memberraci)
          });
          if (!res.ok) { throw new Error(`HTTP error! status: ${res.status}`); }
          const response = await res.json(); // hoặc .text() nếu API không trả JSON
          if (response.status == 0) {
            senapp.window.toast({ message: response.message, type: 'danger' });
          } else {
            senapp.window.toast({ message: response.message, type: 'success' });
          }
        });
        await Promise.all(promises);
        senapp.window.loading.hide();
        console.log("Tất cả đã xong!");
      } catch (err) {
        senapp.window.loading.hide();
        senapp.window.alert({ message: `⚠️ ${await senapp.utils.text.t('An error occurred while processing:')}`, type: 'danger' });
        console.error("Có lỗi :", err);
      }

    };

    contractlinememberbycontractlineobject.tbl.saveChange = async function () {
      const tableobject = this;
      if (senapp.window.confirm({ message: `⚠️ ${await senapp.utils.text.t('Are you sure you want to save changes?')}` })) {
        senapp.window.loading.show();
        const changedRows = tableobject.datas.filter(row => row.SysDataStatus === 'Update' || row.SysDataStatus === 'Create' || row.SysDataStatus === 'Delete');

        const promises = changedRows.map(row =>
          tableobject.updateByKey(row[tableobject.keyfield])
          //cập nhật trạng thái về null sau khi lưu
            .then(() => { row.SysDataStatus = null; })
        );
        try {
          await Promise.all(promises);
          senapp.window.loading.hide();
          console.log("Tất cả đã lưu xong!");
        } catch (err) {
          senapp.window.alert({ message: `⚠️ ${await senapp.utils.text.t('Có lỗi khi lưu:')}`, type: 'danger' });
          console.error("Có lỗi khi lưu:", err);
        }
      }
    
    };

    // //mở rộng
    // contractlinememberbycontractlineobject.tbl.updateparaext = function (data) {
    //   //dùng cho override
    //   return `?RoleId=${encodeURIComponent(contractlinememberbycontractlineobject.model.url.query.id)}`;
    // }

    contractlinememberbycontractlineobject.tbl.genCellDataCustom = function ({ data, metacolumn }) {
      if (!metacolumn || !metacolumn.field) {
        return null; // Trả về null nếu không có metacolumn hoặc field
      }
      // Hàm này sẽ được sử dụng để tạo dữ liệu cho các cột tùy chỉnh
      const tableobject = this;
      const td = document.createElement('td');
      td.setAttribute('data-field', metacolumn.field);
      //nếu field.visible là false hoặc field.show là false thì không hiển thị cột này  gán class d-none
      if (!metacolumn.show) { td.classList.add('d-none'); }
      // ['R', 'A', 'C', 'I']
      switch (metacolumn.field) {
        case "R":
        case "A":
        case "C":
        case "I":
          const checkbox = document.createElement('input');
          checkbox.type = 'checkbox';
          checkbox.className = 'form-check-input';
          checkbox.value = data[metacolumn.field] === "True";
          //nếu data[metacolumn.field]==true thì checkbox chọn
          if (data[metacolumn.field] === "True") { checkbox.checked = true; }
          //khi thay đổi thì gọi hàm updateData của  tableobject
          checkbox.onchange = function () {
            data[metacolumn.field] = this.checked ? "True" : "False";
            data['SysDataStatus'] = 'Update';
            // tableobject.updateByKey(data[tableobject.keyfield]);
          };
          td.appendChild(checkbox);
          break;
        default:
          //nếu không phải là cột tùy chỉnh thì trả về giá trị của trường đó
          td.innerHTML = data[metacolumn.field] || '';
          break;
      }

      return td;
    }

    contractlinememberbycontractlineobject.lineassignToUsercallback = async function (response) {
      if (response && response.length > 0) {
        // Process the selected roles
        console.log('Selected members:', response);
        senapp.window.loading.show();
        const ContractId = contractlinememberbycontractlineobject.model.url.query.parentid;
        const ItemId = contractlinememberbycontractlineobject.model.url.query.id;
        const tableobject = contractlinememberbycontractlineobject.tbl;
        // const selectedKeys = contractobject.contractlineobject.getKeySelected();
        const selectedKeys = [ItemId];
        try {
          // Tạo mảng Promise bất đồng bộ
          const promises = selectedKeys.flatMap(async id => {
            const selectusers = response[0]; // Lấy danh sách người dùng từ phần tử đầu tiên của response
            const selectroles = response[1]; // Lấy danh sách vai trò từ phần tử thứ hai của response
            //quét từng user
            for (const u of selectusers) {
              //quét từng role
              for (const r of selectroles) {
                const newcontractlinemember = {
                  Id: senapp.data.sessionAutoId(),
                  ContractId: ContractId,
                  ItemId: ItemId,
                  Account: u,
                  IsActive: 'Yes',
                  Description: `Assigned to role ${r}`,
                  Role: r
                };
                // console.log('Adding contract line member:', newcontractlinemember);
                const res = await fetch(contractlinememberbycontractlineobject.urldata.assignToSubmission, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(newcontractlinemember)
                });
                if (!res.ok) { throw new Error(`HTTP error! status: ${res.status}`); }
                const response = await res.json(); // hoặc .text() nếu API không trả JSON
                if (response.status == 0) {
                  senapp.window.toast({ message: response.message, type: 'danger' });
                } else {
                  senapp.window.toast({ message: response.message, type: 'success' });
                }
              }
            }

          });
          await Promise.all(promises);
          senapp.window.loading.hide();
          contractlinememberbycontractlineobject.tbl.refreshDataDisplay();
          console.log("Tất cả đã xong!");
        } catch (err) {
          senapp.window.alert({ message: `⚠️ ${await senapp.utils.text.t('An error occurred while processing:')}`, type: 'danger' });
          console.error("Có lỗi :", err);
        }
      }
      else {
        senapp.window.alert({ message: `⚠️ ${await senapp.utils.text.t('No roles selected.')}`, type: 'warning' });
      }
    };

