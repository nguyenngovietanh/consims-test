    $(async function () {
      //lấy danh sách RACI
      const racilistres = await fetch(`/common/lookup?lookupType=raci_list`);
      const racilistdata = await racilistres.json();
      contractlinememberbycontractlineobject.racilist = racilistdata.datas;
      //console.log('RACI List:', racilist);
      //map labels cho các cột RACI trong metacolumns
      contractlinememberbycontractlineobject.tbl.metacolumns.forEach(metacolumn => {
        if (['R', 'A', 'C', 'I'].includes(metacolumn.field)) {
          metacolumn.description = contractlinememberbycontractlineobject.racilist.find(r => r.Role === metacolumn.field)?.RoleName || metacolumn.description;
          metacolumn.colorder = 100 + (['R', 'A', 'C', 'I'].indexOf(metacolumn.field) * 10);
        }
      });

      contractlinememberbycontractlineobject.tbl.initTable();
    });

  </script>

</div>