  <script>
    var contractlinememberbycontractlineobject = {};
    contractlinememberbycontractlineobject.model = JSON.parse('<%- JSON.stringify(model) %>');
    contractlinememberbycontractlineobject.contractid = contractlinememberbycontractlineobject.model.url.query.parentid;
    contractlinememberbycontractlineobject.itemid = contractlinememberbycontractlineobject.model.url.query.id;
    contractlinememberbycontractlineobject.worktype ='deduction';// contractlinememberbycontractlineobject.model.url.query.itemworktype || '';

    contractlinememberbycontractlineobject.container = document.getElementById("contractlinememberbycontractline-section");//khu vực chứa danh sách
    contractlinememberbycontractlineobject.urldata = {
      lists: `/contractlinemember/memberbycontractline?contractid=${contractlinememberbycontractlineobject.model.url.query.parentid}&id=${contractlinememberbycontractlineobject.model.url.query.id}&pagesize=0&worktype=${encodeURIComponent(contractlinememberbycontractlineobject.worktype)}`,
      item: '/contractlinemember/item',
      // create: '/contractlinemember/create?callback=' + encodeURIComponent('contractlinememberbycontractlineobject.createcallback'),
      // edit: '/contractlinemember/edit?callback=' + encodeURIComponent('contractlinememberbycontractlineobject.editcallback'),
      delete: '/contractlinemember/delete',
      update0: `/contractlinemember/edit?parentid=${contractlinememberbycontractlineobject.model.url.query.parentid}&id=${contractlinememberbycontractlineobject.model.url.query.id}&worktype=${encodeURIComponent(contractlinememberbycontractlineobject.worktype)}`,
