      if (!excludedFields.includes(element.field)) { element.visible = false; }
    });

    // Khởi tạo bảng
    contractlinememberbycontractlineobject.tbl = new senapp.utils.table({
      meta: contractlinememberbycontractlineobject.model.meta,
      urldata: contractlinememberbycontractlineobject.urldata,
      container: contractlinememberbycontractlineobject.container,
      tableelement: contractlinememberbycontractlineobject.container.querySelector('table'),
      modal: true,
      selectcolumn: true,
      filterrow: false, // không hiển thị filter row
      //filtercompact: false // hiển thị filter row ở dạng compact
      loadmoreonvisible: true, // tự động tải thêm dữ liệu khi cuộn đến cuối danh sách
      //loadmoreshowtoast: true,
