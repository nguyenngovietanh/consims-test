              <span class="fas fa-search search-box-icon"></span>
            </div>
          </div>
          <div id="paymentorder-table-filter" class="mb-2 text-muted fs-9">
            <!-- Filter controls will be added here -->
          </div>
          <div id="paymentorder-table-command" class="mb-2 text-muted fs-9">
            <!-- Command controls will be added here -->
            <div class="mb-1 text-end">
              <div class="btn-group me-1">
                <a onclick="contractobject.paymentorderobject.createDraftIPC(this)"
                  class="btn btn-subtle-secondary btn-sm">Create Draft IPC</a>
                <a onclick="contractobject.paymentorderobject.viewDraftIPC(this)"
                  class="btn btn-subtle-secondary btn-sm ms-1">View Draft IPC</a>
                <a onclick="contractobject.paymentorderobject.removeDraftIPC(this)"
