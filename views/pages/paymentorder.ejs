      metacolumns: [
        { field: 'SysAction', visible: false, colorder: -20 },
        // // { field: 'Ext02', description: 'Apply Tax', colorder: -18, visible: true, show: true, gridwidth: 80, readonly: true },
        // { field: 'Ext01', description: '<i class="fas fa-print" title="Print IPC"></i>', colorder: -1, visible: true, show: true, width: 32 },
        { field: 'Ext03', description: 'View', colorder: -7, visible: true, show: true, width: 48 },
        { field: 'Ext04', description: 'Review', colorder: -8, visible: true, show: true, width: 64 },

        { field: 'ContractCode', show: true, visible: true },
