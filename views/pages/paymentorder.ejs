    contractobject.paymentorderobject.mapDraftIPC = async function () {
      const filtercontainer = contractobject.container;
      const tableobject = contractobject.paymentorderobject.tbl;

      const selectcontract = contractobject.container.querySelector('#paymentorder-contract-select');
      const contractid = selectcontract.value;
      const paymentorderDraftIPC = contractobject.container.querySelector('#paymentorder-draft-ipc');
      paymentorderDraftIPC.innerHTML = '';

      filtercontainer.querySelector('span[field-name="ipc-deducted"]').innerHTML = '';
      filtercontainer.querySelector('span[field-name="ipc-payable"]').innerHTML = '';
      filtercontainer.querySelector('span[field-name="ipc-performed"]').innerHTML = '';
      filtercontainer.querySelector('span[field-name="ipc-added"]').innerHTML = '';
      filtercontainer.querySelector('span[field-name="ipc-number"]').innerHTML = '';

      // filtercontainer.querySelector('span[field-name="ipc-description"]').innerHTML = '';
      // filtercontainer.querySelector('span[field-name="ipc-remarks"]').innerHTML = '';
      const filterfromdate = filtercontainer.querySelector('input[name="filter-fromdate"]').value;
      const filtertodate = filtercontainer.querySelector('input[name="filter-todate"]').value;


      const ipcmanagementfilterstatus = filtercontainer.querySelector('select[name="ipcmanagement-filter-status"]').value;
      const ipcmanagementfilterkeyword = filtercontainer.querySelector('input[name="ipcmanagement-filter-keyword"]').value.trim();
      const ipcmanagementfilterfromdate = filtercontainer.querySelector('input[name="ipcmanagement-filter-fromdate"]').value;
      const ipcmanagementfiltertodate = filtercontainer.querySelector('input[name="ipcmanagement-filter-todate"]').value;

      const tableipcbject = contractobject.ipcobject.tbl;
      const tableipcalloobject = contractobject.ipcallobject.tbl;
      tableipcbject.clearRowData();
      tableipcalloobject.clearRowData();
      if (!contractid) {
        //nếu chưa chọn hợp đồng nào thì không làm gì cả
        //ipc all
        tableipcalloobject.urldata.lists = `${tableipcalloobject.urldata.lists0}?filterfromdate=${encodeURIComponent(ipcmanagementfilterfromdate)}&filtertodate=${encodeURIComponent(ipcmanagementfiltertodate)}&filterkeyword=${encodeURIComponent(ipcmanagementfilterkeyword)}&filterstatus=${encodeURIComponent(ipcmanagementfilterstatus)}`;
        tableipcalloobject.refreshDataDisplay();
        return;
      }
      const url = `${contractobject.urldata.getdraftipc}?contractid=${encodeURIComponent(contractid)}`;
      const response = await fetch(url, { method: 'GET', });
      const resjson = await response.json();
      if (resjson.datas) {
        // console.log('Draft IPC data:', resjson.datas);
        // console.log('Draft IPC Payable Amount:', resjson.datas.PayableAmount);
        const metacolumn = tableobject.meta.find(col => col.field === 'ApprovedAmount');
        paymentorderDraftIPC.innerHTML = senapp.data.stringifyValue(resjson.datas.PayableAmount, metacolumn ? metacolumn : {});


        filtercontainer.querySelector('span[field-name="ipc-number"]').innerHTML = resjson.datas.POCode || '';
        filtercontainer.querySelector('span[field-name="ipc-payable"]').innerHTML = senapp.data.stringifyValue(resjson.datas.PayableAmount, metacolumn ? metacolumn : {});
        filtercontainer.querySelector('span[field-name="ipc-performed"]').innerHTML = senapp.data.stringifyValue(resjson.datas.PerformedAmount, metacolumn ? metacolumn : {});
        filtercontainer.querySelector('span[field-name="ipc-added"]').innerHTML = senapp.data.stringifyValue(resjson.datas.AddedAmount, metacolumn ? metacolumn : {});
        filtercontainer.querySelector('span[field-name="ipc-deducted"]').innerHTML = senapp.data.stringifyValue(resjson.datas.DeductedAmount, metacolumn ? metacolumn : {});

        // filtercontainer.querySelector('span[field-name="ipc-description"]').innerHTML =  resjson.datas.IPCName || '';
        // filtercontainer.querySelector('span[field-name="ipc-remarks"]').innerHTML = resjson.datas.Remarks || '';


      }

      //ipc 

      tableipcbject.urldata.lists = `${tableipcbject.urldata.lists0}?filtercontractid=${encodeURIComponent(contractid)}&filterfromdate=${encodeURIComponent(filterfromdate)}&filtertodate=${encodeURIComponent(filtertodate)}`;
      tableipcbject.refreshDataDisplay();

      //ipc all
      tableipcalloobject.urldata.lists = `${tableipcalloobject.urldata.lists0}?filtercontractid=${encodeURIComponent(contractid)}&filterfromdate=${encodeURIComponent(ipcmanagementfilterfromdate)}&filtertodate=${encodeURIComponent(ipcmanagementfiltertodate)}&filterkeyword=${encodeURIComponent(ipcmanagementfilterkeyword)}&filterstatus=${encodeURIComponent(ipcmanagementfilterstatus)}`;
      tableipcalloobject.refreshDataDisplay();

    };

