    $(async function () {
      // await contractobject.tbl.initTable();
      // contractobject.paymentorderobject.model = await senapp.data.getMeta({ url: contractobject.paymentorderobject.urldata.meta });
      contractobject.paymentorderobject.model = await senapp.data.getMeta({ url: contractobject.paymentorderobject.urldata.meta });
      // const workcategory = await contractobject.paymentorderobject.getWorkType();
      // contractobject.paymentorderobject.model.meta.find(item => item.field === 'ReviewedWorkCat').data = workcategory;

      contractobject.paymentorderobject.tbl.datanew = JSON.parse(JSON.stringify(contractobject.paymentorderobject.model.datanew));
      contractobject.paymentorderobject.tbl.meta = JSON.parse(JSON.stringify(contractobject.paymentorderobject.model.meta));

      // contractobject.paymentorderobject.tbl.meta.map(column => {
      //   column.description = `<span class="text-primary">${column.description || ''}</span>`;
      // });
      // contractobject.paymentorderobject.tbl.meta.forEach(column => {
      //   const description=column.description || '';
      //   column.description = `<span class="text-primary">${description}</span>`;
      // });

      await contractobject.paymentorderobject.tbl.initTable();

      //gán định dạng tiêu đề cột được phép sửa
      const headers = contractobject.paymentorderobject.tbl.container.querySelectorAll('th');
      headers.forEach(th => {
        const field = th.getAttribute('data-field');
        const metacolumn = contractobject.paymentorderobject.tbl.metacolumns.find(col => col.field === field);
        if (metacolumn) {
          const isEditable = metacolumn.readonly !== true;// metacolumn.edit;
          if (isEditable) {
            th.classList.add('text-primary');
          }
        }
      });

      //khởi tạo điều kiện lọc cho chi tiết hợp đồng
      await contractobject.getWorkType();
      if (contractobject.itemworktype.length > 0) { contractobject.filterworktype = contractobject.itemworktype[0].id; }
      await contractobject.getStatus();
      // await contractobject.getWorkCategory();
      // await contractobject.getRoles();

      //gán filter
      const linefilterhtml = contractobject.paymentorderobject.filterline();
      contractobject.container.querySelector('#paymentorder-table-filter').innerHTML = linefilterhtml;

      //tạo điều kiện lọc cho IPC management
      const ipcmanagementfilterhtml = contractobject.ipcallobject.filter();
      contractobject.container.querySelector('#paymentorder-ipcmanagement-filter').innerHTML = ipcmanagementfilterhtml;


      //ngầm định chon status = 'in-progress'
      contractobject.container.querySelector('select[name="filter-status"]').value = 'In-Progress';
      //gọi hàm filterchange để load dữ liệu

      // await contractobject.paymentorderobject.linefilterchange(contractobject.container.querySelector('input[name="filter-keyword"]'));

      const selectcontract = contractobject.container.querySelector('#paymentorder-contract-select');
      const choices = senapp.utils.lookup(selectcontract, {
        itemSelectText: '',     // Ẩn "Press to select"
        noChoicesText: '',      // Ẩn "No choices to choose from"
        removeItemButton: true,
        searchEnabled: true,
        searchChoices: false
      })
      const lookup = contractobject.paymentorderobject.lookupfiltercontract;
      selectcontract.addEventListener('search', async function (e) {
        const keyword = e.detail.value;
        if (!keyword.endsWith(' ')) return;
        const trimmed = keyword.trim();
        lookup.filter.conditions[0].value = trimmed;
        try {
          const res = await fetch(`${lookup.url}?lookupType=contract&pagesize=${lookup.pagesize || 10}&filter=${JSON.stringify(lookup.filter)}`);
          lookup.data = [];
          if (res.ok) {
            const data = await res.json();
            lookup.data = data.datas.map(item => ({ id: eval(lookup.fields.id), value: eval(lookup.fields.value), label: eval(lookup.fields.label) }));
          }
        } catch (err) { console.error('Lỗi khi gọi API:', err); }
        choices.setChoices(lookup.data, 'value', 'label', true);
      });

      selectcontract.addEventListener('change', async function (e) {
        await contractobject.paymentorderobject.mapDraftIPC();
      });

      //ipc
      contractobject.ipcobject.model = await senapp.data.getMeta({ url: contractobject.ipcobject.urldata.meta });
      contractobject.ipcobject.tbl.datanew = JSON.parse(JSON.stringify(contractobject.ipcobject.model.datanew));
      contractobject.ipcobject.tbl.meta = JSON.parse(JSON.stringify(contractobject.ipcobject.model.meta));
      await contractobject.ipcobject.tbl.initTable();
      //ipc all
      contractobject.ipcallobject.model = await senapp.data.getMeta({ url: contractobject.ipcallobject.urldata.meta });
      contractobject.ipcallobject.tbl.datanew = JSON.parse(JSON.stringify(contractobject.ipcallobject.model.datanew));
      contractobject.ipcallobject.tbl.meta = JSON.parse(JSON.stringify(contractobject.ipcallobject.model.meta));
      await contractobject.ipcallobject.tbl.initTable();

      await contractobject.paymentorderobject.mapDraftIPC();
      

    });
  </script>

