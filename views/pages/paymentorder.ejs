        urldata.lists += `&${filterParams}`;
      }


      let tblline = new senapp.utils.table({
        datanew: datanew,
        meta: this.model.meta,
        urldata: urldata,
        container: extline,
        selectcolumn: false, // có hiển thị cột chọn hay không
        filterrow: false, // có hiển thị filter row hay không        
        addrow: false, // cho phép thêm mới
