<div id="paymentorder-section">
  <div class="mb-9">
    <h2 class="mb-4"><%- title %></h2>
    <!-- <div class="mb-1">
      <div class="">
        <div class="btn-group me-1">
          <a onclick="contractobject.paymentorderobject.tbl.savechanged()" class="btn btn-subtle-primary">Save
