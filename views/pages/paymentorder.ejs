                <a onclick="contractobject.paymentorderobject.memberRACI(this)"
                  class="btn btn-subtle-secondary btn-sm ms-1">Members</a>
              </div>
            </div>
          </div>
          <div id="paymentorder-table-info" class="mb-2 d-none">
            <!-- Command controls will be added here -->
            <div class="col-12 text-end" style="font-weight:bold;">
              <label for="paymentorder-draft-ipc" class="form-label me-2">Payable Amount:</label>
              <span id="paymentorder-draft-ipc"></span>
            </div>

          </div>

          <ul class="nav nav-underline fs-9" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#paymentorder-tab-1" type="button"
                role="tab" aria-controls="paymentorder-tab-1" aria-selected="true">Payment Preparation</button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" data-bs-toggle="tab" data-bs-target="#paymentorder-tab-2" type="button"
