  <script>
    var contractobject = {};
    contractobject.model = JSON.parse('<%- JSON.stringify(model) %>');
    contractobject.container = document.getElementById("paymentorder-section");//khu vực chứa danh sách
    contractobject.containeripcmanagement = document.getElementById("paymentorder-section-ipc-management");//khu vực chứa danh sách IPC management

    contractobject.urldata = {
      lists: '/contract/list',
      item: '/contract/item',
      // create: '/contract/create?viewname=paymentorderupdate&callback=' + encodeURIComponent('contractobject.createcallback'),
      // edit: '/contract/edit?viewname=paymentorderupdate&callback=' + encodeURIComponent('contractobject.editcallback'),
      // delete: '/contract/delete',
      // update: '/contract/edit'
      assignToUser: '/contractmember/create',
      assignToSubmission: '/contractlinemember/create',
      memberbycontract: '/contractmember/memberbycontract',
      management: '/contract/management',
      removedraftipc: '/paymentorder/removedraftipc',
      createdraftipc: '/paymentorder/createdraftipc',
      getdraftipc: '/paymentorder/getdraftipc',
      createipcfromdraft: '/paymentorder/createipcfromdraft',
      memberbypaymentorder: '/contractmember/memberbypaymentorder',
    };

    //#region IPC
    contractobject.ipcobject = { model: {}, tbls: [] };
    contractobject.ipcobject.urldata = {
      lists0: '/paymentorderipc/list',
      lists: '/paymentorderipc/list',
      listsall0: '/paymentorderipc/listall',
      listsall: '/paymentorderipc/listall',
      create0: '/paymentorderipc/create?callback=' + encodeURIComponent('contractobject.ipcobject.createcallback'),
      create: '/paymentorderipc/create?callback=' + encodeURIComponent('contractobject.ipcobject.createcallback'),
      delete: '/paymentorderipc/delete',
      meta: '/paymentorderipc/meta',
    };
    contractobject.ipcobject.createcallback = function (response) {
      //nếu response[0] tồn tại thì hiển thị thông báo lỗi
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        contractobject.paymentorderobject.mapDraftIPC();
        // contractobject.ipcobject.tbl.onAddRowData({ data: response[0].data });
        //senapp.sidebar.menuclickbydatalink('/senobject');
      }
    };

    contractobject.ipcobject.tbl = new senapp.utils.table({
      // datanew: datanew,
      // meta: this.model.meta,
      urldata: contractobject.ipcobject.urldata,
      container: contractobject.container,
      tableelement: contractobject.container.querySelector('#paymentorder-ipc-table'),
      selectcolumn: false, // có hiển thị cột chọn hay không
      filterrow: false, // có hiển thị filter row hay không
      addrow: false, // cho phép thêm mới
      editrow: false, // cho phép sửa
      deleterow: true, // cho phép xóa
      addnewfirst: false, //thêm mới vào đầu danh sách
      // loadmoreonvisible: true, // tự động tải thêm dữ liệu khi cuộn đến cuối danh sách  
      metacolumns: [
        { field: 'SysAction', visible: true, colorder: -20 },
        // { field: 'Ext02', description: 'Apply Tax', colorder: -18, visible: true, show: true, gridwidth: 80, readonly: true },
        { field: 'Ext01', description: '<i class="fas fa-print" title="Print IPC"></i>', colorder: -1, visible: true, show: true, width: 32 },
        { field: 'Ext03', description: 'View', colorder: -7, visible: true, show: true, width: 48 },
        { field: 'Ext04', description: 'Review', colorder: -8, visible: true, show: true, width: 64 },

      ],
      customcolumns: ['Ext01', 'Ext03', 'Ext04'], // Danh sách các cột tùy chỉnh khi render cell
      allowloaddataininit: false,//không tự động load data khi khởi tạo
      modal: true,
      actionbuttons: { edit: false },
      allowpinheader: true, //cho phép cố định header khi cuộn trang
    });

    contractobject.ipcobject.tbl.genCellDataCustom = function ({ data, metacolumn }) {
      if (!metacolumn || !metacolumn.field) {
        return null; // Trả về null nếu không có metacolumn hoặc field
      }
      // Hàm này sẽ được sử dụng để tạo dữ liệu cho các cột tùy chỉnh
      const tableobject = this;
      const td = document.createElement('td');
      td.setAttribute('data-field', metacolumn.field);
      //nếu field.visible là false hoặc field.show là false thì không hiển thị cột này  gán class d-none
      if (!metacolumn.show || !metacolumn.visible) { td.classList.add('d-none'); }
      switch (metacolumn.field) {
        case 'Ext02':
          //<i class="uil-file-check" style="font-size: 18px;"></i>
          td.innerHTML = `<a href="javascript:;" onclick="contractobject.ipcobject.validateapplytax({ el: this })" title="Apply Tax">Apply Tax</a>`;
          break;
        case 'Ext04':
          if (data.IsAssigned == 'No') {
            td.innerHTML = `<a class="text-muted" href="javascript:;" onclick="contractobject.ipcobject.showapproval({ el: this,edit:true })" title="Approval"><i class="fa fa-edit"></i></a>`;
          }
          else {
            td.innerHTML = `<a class="text-muted" href="javascript:;" onclick="contractobject.ipcobject.showapproval({ el: this,edit:false })" title="Review"><i class="fas fa-list"></i></a>`;
          }
          // td.innerHTML = `<a href="javascript:;" onclick="contractobject.ipcobject.showapproval({ el: this })" title="Approval">Approval</a>`;
          break;
        case 'Ext01':
          td.innerHTML = `<a href="javascript:;" onclick="contractobject.ipcobject.print({ el: this })" title="Print IPC"><i class="fas fa-print text-muted"></i></a> <a class="d-none" href="javascript:;" onclick="contractobject.ipcobject.printcumulative({ el: this })" title="Print IPC"><i class="fas fa-print text-muted"></i></a>`;
          break;
        case 'Ext03':
          td.innerHTML = `<a class="text-muted" href="javascript:;" onclick="contractobject.ipcobject.showipcline({ el: this })" title="View IPC"><i class="fa fa-eye"></i></a>`;
          break;

        default:
          //nếu không phải là cột tùy chỉnh thì trả về giá trị của trường đó
          td.innerHTML = data[metacolumn.field] || '';
          break;
      }
      return td;
    }

    contractobject.ipcobject.tbl.genCellDataActionCheck = function ({ data, metacolumn, actionbuttons } = {}) {
      actionbuttons.delete = (data.IsAssigned === "No");
    }

    //#region IPC functions
    contractobject.ipcobject.validateapplytax = async function ({ el }) {
      //hàm này dùng để validate trước khi apply tax
      // console.log('Validate before apply tax for element:', el);
      senapp.window.loading.show();
      try {
        const datapost = {
          //lấy id từ thuộc tính data-id của thẻ cha tr của el
          paymentid: parseInt(el.closest('tr').getAttribute('data-id')),
        };
        const url = '/paymentorderipc/validateapplytax';
        const response = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(datapost) });
        resdata = await response.json();
        senapp.window.loading.hide();
        if (senapp.window.confirm({ message: `${resdata.message}` })) {
          await contractobject.ipcobject.acceptapplytax({ el: el });
        }
        else {
          await contractobject.ipcobject.rejectapplytax({ el: el });
        }

        // senapp.window.toast({ message: resdata.message, type: resdata.status == 1 ? 'success' : 'error' });
        // tableobject.refreshDataDisplay();
        // await contractobject.paymentorderobject.mapDraftIPC();

      } catch (error) {
        console.error(`Error in synServer: ${error}`);
        resdata = { status: 0, message: error.message || 'Error in synServer', data: {}, errors: {} };
        senapp.window.loading.hide();
      }

    }
    contractobject.ipcobject.acceptapplytax = async function ({ el }) {
      //hàm này dùng để accept apply tax
      // console.log('Accept apply tax for element:', el);
      senapp.window.loading.show();
      try {
        //lấy id từ thuộc tính data-id của thẻ cha tr của el
        const datapost = { paymentid: parseInt(el.closest('tr').getAttribute('data-id')) };
        const url = '/paymentorderipc/acceptapplytax';
        const response = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(datapost) });
        resdata = await response.json();
        if (resdata.status == 1) {
          this.showipcline({ el: el });
        }
        else {
          senapp.window.toast({ message: resdata.message, type: 'error' });
        }

        // console.log('Apply tax response:', resdata);
        // senapp.window.toast({ message: resdata.message, type: resdata.status == 1 ? 'success' : 'error' });
        // tableobject.refreshDataDisplay();
        // await contractobject.paymentorderobject.mapDraftIPC();

      } catch (error) {
        console.error(`Error in synServer: ${error}`);
        resdata = { status: 0, message: error.message || 'Error in synServer', data: {}, errors: {} };
      }
      senapp.window.loading.hide();

    }
    contractobject.ipcobject.rejectapplytax = async function ({ el }) {
      //hàm này dùng để reject apply tax
      this.showipcline({ el: el });
    }
    contractobject.ipcobject.showipcline = async function ({ el }) {
      //hàm này dùng để show IPC line
      const url = '/paymentorderipc/ipcline?paymentid=' + parseInt(el.closest('tr').getAttribute('data-id'));
      senapp.window.modal({ title: `IPC detail`, url, size: 'xl', maximizebutton: true });
    }

    contractobject.ipcobject.print = async function ({ el }) {
      //hàm này dùng để show IPC line
      const url = '/paymentorderipc/ipcprint?paymentid=' + parseInt(el.closest('tr').getAttribute('data-id'));
      senapp.window.modal({ title: `IPC Print`, url, size: 'xl', maximizebutton: true });
    }
    
    contractobject.ipcobject.printcumulative = async function ({ el }) {
      //hàm này dùng để show IPC line
      const url = '/paymentorderipc/ipcprintcumulative?paymentid=' + parseInt(el.closest('tr').getAttribute('data-id'));
      senapp.window.modal({ title: `IPC Print Cumulative`, url, size: 'xl', maximizebutton: true });
    }

    contractobject.ipcobject.showapprovalcallback = function (response) {
      //nếu response[0] tồn tại thì hiển thị thông báo lỗi
      // console.log('Show approval callback response:', response);
      // console.log('Current payment ID:', contractobject.ipcobject.currentpaymentid);
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        //lấy data
        const data = response[0].data;


        //cập nhật lại dòng dữ liệu trong bảng IPC
        contractobject.ipcobject.tbl.onChangeRowData({ data: data });
        // senobjectobject.tbl.onChangeRowData({ data: response[0].data });
        //senapp.sidebar.menuclickbydatalink('/senobject');
      }
    }

    contractobject.ipcobject.currentpaymentid = null;
    contractobject.ipcobject.showapproval = async function ({ el, edit }) {
      //hàm này dùng để show IPC approval
      const selectcontract = contractobject.container.querySelector('#paymentorder-contract-select');
      const contractid = selectcontract.value;
      const filtercontainer = contractobject.container; //element.closest('table');// element.closest('.mb-1');
      const filterworktype = "payment_order";//filtercontainer.querySelector('select[name="filter-worktype"]').value;
      contractobject.ipcobject.currentpaymentid = parseInt(el.closest('tr').getAttribute('data-id'));
      if (edit == true) {
        const url = `/paymentorderipc/ipcapproval?callback=contractobject.ipcobject.showapprovalcallback&contractid=${contractid}&paymentid=${parseInt(el.closest('tr').getAttribute('data-id'))}&worktype=${filterworktype}&edit=${edit}`;
        senapp.window.modal({ title: `IPC Approval`, url, size: 'lg', maximizebutton: true });
      }
      else {
        contractobject.ipcobject.loadreviewall(el);
      }
    }

    contractobject.ipcobject.loadreviewall = function (element) {
      const tableobject = contractobject.ipcobject.tbl;
      const id = parseInt(element.closest('tr').getAttribute('data-id'));
      const data = tableobject.datas.find(item => item[tableobject.keyfield] === id);

      const itemworktype = 'payment_order';
      let url = `/contractlineperform/review?submissionid=${data.PaymentId}&worktype=${encodeURIComponent(itemworktype)}&itemworktype=${encodeURIComponent(itemworktype)}`;
      if (['payment_order'].includes(itemworktype)) {
        url += `&viewname=contractlineperformreview4paymentorder`;
      }

      senapp.window.modal({
        title: `Review of ${data["POCode"] || ''} - ${data["POName"] || ''}`,
        url: url,
        size: 'xl'
      });
    };

    contractobject.ipcobject.filterchange = async function () {
      const filtercontainer = contractobject.container;
      const selectcontract = contractobject.container.querySelector('#paymentorder-contract-select');
      const contractid = selectcontract.value;

      const tableipcbject = contractobject.ipcobject.tbl;
      tableipcbject.clearRowData();

      if (!contractid) {
        //nếu chưa chọn hợp đồng nào thì không làm gì cả
        return;
      }
      //ipc 
      tableipcbject.urldata.lists = `${tableipcbject.urldata.lists0}?filtercontractid=${encodeURIComponent(contractid)}`;
      tableipcbject.refreshDataDisplay();

    };
    //#endregion IPC functions

