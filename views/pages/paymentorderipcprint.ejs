            <div class="sheet mx-auto shadow-sm">

              <!-- HEADER (grid bootstrap + border) -->
              <div class="row g-0 border-bottom border-dark">
                <!-- Logo -->
                <div class="col-4 border-end border-dark p-2">
                  <div class="d-flex align-items-center gap-2">
                    <!-- <span class="logo-badge" aria-hidden="true"></span>
                  <div class="fw-bold">LOGO</div> -->
                    <img src="<%=senapp.logo? senapp.logo.FilePath : '/assets/img/icons/logo.png' %>" alt="phoenix"
                      width="125" />
                  </div>
                </div>

                <!-- Meta -->
                <div class="col-6 border-end border-dark">
                  <div class="p-2 border-bottom border-dark small">
                    <div class="row g-0">
                      <div class="col-3 fw-bold" style="text-align:left;">Hợp đồng:</div>
                      <div class="col-9 fw-bold" style="text-align:left;">
                        <div class="sen-display" name="ContractName"></div>
                      </div>
                    </div>
                  </div>
                  <div class="p-2 border-bottom border-dark small">
                    <div class="row g-0">
                      <div class="col-3 fw-bold" style="text-align:left;">Ngày nhận:</div>
                      <div class="col-9" style="text-align:left;">
                        <div class="sen-display" name="PaymentDate"></div>
                      </div>
                    </div>
                  </div>
                  <div class="p-2 small">
                    <div class="row g-0">
                      <div class="col-6 fw-bold" style="text-align:left;">Số hạch toán:</div>
                      <div class="col-6 fw-bold" style="text-align:left;">Kỳ thanh toán:</div>
                    </div>
                  </div>
                </div>

                <!-- Status -->
                <div class="col-2">
                  <div class="approved-badge text-center p-2 border-bottom border-dark">
                    <div class="sen-display" name="PaymentApprovalStatus"></div>
                  </div>
                  <div class="text-center fw-bold p-2 small">TCC</div>
                </div>
              </div>

              <!-- TITLE -->
              <div class="text-center border-bottom border-dark py-2">
                <div class="fw-bold">THÔNG BÁO THANH TOÁN</div>
                <div class="fw-bold">(NCC/NTP)</div>
              </div>

              <!-- INFO TABLE -->
              <div class="p-0">
                <table class="table table-bordered border-dark mb-0 small">
                  <colgroup>
                    <col style="width:13%">
                    <col style="width:37%">
                    <col style="width:13%">
                    <col style="width:37%">
                  </colgroup>
                  <tbody>
                    <tr>
                      <td class="fw-bold">NCC/NTP:</td>
                      <td>
                        <div class="sen-display" name="ContractorName"></div>
                      </td>
                      <td class="fw-bold">Số HĐ:</td>
                      <td>
                        <div class="sen-display" name="ContractCode"></div>
                      </td>
                    </tr>
                    <tr>
                      <td class="fw-bold">Hạng mục:</td>
                      <td></td>
                      <td class="fw-bold">Ngày ký:</td>
                      <td>
                        <div class="sen-display" name="PaymentDate"></div>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <!-- MAIN TABLE -->
              <div class="p-0">
                <table class="table table-bordered table-sm fs-9 mb-5">
                  <colgroup>
                    <col style="width:56px">
                    <col>
                    <col style="width:210px">
                  </colgroup>
                  <thead>
                    <tr class="text-center">
                      <th class="fw-bold"><i class="toggle-icon">▼</i>No.</th>
                      <th class="fw-bold">Nội dung</th>
                      <th class="fw-bold">Giá trị</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr class="toggle-row" data-toggle-group="group-a" aria-expanded="true">
                      <td class="text-center fw-bold"><i class="toggle-icon">▼</i>A</td>
