                      <td class="text-end fw-bold"></td>
                    </tr>
                    <tr data-group="group-a">
                      <td class="text-center">1</td>
                      <td>Giá trị hợp đồng ban đầu</td>
                      <td class="text-end">
                        <div class="sen-display" name="ContractAmount"></div>
                      </td>
                    </tr>

                    <tr data-group="group-a">
                      <td class="text-center">2</td>
                      <td>Điều chỉnh hợp đồng</td>
                      <td class="text-end">
                        <div class="sen-display" name="ContractAdjustment"></div>
                      </td>
                    </tr>
                    <tr data-group="group-a">
                      <td class="text-center">3</td>
                      <td>Giá trị hợp đồng sau điều chỉnh</td>
