  <script>
    var paymentorderipcprintobject = {};
    paymentorderipcprintobject.model = <%- JSON.stringify(model) %>;// dùng cách này là ok nhất không bị các trường hợp rớt dòng nhưng bị cảnh báo
    // paymentorderipcprintobject.model = JSON.parse(('<%- JSON.stringify(model) %>').replace(/\r?\n|\r/g, "\\n"));//xử lí xuống dòng trong chuỗi json
    paymentorderipcprintobject.container = document.getElementById("paymentorderipcprint-section");//khu vực chứa form nghiệp vụ

    // Khởi tạo bảng
    paymentorderipcprintobject.form = new senapp.utils.form({
      meta: paymentorderipcprintobject.model.meta,
      data: paymentorderipcprintobject.model.data,
      urldata: paymentorderipcprintobject.model.url,
      container: paymentorderipcprintobject.container,
      mode: 'view',//chỉ xem không cho sửa
    });

    // paymentorderipcprintobject.form.saveBefore = async function () {
    //   this.data.ContractId = parseInt(paymentorderipcprintobject.model.url.query.contractid) || 0;//thêm ContractId vào data để gửi lên server
    //   return true;
    // };

    paymentorderipcprintobject.mapasignee = function () {
      /*
      const metaassignee = [
        { field: 'RoleInWord', type: 'string', description: 'Role In Word', isnullable: true, show: true, visible: true, readonly: true },
        { field: 'FullName', type: 'string', description: 'Full Name', isnullable: true, show: true, visible: true, readonly: true },
        { field: 'ActualFinish', type: 'date', description: 'Actual Finish', isnullable: true, show: true, visible: true, readonly: true },
        { field: 'ApprovalStatus', type: 'string', description: 'Approval Status', isnullable: true, show: true, visible: true, readonly: true },
        { field: 'Remarks', type: 'string', description: 'Remarks', isnullable: true, show: true, visible: true, readonly: true }
      ];
      */
      const tbody = paymentorderipcprintobject.container.querySelector('#paymentorderipcprint-asignee-section');
      tbody.innerHTML = '';//xóa dữ liệu cũ
      const asignees = paymentorderipcprintobject.model.data.dataext?.asignee || [];
      asignees.forEach(asignee => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${asignee.RoleInWord || ''}</td>
          <td>${asignee.FullName || ''}</td>
          <td class="text-center">${asignee.ActualFinish ? new Date(asignee.ActualFinish).toLocaleString() : ''}</td>
          <td class="text-center">${asignee.ApprovalStatus || ''}</td>
          <td>${asignee.Remarks || ''}</td>
        `;
        tbody.appendChild(tr);
      });

    }

    paymentorderipcprintobject.metacontractinfo;
    paymentorderipcprintobject.mapmeta = async function () {
      //ví dụ nếu muốn ẩn cột nào đó trong form thì có thể gán show hoặc visible của trường đó thành false ở đây
      // paymentorderipcprintobject.form.metacolumns.find(c => c.field === 'ContractorName').show = false;
      const urlmeta = `/paymentorderipc/metacontractinfo`;
      const response = await fetch(urlmeta, {
        method: 'GET', headers: { 'Content-Type': 'application/json' }
      }).then(res => res.json())
        .then(data => {
          paymentorderipcprintobject.metacontractinfo = data;
        })
        .catch(error => {
          console.error('Error fetching meta contract info:', error);
        });
    }

    paymentorderipcprintobject.mapcontract = function () {
      console.log(paymentorderipcprintobject.metacontractinfo);
      senapp.utils.data2displays({
        metas: paymentorderipcprintobject.metacontractinfo.meta,
        data: paymentorderipcprintobject.model.data.dataext?.contractinfo || {},
        container: paymentorderipcprintobject.container
      });
    }

    // Gọi hàm này SAU KHI modal đã render xong
    paymentorderipcprintobject.initToggleRows = function (container) {
      container = container || document;//mặc định là document nhưng nếu có container cụ thể thì truyền vào để chỉ scope tìm kiếm trong container đó, tránh ảnh hưởng đến các phần khác
      container.querySelectorAll('.toggle-row[data-toggle-group]').forEach(function (row) {
        // Tránh bind nhiều lần
        if (row.dataset.toggleBound === '1') return;
        row.dataset.toggleBound = '1';

        row.addEventListener('click', function () {
          const groupName = row.getAttribute('data-toggle-group');
          const isExpanded = row.getAttribute('aria-expanded') === 'true';

          // Toggle tất cả <tr> con trong nhóm
          container.querySelectorAll(`tr[data-group="${groupName}"]`).forEach(function (tr) {
            tr.style.display = isExpanded ? 'none' : ''; // '' = trả về mặc định (table-row)
          });

          // Cập nhật trạng thái + icon
          row.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
          row.classList.toggle('collapsed', isExpanded);
        });
      });

      // ── 2. Click vào "No." header → mở rộng hết / gom lại hết ──
      const thNo = container.querySelector('thead th:first-child');
      if (thNo && thNo.dataset.toggleBound !== '1') {
        thNo.dataset.toggleBound = '1';

        // Đổi cursor để người dùng biết có thể click
        thNo.style.cursor = 'pointer';
        thNo.title = 'Click để mở rộng / gom lại tất cả';

        // Trạng thái tổng: mặc định đang mở hết
        let allExpanded = true;

        thNo.addEventListener('click', function () {
          allExpanded = !allExpanded;

          // Toggle tất cả toggle-row
          container.querySelectorAll('.toggle-row[data-toggle-group]').forEach(function (row) {
            const groupName = row.getAttribute('data-toggle-group');

            container.querySelectorAll(`tr[data-group="${groupName}"]`).forEach(function (tr) {
              tr.style.display = allExpanded ? '' : 'none';
            });

            row.setAttribute('aria-expanded', allExpanded ? 'true' : 'false');
            row.classList.toggle('collapsed', !allExpanded);
          });

          // Cập nhật icon trên header No.
          thNo.innerHTML = allExpanded
            ? '<i class="toggle-icon">▼</i> No.'
            : '<i class="toggle-icon" style="transform:rotate(-90deg)">▼</i> No.';
        });
      }

      //ngầm định thu gọn hết các nhóm
      thNo.click(); //gọi sự kiện click để thu gọn hết ngay khi load modal, nếu muốn mặc định mở hết thì bỏ dòng này đi

      // container.querySelectorAll('.toggle-row[data-toggle-group]').forEach(function (row) {
      //   const groupName = row.getAttribute('data-toggle-group');
      //   container.querySelectorAll(`tr[data-group="${groupName}"]`).forEach(function (tr) {
      //     tr.style.display = 'none';
      //   });
      //   row.setAttribute('aria-expanded', 'false');
      //   row.classList.add('collapsed');
      // });

    }


    //print 
    paymentorderipcprintobject.print = function () {
      //lấy đối tượng cần in
      const elementToPrint = paymentorderipcprintobject.container.querySelector('#paymentorderipcprint-section-print');
      if (!elementToPrint) {
        console.error('Không tìm thấy phần tử để in');
        return;
      }
      senapp.common.printelem({
        elem: elementToPrint,
        title: 'Phiếu thanh toán IPC',
        // css: '/assets/css/print.css' //nếu có css riêng cho in ấn thì thêm vào đây
      });

    }

    $(async function () {
      await paymentorderipcprintobject.form.initForm();
      await paymentorderipcprintobject.mapmeta();
      paymentorderipcprintobject.mapasignee();
      paymentorderipcprintobject.mapcontract();

      // Truyền container để đảm bảo đúng scope trong modal
      paymentorderipcprintobject.initToggleRows(paymentorderipcprintobject.container);

    });

  </script>


