<div id="paymentorderipcprint-section" class="" style="margin: 0 auto;">
  <form id="paymentorderipcprint-form">
    <div class="card">
      <div class="card-header">
        <h4 class="mb-0">
          <a class="me-3" href="javascript:;" onclick="paymentorderipcprintobject.print()" title="Print IPC"><i
              class="fas fa-print text-muted"></i></a>
          IPC Print
        </h4>
      </div>
      <div class="card-body">
        <!-- Thông báo tổng -->
        <div class="message-all callout d-none" role="alert"></div>
        <div id="paymentorderipcprint-section-print">
          <div class="container pt-4 print-block">
            <style>
              /* CSS custom tối thiểu (ưu tiên Bootstrap) */
              .sheet {
                background: #fff;
                border: 2px solid #000;
                max-width: 860px;
              }

              .approved-badge {
                background: #d40000;
                color: #fff;
                font-weight: 700;
              }

              .logo-badge {
                width: 28px;
                height: 28px;
                border: 2px solid #1f4e79;
                border-radius: 50%;
                position: relative;
                box-sizing: border-box;
                flex: 0 0 auto;
              }

              .logo-badge:before {
                content: "";
                position: absolute;
                inset: 6px;
                border: 2px solid #c00000;
                border-left-color: transparent;
                border-bottom-color: transparent;
                border-radius: 50%;
                transform: rotate(45deg);
              }

              /* giống “phiếu” hơn (tùy chọn) */
              .table td,
              .table th {
                vertical-align: top;
              }

              /* Toggle row styles */
              .toggle-row {
                cursor: pointer;
                user-select: none;
              }

              .toggle-row:hover td {
                background-color: #f8f9fa;
              }

              .toggle-icon {
                display: inline-block;
                margin-right: 6px;
                font-style: normal;
                transition: transform .2s ease;
                font-size: 10px;
              }

              .toggle-row.collapsed .toggle-icon {
                transform: rotate(-90deg);
              }
            </style>


