    placeholder: true,
    placeholderValue: 'Input Object String...'
  });

  async function fetchViaAsync(keyword = '') {
    //if (!keyword) return [];
    senobjectlookupViaAsync.filter.conditions[1].value = keyword; // Cập nhật điều kiện lọc
    try {
      const res = await fetch(`${senobjectlookupViaAsync.url}?pagesize=${senobjectlookupViaAsync.pagesize}&filter=${JSON.stringify(senobjectlookupViaAsync.filter)}`);
      console.log('fetchViaAsync', res);
      if (!res.ok) return [];
      const data = await res.json();
      return data.datas.map(item => ({
        value: item.Id,
        label: item.String
      }));
    } catch (err) {
      console.error('Lỗi khi gọi API:', err);
      return [];
    }
  }

  var debounceTimerViaAsync;
  //khi gõ phím space thì sẽ gọi API để tìm kiếm
  selectElementViaAsync.addEventListener('search', function (e) {
    const keyword = e.detail.value;
    // Kiểm tra nếu vừa gõ phím space (có khoảng trắng)
    if (!keyword.endsWith(' ')) return;
    const trimmed = keyword.trim();
    //if (!trimmed) return;//khoảng trắng không cần thiết (nếu cần thì mở dòng này)

    clearTimeout(debounceTimerViaAsync);
    debounceTimerViaAsync = setTimeout(async () => {
      const options = await fetchViaAsync(trimmed);
      choicesViaAsync.setChoices(options, 'value', 'label', true);
    }, 300);
  });

  // Hiển thị quốc gia đã chọn
  selectElementViaAsync.addEventListener('change', function (e) {
    const selected = choicesViaAsync.getValue(true); // lấy value
    const label = choicesViaAsync.getValue(true, 'label'); // lấy label
    console.log(`value: ${selected} - label: ${label}`);

  });


</script>

<script>

  // lookup load trước data

  var senobjectlookup = { url: '/senobject/list', data: [], pagesize: 0, filter: { "logic": "and", "conditions": [{ "field": "Boolean", "op": "==", "value": true }] } };
  senobjectlookup.init = function () {
    //fetch data for lookup
    fetch(`${senobjectlookup.url}?pagesize=${senobjectlookup.pagesize}&filter=${JSON.stringify(senobjectlookup.filter)}`)
      .then(response => response.json())
      .then(data => {
        senobjectlookup.data = data.datas;
        const select = document.getElementById("lookup-select");
        const selectVia = document.getElementById("lookup-select-via");

        // Populate the first select
        senobjectlookup.data.forEach(item => {
          const option = document.createElement("option");
          option.value = item.Id; // Assuming Id is the unique identifier
          option.textContent = item.String; // Assuming String is the display value
          select.appendChild(option);
        });

        // Populate the second select (via)
        senobjectlookup.data.forEach(item => {
          const optionVia = document.createElement("option");
          optionVia.value = item.Id; // Assuming Id is the unique identifier
          optionVia.textContent = item.String; // Assuming String is the display value
          selectVia.appendChild(optionVia);
        });
      })
      .catch(error => console.error('Error fetching lookup data:', error));
  };

  senobjectlookup.initwithchoices = async function () {
    //fetch data for lookup
    await fetch(`${senobjectlookup.url}?pagesize=${senobjectlookup.pagesize}&filter=${JSON.stringify(senobjectlookup.filter)}`)
      .then(response => response.json())
      .then(data => {
        senobjectlookup.data = data.datas;

        const selectVia = document.getElementById("lookup-select-via");
        // Populate the second select (via)
        senobjectlookup.data.forEach(item => {
          const optionVia = document.createElement("option");
          optionVia.value = item.Id; // Assuming Id is the unique identifier
          optionVia.textContent = item.String; // Assuming String is the display value
          selectVia.appendChild(optionVia);

        });


        // Initialize Choices.js for the second select
        const choicesVia = new Choices(selectVia, {
          searchEnabled: true,
          removeItemButton: true
        });

        const selectViaMulti = document.getElementById("lookup-select-via-multi");
        senobjectlookup.data.forEach(item => {
          const optionVia = document.createElement("option");
          optionVia.value = item.Id; // Assuming Id is the unique identifier
          optionVia.textContent = item.String; // Assuming String is the display value
          selectViaMulti.appendChild(optionVia);

        });


        // Initialize Choices.js for the second select
        const choicesViaMulti = new Choices(selectViaMulti, {
          searchEnabled: true,
          removeItemButton: true
        });


        const select = document.getElementById("lookup-select");
        // Initialize Choices.js for the first select
        const choices = new Choices(select, {
          searchEnabled: true,
          removeItemButton: true
        });

      })
      .catch(error => console.error('Error fetching lookup data:', error));
  };


  senobjectlookup.initwithchoices();


  //lookup
  document.getElementById("lookup-select").addEventListener("change", function () {
    var selectedValue = this.value;
    // Thực hiện tìm kiếm hoặc lọc dữ liệu dựa trên giá trị đã chọn
    console.log("Selected value:", selectedValue);
  });

  //lookup via
  document.getElementById("lookup-select-via").addEventListener("change", function () {
    var selectedValue = this.value;
    // Thực hiện tìm kiếm hoặc lọc dữ liệu dựa trên giá trị đã chọn
    console.log("Selected value via:", selectedValue);
  });

  //lookup via multi
  document.getElementById("lookup-select-via-multi").addEventListener("change", function () {
    var selectedValues = Array.from(this.selectedOptions).map(option => option.value);
    // Thực hiện tìm kiếm hoặc lọc dữ liệu dựa trên các giá trị đã chọn
    console.log("Selected values via multi:", selectedValues);
  });


</script>

