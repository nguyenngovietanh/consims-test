<script>
  function lookupcallback(response) {
    // Callback function for lookup
    console.log('Response from lookup:', response);
  }
  function showLookupModal0() {
    const filter = { url: '/senobject/lookup', fields: { id: '`${item.Id}`', value: '`${item.String}`', label: '`${item.Id}-${item.String}`' }, filter: { logic: "and", conditions: [{ field: "String", op: "includes", value: '' }] } };
    const data = [{ id: 1, value: 'option1', label: 'Option 1' }, { id: 2, value: 'option2', label: 'Option 2' }, { id: 3, value: 'option3', label: 'Option 3' }, { id: 4, value: 'option4', label: 'Option 4' }];
    senapp.window.lookup({ options: { multiple: false, callback: 'lookupcallback', data: data } });
  }

  function showLookupModal1() {
    const lookupfilter = {
      url: '/module/lookup', fields: { id: '`${item.ModuleId}`', value: '`${item.Code}`', label: '`${item.Code}-${item.Description}`' },
      //filter: { logic: "and", conditions: [{ field: "Description", op: "includes", value: '' }] }
      filter: { logic: "and", conditions: [{ field: "searchTerm", op: "includes", value: '' }] }
    };
    senapp.window.lookup({ options: { multiple: true, callback: 'lookupcallback', lookup: lookupfilter } });
  }

  function showLookupModal() {
    const lookupfilter = { url: '/senobject/lookup', fields: { id: '`${item.Id}`', value: '`${item.String}`', label: '`${item.Id}-${item.String}`' }, filter: { logic: "and", conditions: [{ field: "String", op: "includes", value: '' }] } };
    const data = [{ id: 1, value: 'option1', label: 'Option 1' }, { id: 2, value: 'option2', label: 'Option 2' }, { id: 3, value: 'option3', label: 'Option 3' }, { id: 4, value: 'option4', label: 'Option 4' }];
    senapp.window.lookup({ options: { multiple: true, callback: 'lookupcallback', lookup: lookupfilter } });
  }

  function lookup({ options } = {}) {
    // Tạo một modal với nội dung có sẵn
    // Nội dung này có thể là HTML hoặc cấu trúc DOM
    // Ví dụ: tạo một select với các tùy chọn
    //#region initialization
    const defaults = {
      title: '',//'Lookup Modal',
      titleselect: '',//'Select an option from the list',
      multiple: false, // Chỉ chọn một hay nhiều
      lookup: null,// { url: '/senobject/lookup', fields: { id: '`${item.Id}`', value: '`${item.String}`', label: '`${item.Id}-${item.String}`' }, filter: { logic: "and", conditions: [{ field: "String", op: "includes", value: '' }] } },
      data: [],//[{id:1,value:'option1',label:'Option 1'},{id:2,value:'option2',label:'Option 2'},{id:3,value:'option3',label:'Option 3'},{id:4,value:'option4',label:'Option 4'}]
    };
    Object.assign(defaults, options);

    // 1) Tạo select + container
    const select = document.createElement('select');
    select.className = 'form-select';
    select.multiple = defaults.multiple;
    select.innerHTML = `${defaults.data.map(item => `<option value="${item.id}">${item.label}</option>`).join('')} `;

    //tạo container là cấu trúc card bootstrap
    const card = document.createElement('div');
    card.className = 'card';
    card.innerHTML = `
    <div class="card-header">
      <h5 class="card-title mb-0">${defaults.title}</h5>
    </div>
    <div class="card-body">
      <p class="card-text">${defaults.titleselect}</p>
    </div>
    <div class="card-footer">
    </div>
  `;
    //tạo 2 nut accept và cancel thêm sự kiện cho chúng không dùng id
    const acceptBtn = document.createElement('button');
    acceptBtn.className = 'btn btn-subtle-primary me-1';
    acceptBtn.innerText = 'Accept';
    const cancelBtn = document.createElement('button');
    cancelBtn.className = 'btn btn-subtle-secondary';
    cancelBtn.innerText = 'Cancel';

    //tạo thêm 2 button accept và cancel gán vào card-footer
    const cardFooter = card.querySelector('.card-footer');
    cardFooter.appendChild(acceptBtn);
    cardFooter.appendChild(cancelBtn);
    card.appendChild(cardFooter);
    //cancel-btn là đóng modal
    cancelBtn.addEventListener('click', () => {
      //đóng modal nếu có
      const modal = card.closest('.modal');
      if (modal) {
        const bootstrapModal = bootstrap.Modal.getInstance(modal);
        bootstrapModal.hide();
      }
    });

    //accept-btn là xác nhận và lấy giá trị
    acceptBtn.addEventListener('click', () => {
      const selectedValues = Array.from(select.selectedOptions).map(option => option.value);
      //console.log('Selected values:', selectedValues);
      // Đóng modal nếu có
      const modal = card.closest('.modal');
      if (modal) {
        const bootstrapModal = bootstrap.Modal.getInstance(modal);
        bootstrapModal.hide();
      }
      //nếu có callback thì gọi callback
      if (options.callback) {
        senapp.utils.executefunctionbyname(options.callback, window, selectedValues);
      }
    });

    //append select vào card body
    const cardBody = card.querySelector('.card-body');
    cardBody.appendChild(select);

    senapp.window.modal({ contentel: card });

    // 4) Khởi tạo Choices *sau* khi select đã ở trong DOM
    const choices = senapp.utils.lookup(select, { searchChoices: !(defaults.lookup) });// new Choices(select,{});



    // // lắng nghe thay đổi: lắng vào chính select là ok
    // select.addEventListener('change', (e) => {
    //   console.log('Selected value:', select.value);
    // });

    //focus vào trường đầu tiên
    // Đợi Choices render xong rồi focus
    setTimeout(() => {
      const firstInput = card.querySelector('.choices');
      if (firstInput) {
        //console.log('Focus vào trường đầu tiên:', firstInput);
        //focus vào trường đầu tiên
        //nếu nằm trong modal thì focus vào trường đầu tiên

        //nếu select có multiple thì 
        if (defaults.multiple) {
          //nếu là multiple thì focus vào trường đầu tiên của select
          const input = firstInput.querySelector('input.choices__input');
          if (input) {
            //console.log('Focus vào trường đầu tiên:', input);
            if (card.closest('.modal')) {
              $(card).closest('.modal').off('shown.bs.modal').on('shown.bs.modal', function () {
                input.focus();
              });
            } else  //nếu không nằm trong modal thì focus vào trường đầu tiên
              input.focus();
          }
        } else {
          if (card.closest('.modal')) {
            $(card).closest('.modal').off('shown.bs.modal').on('shown.bs.modal', function () {
              firstInput.focus();
            });
          } else  //nếu không nằm trong modal thì focus vào trường đầu tiên
            firstInput.focus();
        }
      }
    }, 0);


    const lookup = defaults.lookup;
    if (lookup) {
      select.addEventListener('search', async function (e) {
        const keyword = e.detail.value;
        if (!keyword.endsWith(' ')) return;
        const trimmed = keyword.trim();
        lookup.filter.conditions[0].value = trimmed;
        try {
          const res = await fetch(`${lookup.url}?pagesize=${lookup.pagesize || 0}&filter=${JSON.stringify(lookup.filter)}`);
          lookup.data = [];
          if (res.ok) {
            const data = await res.json();
            lookup.data = data.datas.map(item => ({ id: eval(lookup.fields.id), value: eval(lookup.fields.value), label: eval(lookup.fields.label) }));
          }
        } catch (err) { console.error('Lỗi khi gọi API:', err); }
        choices.setChoices(lookup.data, 'id', 'label', true);
      });
    }
  }


  function showLookupModal2() {
    // 1) Tạo select + container
    const select = document.createElement('select');
    select.className = 'form-select';
    select.innerHTML = `
    <option value="">Select an option</option>
    <option value="option1">Option 1</option>
    <option value="option2">Option 2</option>
    <option value="option3">Option 3</option>
    <option value="option4">Option 4</option>
  `;

    const container = document.createElement('div');
    container.className = 'mb-3';
    // tùy bạn muốn label hay ko
    const label = document.createElement('label');
    label.textContent = 'Chọn một tùy chọn:';
    container.appendChild(label);
    container.appendChild(select);

    // 2) Tạo cấu trúc modal bootstrap (dialog -> content -> header/body/footer)
    const modal = document.createElement('div');
    modal.className = 'modal fade';
    modal.tabIndex = -1;
    modal.setAttribute('role', 'dialog');

    const modalDialog = document.createElement('div');
    modalDialog.className = 'modal-dialog';

    const modalContent = document.createElement('div');
    modalContent.className = 'modal-content';

    // header
    const modalHeader = document.createElement('div');
    modalHeader.className = 'modal-header';
    const title = document.createElement('h5');
    title.className = 'modal-title';
    title.textContent = 'Lookup Modal';
    const btnClose = document.createElement('button');
    btnClose.type = 'button';
    btnClose.className = 'btn-close';
    btnClose.setAttribute('data-bs-dismiss', 'modal');
    btnClose.setAttribute('aria-label', 'Close');
    modalHeader.appendChild(title);
    modalHeader.appendChild(btnClose);

    // body
    const modalBody = document.createElement('div');
    modalBody.className = 'modal-body';
    const p = document.createElement('p');
    p.textContent = 'Chọn một tùy chọn từ danh sách:';
    modalBody.appendChild(p);
    modalBody.appendChild(container); // <-- an toàn: container là Node

    // footer
    const modalFooter = document.createElement('div');
    modalFooter.className = 'modal-footer';
    const btnDismiss = document.createElement('button');
    btnDismiss.type = 'button';
    btnDismiss.className = 'btn btn-secondary';
    btnDismiss.setAttribute('data-bs-dismiss', 'modal');
    btnDismiss.textContent = 'Đóng';

    const btnChoose = document.createElement('button');
    btnChoose.type = 'button';
    btnChoose.className = 'btn btn-primary';
    btnChoose.textContent = 'Chọn';
    btnChoose.addEventListener('click', function () {
      // Ví dụ submitLookup lấy giá trị select hiện tại
      const val = select.value;
      console.log('Chọn:', val);
      if (typeof submitLookup === 'function') submitLookup(val);
      bsModal.hide();
    });

    modalFooter.appendChild(btnDismiss);
    modalFooter.appendChild(btnChoose);

    // ghép lại
    modalContent.appendChild(modalHeader);
    modalContent.appendChild(modalBody);
    modalContent.appendChild(modalFooter);
    modalDialog.appendChild(modalContent);
    modal.appendChild(modalDialog);
    document.body.appendChild(modal);

    // 3) Khởi tạo Bootstrap Modal
    const bsModal = new bootstrap.Modal(modal);
    bsModal.show();

    // 4) Khởi tạo Choices *sau* khi select đã ở trong DOM
    const choices = new Choices(select, {
      removeItemButton: true,
      searchEnabled: true,
      placeholder: true,
      placeholderValue: 'Select an option...'
    });

    // lắng nghe thay đổi: lắng vào chính select là ok
    select.addEventListener('change', (e) => {
      console.log('Selected value:', select.value);
    });

    // 5) Clean up khi modal đóng: xóa element và destroy choices
    modal.addEventListener('hidden.bs.modal', () => {
      try { choices.destroy(); } catch (e) { /* ignore */ }
      modal.remove();
    }, { once: true });
  }

</script>

