<script>

  var selectElement = document.getElementById('country-select');
  var displayDiv = document.getElementById('selected-country');

  var choices = new Choices(selectElement, {
    removeItemButton: true,
    searchEnabled: true,
    searchChoices: false, // Tắt lọc nội bộ, dùng API remote
    placeholder: true,
    placeholderValue: 'Nhập tên quốc gia...'
  }
  );
  console.log('Choices initialized:', choices);

  // Đợi Choices render xong rồi focus
  setTimeout(() => {
    const firstSelect = document.getElementById('country-select').closest('.choices');
    if (firstSelect) {
      //console.log('Focus on first select');
      document.getElementById('country-select').focus();
      const input = firstSelect.querySelector('input');
      input.focus();
      //firstSelect.focus();

    }
  }, 0);


  async function fetchCountries(keyword = '') {
    if (!keyword) return [];

    try {
      const res = await fetch(`https://restcountries.com/v3.1/name/${encodeURIComponent(keyword)}`);
      if (!res.ok) return [];

      const data = await res.json();
      return data.map(country => ({
        value: country.cca2,
        label: country.name.common
      }));
    } catch (err) {
      console.error('Lỗi khi gọi API:', err);
      return [];
    }
  }

  var debounceTimer;
  // selectElement.addEventListener('search', function(e) {
  //   const keyword = e.detail.value;
  //   clearTimeout(debounceTimer);
  //   debounceTimer = setTimeout(async () => {
  //     const options = await fetchCountries(keyword);
  //     choices.setChoices(options, 'value', 'label', true);
  //   }, 400); // debounce 400ms
  // });

  //khi gõ phím space thì sẽ gọi API để tìm kiếm
  selectElement.addEventListener('search', function (e) {
    const keyword = e.detail.value;

    // Kiểm tra nếu vừa gõ phím space (có khoảng trắng)
    if (!keyword.endsWith(' ')) return;

    const trimmed = keyword.trim();
    if (!trimmed) return;

    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(async () => {
      const options = await fetchCountries(trimmed);
      choices.setChoices(options, 'value', 'label', true);
    }, 300);
  });

  // Hiển thị quốc gia đã chọn
  selectElement.addEventListener('change', function (e) {
    const selected = choices.getValue(true); // lấy value
    const label = choices.getValue(true, 'label'); // lấy label
    displayDiv.classList.remove('d-none');
    displayDiv.innerHTML = `🇺🇳 Mã quốc gia: <strong>${selected}</strong> - Tên: <strong>${label}</strong>`;
  });


</script>

<script>


  var senobjectlookupViaAsync = { url: '/senobject/list', data: [], pagesize: 0, filter: { "logic": "and", "conditions": [{ "field": "Boolean", "op": "==", "value": true }, { "field": "String", "op": "includes", "value": '' }] } };
