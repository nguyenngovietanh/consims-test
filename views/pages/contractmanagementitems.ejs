      document.querySelectorAll('footer.footer').forEach(footer => footer.remove());

      // await contractobject.tbl.initTable();
      contractobject.lineobject.model = await senapp.data.getMeta({ url: contractobject.lineobject.urldata.meta });
      contractobject.lineperformobject.model = await senapp.data.getMeta({ url: contractobject.lineperformobject.urldata.meta });

      contractobject.lineobject.loadLine(document.getElementById("contractmanagement-body-section"));//bổ sung cho contract management items

      //gán thông tin dự án hiện hành
