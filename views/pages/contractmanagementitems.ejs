        "ContractName": contractobject.model.data.ContractName || '',
        "ContractType": contractobject.model.data.ContractType || '',
        "ContractId": parseInt(contractobject.model.url.query.ContractId) || 0
      }
      contractobject.tbl.datas.push(data);

      // console.log('Contract Object initialized:', contractobject.model);
      // console.log('Contract Object initialized:', contractobject.tbl.datas);

    });
