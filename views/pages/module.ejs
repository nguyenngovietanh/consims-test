<div id="moduleobject-section">
  <div class="mb-9">
    <h2 class="mb-4"><%- title %></h2>
    <div id="moduleobject-filter" class="mb-3">
      <!-- Filter form will be rendered here -->
    </div>
    <div class="mb-1">
      <div class="btn-group me-1 d-none">
        <div class="dropdown">
          <a class="btn btn-subtle-secondary" href="#" role="button" data-bs-toggle="dropdown" aria-haspopup="true"
            aria-expanded="false"><i class="fa-solid fa-ellipsis-vertical"></i></a>
          <div class="dropdown-menu">
            <!-- <a class="dropdown-item" onclick="moduleobject.tbl.deleteBySelected()">Delete Selected</a>
            <div class="dropdown-divider"></div> -->
            <a class="dropdown-item" onclick="moduleobject.assignToModule()">Assign Member To Module</a>
          </div>
        </div>

      </div>
      <div class="btn-group me-1">
        <a onclick="moduleobject.tbl.create()" class="btn btn-subtle-primary">Create New</a>
        <a onclick="moduleobject.tbl.deleteBySelected()" class="btn btn-subtle-secondary">Delete Selected</a>
      </div>
    </div>

    <div class="row-fluid">
      <div class="card">
        <div class="card-body">
          <div class="search-box mb-3 mx-auto">
            <div class="position-relative"><input class="form-control search-input search form-control-sm" type="search"
                placeholder="Search" aria-label="Search" />
              <span class="fas fa-search search-box-icon"></span>
            </div>
          </div>
          <div class="table-responsive">
            <table class="table table-sm fs-9 mb-5">
              <tbody class="list">
                <!-- Table datas will be added here -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div>
  <script>
    var moduleobject = {};
    moduleobject.model = JSON.parse('<%- JSON.stringify(model) %>');
    moduleobject.container = document.getElementById("moduleobject-section");//khu vực chứa danh sách
    console.log('lists api: /api/get-module-list');
    console.log('create api: /api/upsert-module');
    console.log('update api: /api/upsert-module');
    console.log('delete api: /api/upsert-module');

    moduleobject.urldata = {
      lists: '/module/list',
      item: '/module/item',
      create: '/module/create?callback=' + encodeURIComponent('moduleobject.createcallback'),
      edit: '/module/edit?callback=' + encodeURIComponent('moduleobject.editcallback'),
      delete: '/module/delete',
      assignToModule: '/modulemember/create'
    };
    moduleobject.createcallback = function (response) {
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        senapp.sidebar.menuclickbydatalink('/module');
      }
    };
    moduleobject.editcallback = function (response) {
      if (response[0]) {
        if (response[0].status == 0) {
          alert(response[0].message);
          return;
        }
        senapp.sidebar.menuclickbydatalink('/module');
      }
    };
    // Khởi tạo bảng
    moduleobject.tbl = new senapp.utils.table({
      meta: moduleobject.model.meta,
      urldata: moduleobject.urldata,
      container: moduleobject.container,
      tableelement: moduleobject.container.querySelector('table'),
      modal: true,
      selectcolumn: true,
            deleterow: true, // cho phép xóa
      filterrow: false, // không hiển thị filter row
      //filtercompact: false, // hiển thị filter row ở dạng compact
      // metacolumns: [
      //   { field: 'Ext01', description: '<i class="fa-solid fa-users"></i>', colorder: 1, visible: true, show: true },
      // ],
      // customcolumns: ['Ext01'],
    });

    //mở rộng
    moduleobject.assignToModulecallback = async function (response) {
      // Callback function for lookup
      console.log('Response from assignToModule:', response);
      if (response && response.length > 0) {
        // Process the selected modules
        console.log('Selected members:', response);
        senapp.window.loading.show();
        const tableobject = moduleobject.tbl;
        const selectedKeys = tableobject.getKeySelected();
        try {
          // Tạo mảng Promise bất đồng bộ
          const promises = selectedKeys.flatMap(id =>
            response.map(async m => {
              const newmodulemember = { Id: senapp.data.sessionAutoId(), ModuleId: id, UserId: parseInt(m) };
              //console.log('Adding module member:', newmodulemember);
              // viết hàm post vào moduleobject.urldata.assignToModule bằng fetch
              const res = await fetch(moduleobject.urldata.assignToModule, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(newmodulemember)
              });
              if (!res.ok) { throw new Error(`HTTP error! status: ${res.status}`); }
              const response = await res.json(); // hoặc .text() nếu API không trả JSON
              if (response.status == 0) {
                senapp.window.toast({ message: response.message, type: 'danger' });
              } else {
                senapp.window.toast({ message: response.message, type: 'success' });
              }
            })
          );
          await Promise.all(promises);
          senapp.window.loading.hide();
          console.log("Tất cả đã xong!");
        } catch (err) {
          senapp.window.alert({ message: `⚠️ ${await senapp.utils.text.t('An error occurred while processing:')}`, type: 'danger' });
          console.error("Có lỗi :", err);
        }
      }
      else {
        senapp.window.alert({ message: `⚠️ ${await senapp.utils.text.t('No modules selected.')}`, type: 'warning' });
      }
    };
    moduleobject.assignToModule = async function () {
      const selectedKeys = moduleobject.tbl.getKeySelected();
      if (selectedKeys.length === 0) {
        senapp.window.alert({ message: `⚠️ ${await senapp.utils.text.t('Please select at least one row to assign.')}`, type: 'danger' });
        return;
      }

      const lookupfilter = {
        url: '/member/lookup', fields: { id: '`${item.UserId}`', value: '`${item.UserId}`', label: '`${item.Email}`' },
        //filter: { logic: "and", conditions: [{ field: "Description", op: "includes", value: '' }] }
        filter: { logic: "and", conditions: [{ field: "searchTerm", op: "includes", value: '' }] }
      };
      senapp.window.lookup({ options: { title: 'Select Members', multiple: true, callback: 'moduleobject.assignToModulecallback', lookup: lookupfilter } });
    };

    moduleobject.tbl.genCellDataCustom = function ({ data, metacolumn }) {
      if (!metacolumn || !metacolumn.field) {
        return null; // Trả về null nếu không có metacolumn hoặc field
      }
      // Hàm này sẽ được sử dụng để tạo dữ liệu cho các cột tùy chỉnh
      const tableobject = this;
      const td = document.createElement('td');
      td.setAttribute('data-field', metacolumn.field);
      //nếu field.visible là false hoặc field.show là false thì không hiển thị cột này  gán class d-none
      if (!metacolumn.show) { td.classList.add('d-none'); }
      switch (metacolumn.field) {
        case 'Ext01':
          td.innerHTML = `<a href="javascript:;" onclick="moduleobject.loadLine(this)"><i class="fa fa-ellipsis"></i></a>`;
          break;
        default:
          //nếu không phải là cột tùy chỉnh thì trả về giá trị của trường đó
          td.innerHTML = data[metacolumn.field] || '';
          break;
      }
      return td;
    }

    moduleobject.loadLine = function (element) {
      const tableobject = moduleobject.tbl;
      const id = parseInt(element.closest('tr').getAttribute('data-id'));
      const data = tableobject.datas.find(item => item[tableobject.keyfield] === id);

      const urlline = `/modulemember?viewname=modulememberbymodule&id=${id}`;
      senapp.window.offcanvas({
        title: `User List of ${data["Description"] || ''}`,
        url: urlline
      });
    };

    $(function () { moduleobject.tbl.initTable(); });


  </script>
</div>