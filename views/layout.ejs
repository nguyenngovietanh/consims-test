  <script>
    var senapp = {};
    senapp = JSON.parse('<%- JSON.stringify(senapp) %>');
    //khai báo đối tượng senapp để sử dụng trong các script khác
    senapp.session = { env: {} };//dùng để lưu trữ thông tin phiên làm việc ( ví dụ: senapp.session.role = {})
    senapp.session.env.lang = JSON.parse('<%- JSON.stringify(env.lang) %>');//lưu ngôn ngữ người dùng chọn
    senapp.session.env.culture = 'en-US';//lưu culture người dùng chọn
    senapp.session.env.decimalSeparator = '.';//lưu ký tự phân cách thập phân
    senapp.session.env.thousandSeparator = ',';//lưu ký tự phân cách hàng nghìn
    senapp.session.env.decimalDigits = 0;//lưu số chữ số thập phân

  </script>
  <script src="/assets/js/senapp.js"></script>
</head>

<body>
